{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 900px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Full Bleed Split Layout */
  .custom-hero-split {
    overflow: hidden;
    width: 100%;
  }

  .custom-hero-split__inner {
    display: flex;
    flex-direction: column;
    width: 100%;
    position: relative;
  }

  /* Section Heights */
  .custom-hero-split__inner--small { min-height: 400px; }
  .custom-hero-split__inner--medium { min-height: 600px; }
  .custom-hero-split__inner--large { min-height: 800px; }
  .custom-hero-split__inner--fullscreen { min-height: 100vh; }

  @media screen and (min-width: 900px) {
    .custom-hero-split__inner {
      flex-direction: row;
      align-items: stretch; /* Forces equal height for both columns */
    }
    .custom-hero-split__inner.image-first {
      flex-direction: row-reverse;
    }
  }

  /* Text Column (Page Width Aligned) */
  .custom-hero-split__content-wrapper {
    background: #ffffff; /* Clean white bg for mobile content */
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .custom-hero-split__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    padding: 3rem 2rem 4rem 2rem;
    width: 100%;
    max-width: 600px;
  }

  @media screen and (min-width: 900px) {
    .custom-hero-split__content-wrapper {
      width: 50%;
      justify-content: flex-end; /* Align to the inner center boundary */
      background: linear-gradient(135deg, #fdfbfe 0%, #f4f0fa 100%);
    }
    .custom-hero-split__inner.image-first .custom-hero-split__content-wrapper {
      justify-content: flex-start;
    }
    .custom-hero-split__content {
      max-width: calc(var(--page-width, 1200px) / 2);
      padding: 6rem 4rem 6rem 4rem; 
      margin: 0;
      gap: 2rem;
    }
    .custom-hero-split__inner.image-first .custom-hero-split__content {
      padding: 6rem 2rem 6rem 4rem;
    }
  }

  /* Image Column (Full Bleed) */
  .custom-hero-split__image-wrapper {
    position: relative;
    width: 100%;
    min-height: 380px; /* Ensures image is visible on mobile */
    display: flex;
  }

  @media screen and (min-width: 900px) {
    .custom-hero-split__image-wrapper {
      width: 50%;
      min-height: auto; 
      overflow: hidden;
    }
  }

  .custom-hero-split__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  /* Image Overlay */
  .custom-hero-split__overlay {
    position: absolute;
    inset: 0;
    background: #26215C4D;
    z-index: 1;
    pointer-events: none;
    height: 100%; /* Changed to 100% so it covers fully */
  }

  /* Floating Bar - Mobile First */
  .custom-hero__floating-bar {
    position: absolute;
    bottom: 0; /* Pinned to the bottom of the image */
    left: 0;
    transform: none;
    display: flex;
    width: 100%;
    max-width: 100%;
    background: #fff;
    border-radius: 0;
    box-shadow: none;
    z-index: 2; /* Sits above overlay */
  }

  /* Floating Bar - Desktop */
  @media screen and (min-width: 900px) {
    .custom-hero__floating-bar {
      bottom: 4rem;
      left: 50%;
      transform: translateX(-50%);
      max-width: 600px;
      width: 90%;
      /* border-radius: 8px; */
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
      overflow: hidden;
    }
  }

  .floating-stat {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0.5rem;
    text-align: center;
    align-items: center;
  }
  
  .floating-stat--left { 
    background: #ffffff; 
    flex-direction: row; 
    align-items: center; 
    gap: 0.8rem; 
    padding-left: 1.5rem;
  }
  
  .floating-stat--center { 
    background: #ff007f; 
    color: #ffffff; 
    padding: 1rem 0.5rem;
  }
  
  .floating-stat--right { 
    background: #4a306d; 
    color: #ffffff; 
    flex-direction: row; 
    align-items: center; 
    gap: 0.8rem; 
    padding-right: 1.5rem;
  }

  .stat-val { 
    font-weight: 800; 
    font-size: 13px; 
    margin-bottom: 0.2rem; 
    line-height: 1.1; 
  }
  
  .stat-label { 
    font-size: clamp(0.85rem, 2vw, 1.1rem); 
    opacity: 0.8; 
    line-height: 1.2; 
  }
  
  .stat-icon { 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    width: 28px; 
    height: 28px; 
    border-radius: 50%; 
    flex-shrink: 0;
  }
  
  .stat-icon.star { background: #fae8fc; color: #ff007f; }
  .stat-icon.dish { background: #644d8c; color: #ffffff; }

  /* Top Tags */
  .custom-hero__top-tags {
    display: inline-flex;
    align-items: center;
    background: #f0ecf9;
    border-radius: 50px;
    padding: 0.4rem;
    padding-right: 1.5rem;
    width: fit-content;
    gap: 0.8rem;
    font-size: 1.2rem;
    font-weight: 700;
    color: #6046b6;
  }
  .custom-hero__top-tag-primary {
    background: #6046b6;
    color: #ffffff;
    padding: 0.5rem 1.2rem;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .custom-hero__top-tag-secondary {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  /* Heading */
  .custom-hero__heading {
    margin: 0;
    font-size: clamp(3.2rem, 8vw, 5.4rem);
    line-height: 1.1;
    font-weight: 900;
    color: #2c2c2c;
    letter-spacing: -1px;
    max-width: 600px;
  }
  .custom-hero__heading em {
    font-style: normal;
  }

  /* Text */
  .custom-hero__text {
    font-size: 1.5rem;
    line-height: 1.5;
    color: #666666;
    max-width: 480px;
    margin: 0;
  }

  /* Feature Tags */
  .custom-hero__features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.5rem;
  }
  .custom-hero__feature-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.4rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 500;
    background: #ffffff;
    border: 1px solid #e0e0e0;
    color: #666666;
  }
  .custom-hero__feature-tag.highlight-tag {
    background: #eafff0;
    border-color: #2ba24c;
    color: #2ba24c;
  }
  .custom-hero__feature-tag svg {
    width: 14px;
    height: 14px;
  }

  /* Buttons */
{%- endstyle -%}

<div class="custom-hero-split section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient">
  <div class="custom-hero-split__inner custom-hero-split__inner--{{ section.settings.section_height }} {% if section.settings.layout == 'image_first' %}image-first{% endif %}">
    <div class="custom-hero-split__overlay" style="opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};"> </div>
    {%- comment -%} CONTENT COLUMN (Half Width) {%- endcomment -%}
    <div class="custom-hero-split__content-wrapper">
      <div class="custom-hero-split__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'top_tags' -%}
              <div class="custom-hero__top-tags" {{ block.shopify_attributes }}>
                <div class="custom-hero__top-tag-primary">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                  {{ block.settings.tag_1 }}
                </div>
                <div class="custom-hero__top-tag-secondary">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                  {{ block.settings.tag_2 }}
                </div>
              </div>

            {%- when 'heading' -%}
              <style>
                .custom-hero__heading--{{ block.id }} em {
                  color: {{ block.settings.highlight_color }};
                }
              </style>
              <h1 class="custom-hero__heading custom-hero__heading--{{ block.id }}" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h1>

            {%- when 'text' -%}
              <div class="custom-hero__text" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

            {%- when 'feature_tags' -%}
              <div class="custom-hero__features" {{ block.shopify_attributes }}>
                {%- if block.settings.feature_1 != blank -%}
                  <div class="custom-hero__feature-tag highlight-tag">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {{ block.settings.feature_1 }}
                  </div>
                {%- endif -%}
                {%- if block.settings.feature_2 != blank -%}
                  <div class="custom-hero__feature-tag">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"></line><line x1="12" y1="2" x2="16" y2="6"></line><line x1="12" y1="2" x2="8" y2="6"></line><line x1="12" y1="22" x2="16" y2="18"></line><line x1="12" y1="22" x2="8" y2="18"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="12" x2="6" y2="8"></line><line x1="2" y1="12" x2="6" y2="16"></line><line x1="22" y1="12" x2="18" y2="8"></line><line x1="22" y1="12" x2="18" y2="16"></line><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line><line x1="4.93" y1="19.07" x2="19.07" y2="4.93"></line></svg>
                    {{ block.settings.feature_2 }}
                  </div>
                {%- endif -%}
                {%- if block.settings.feature_3 != blank -%}
                  <div class="custom-hero__feature-tag">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                    {{ block.settings.feature_3 }}
                  </div>
                {%- endif -%}
                {%- if block.settings.feature_4 != blank -%}
                  <div class="custom-hero__feature-tag">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    {{ block.settings.feature_4 }}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'buttons' -%}
              <div class="custom-hero__buttons" {{ block.shopify_attributes }}>
                {%- if block.settings.button_label_1 != blank -%}
                  <a href="{{ block.settings.button_link_1 }}" class="custom-hero__btn custom-hero__btn--primary">
                    {{ block.settings.button_label_1 | escape }}
                  </a>
                {%- endif -%}
                {%- if block.settings.button_label_2 != blank -%}
                  <a href="{{ block.settings.button_link_2 }}" class="custom-hero__btn custom-hero__btn--outline">
                    {{ block.settings.button_label_2 | escape }}
                  </a>
                {%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} IMAGE COLUMN (Half Width) {%- endcomment -%}
    <div class="custom-hero-split__image-wrapper">

      
      {%- if section.settings.media_type == 'video' -%}
        {%- if section.settings.video != blank -%}
          <video 
            class="custom-hero-split__image"
            autoplay 
            muted 
            loop 
            playsinline
          >
            {%- for source in section.settings.video.sources -%}
              <source src="{{ source.url }}" type="{{ source.mime_type }}">
            {%- endfor -%}
          </video>
        {%- elsif section.settings.video_url != blank -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe 
              src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&playlist={{ section.settings.video_url.id }}&controls=0&playsinline=1&showinfo=0&rel=0&modestbranding=1"
              class="custom-hero-split__image"
              frameborder="0"
              allow="autoplay; encrypted-media"
              allowfullscreen
              style="border: 0;"
            ></iframe>
          {%- elsif section.settings.video_url.type == 'vimeo' -%}
            <iframe 
              src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&loop=1&controls=0&background=1"
              class="custom-hero-split__image"
              frameborder="0"
              allow="autoplay; fullscreen"
              allowfullscreen
              style="border: 0;"
            ></iframe>
          {%- endif -%}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'custom-hero-split__image placeholder-svg' }}
        {%- endif -%}
      {%- else -%}
        {%- if section.settings.image != blank -%}
          {%- assign image_alt = section.settings.image.alt | escape -%}
          {{ section.settings.image | image_url: width: 1500 | image_tag: 
            class: 'custom-hero-split__image', 
            widths: '550, 720, 990, 1100, 1500', 
            sizes: '(min-width: 900px) 50vw, 100vw', 
            alt: image_alt,
            fetchpriority: 'high'
          }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'custom-hero-split__image placeholder-svg' }}
        {%- endif -%}
      {%- endif -%}

      {%- assign floating_block = section.blocks | where: "type", "floating_bar" | first -%}
    {%- if floating_block -%}
  <style>
    /* Ensures uploaded images scale down to act like small icons */
    .floating-stat-img {
      width: 28px;
      height: 28px;
      object-fit: contain;
      display: block;
    }
  </style>

  <div class="custom-hero__floating-bar" {{ floating_block.shopify_attributes }}>
    
    <div class="floating-stat floating-stat--left">
      {%- if floating_block.settings.stat_1_image != blank -%}
        <div class="stat-icon star">
          {{ floating_block.settings.stat_1_image | image_url: width: 100 | image_tag: class: 'floating-stat-img', alt: floating_block.settings.stat_1_label, loading: 'lazy' }}
        </div>
      {%- endif -%}
      <div style="text-align: left;">
        <div class="stat-val" style="color: #2c2c2c;">{{ floating_block.settings.stat_1_val }}</div>
        <div class="stat-label" style="color: #888;">{{ floating_block.settings.stat_1_label }}</div>
      </div>
    </div>
    
    <div class="floating-stat floating-stat--center">
      {%- if floating_block.settings.stat_2_image != blank -%}
        <div class="stat-icon">
          {{ floating_block.settings.stat_2_image | image_url: width: 100 | image_tag: class: 'floating-stat-img', alt: floating_block.settings.stat_2_label, loading: 'lazy' }}
        </div>
      {%- endif -%}
      <div style="text-align: center;">
        <div class="stat-val">{{ floating_block.settings.stat_2_val }}</div>
        <div class="stat-label">{{ floating_block.settings.stat_2_label }}</div>
      </div>
    </div>
    
    <div class="floating-stat floating-stat--right">
      {%- if floating_block.settings.stat_3_image != blank -%}
        <div class="stat-icon dish">
          {{ floating_block.settings.stat_3_image | image_url: width: 100 | image_tag: class: 'floating-stat-img', alt: floating_block.settings.stat_3_label, loading: 'lazy' }}
        </div>
      {%- endif -%}
      <div style="text-align: left;">
        <div class="stat-val">{{ floating_block.settings.stat_3_val }}</div>
        <div class="stat-label">{{ floating_block.settings.stat_3_label }}</div>
      </div>
    </div>
    
  </div>
{%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Custom Split Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video",
      "info": "Autoplay background video. Takes priority over the image and YouTube/Vimeo URL."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": [
        "youtube",
        "vimeo"
      ],
      "label": "YouTube or Vimeo Video URL",
      "info": "Autoplay background video. Used if no Shopify-hosted video is selected."
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 10
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "auto", "label": "Adapt to text content" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "fullscreen", "label": "Full screen (100vh)" }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        { "value": "text_first", "label": "Text first" },
        { "value": "image_first", "label": "Image first" }
      ],
      "default": "text_first",
      "label": "Desktop image placement"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "top_tags",
      "name": "Top Tag Pills",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "tag_1", "default": "Halal", "label": "Primary Tag" },
        { "type": "text", "id": "tag_2", "default": "5-Min Ready", "label": "Secondary Tag" }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "default": "Authentic Turkish <em>Homestyle Meals,</em> Delivered to You.", "label": "Heading", "info": "Wrap text in <em> tags to highlight it with the selected color." },
        { "type": "color", "id": "highlight_color", "default": "#6046b6", "label": "Highlight Color" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "default": "<p>Fresh, halal, ready to heat. No cooking required. For the Turkish diaspora across NL, DE & BE.</p>", "label": "Text" }
      ]
    },
    {
      "type": "feature_tags",
      "name": "Feature Tags",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "feature_1", "default": "Halal", "label": "Feature 1 (Highlighted)" },
        { "type": "text", "id": "feature_2", "default": "Never Frozen", "label": "Feature 2" },
        { "type": "text", "id": "feature_3", "default": "Own Fleet", "label": "Feature 3" },
        { "type": "text", "id": "feature_4", "default": "Fresh Daily", "label": "Feature 4" }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "button_label_1", "default": "Start Subscription", "label": "First Button Label" },
        { "type": "url", "id": "button_link_1", "label": "First Button Link" },
        { "type": "text", "id": "button_label_2", "default": "Browse Menu", "label": "Second Button Label" },
        { "type": "url", "id": "button_link_2", "label": "Second Button Link" }
      ]
    },
  {
  "type": "floating_bar",
  "name": "Image Floating Stats Bar",
  "limit": 1,
  "settings": [
    { 
      "type": "image_picker", 
      "id": "stat_1_image", 
      "label": "Stat 1 Image/Icon"
    },
    { "type": "text", "id": "stat_1_val", "default": "4.9 / 5.0", "label": "Stat 1 Value" },
    { "type": "text", "id": "stat_1_label", "default": "2,000+ reviews", "label": "Stat 1 Label" },
    
    { 
      "type": "image_picker", 
      "id": "stat_2_image", 
      "label": "Stat 2 Image/Icon"
    },
    { "type": "text", "id": "stat_2_val", "default": "From €6.38/meal", "label": "Stat 2 Value" },
    { "type": "text", "id": "stat_2_label", "default": "With subscription", "label": "Stat 2 Label" },
    
    { 
      "type": "image_picker", 
      "id": "stat_3_image", 
      "label": "Stat 3 Image/Icon"
    },
    { "type": "text", "id": "stat_3_val", "default": "60+ Dishes", "label": "Stat 3 Value" },
    { "type": "text", "id": "stat_3_label", "default": "Updated weekly", "label": "Stat 3 Label" }
  ]
}
  ],
  "presets": [
    {
      "name": "Custom Split Hero",
      "blocks": [
        { "type": "top_tags" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "feature_tags" },
        { "type": "buttons" },
        { "type": "floating_bar" }
      ]
    }
  ]
}
{% endschema %}