<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('PostcodeCheckerForm');
    const input = document.getElementById('PostcodeChecker-Inline');
    const message = document.getElementById('PostcodeMessage');
    const validPostcodesRaw = JSON.parse(document.getElementById('ValidPostcodesData').textContent || '""');
    const errorText = JSON.parse(document.getElementById('PostcodeErrorText').textContent || '""');
    const successText = JSON.parse(document.getElementById('PostcodeSuccessText').textContent || '""');
    const validList = (validPostcodesRaw || '').split(',').map(p => p.trim().toUpperCase()).filter(p => p.length > 0);
    
    if (sessionStorage.getItem('postcodeVerified') === 'true') {
       window.postcodeVerified = true;
       if (message) { message.textContent = successText; message.className = 'postcode-checker__message is-success'; }
       if (input) input.value = sessionStorage.getItem('postcodeValue') || '';
    } else { window.postcodeVerified = false; }
    
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const val = input.value.trim().toUpperCase();
        if (!val) return;
        const isValid = validList.some(validCode => val.startsWith(validCode));
        if (isValid || validList.length === 0) {
          window.postcodeVerified = true;
          sessionStorage.setItem('postcodeVerified', 'true');
          sessionStorage.setItem('postcodeValue', input.value);
          message.textContent = successText;
          message.className = 'postcode-checker__message is-success';
        } else {
          window.postcodeVerified = false;
          sessionStorage.setItem('postcodeVerified', 'false');
          message.textContent = errorText;
          message.className = 'postcode-checker__message is-error';
        }
      });
    }
  });
</script>

