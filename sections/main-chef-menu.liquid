                {{ "blocks.weekly-menu-choices.show_dishes" | t | default: "Bekijk gerechten" }}
              </button>
            </div>

            <div class="chefs-menu-week-card">
              <div class="chefs-menu-week-card-top">
                {{ product.featured_image | image_url: width: 128 | image_tag: alt: product.title, class: 'chefs-menu-week-card-img' }}
                <h4 class="chefs-menu-week-card-title">{{ "blocks.weekly-menu-choices.week_three" | t | default: "Week 3" }}</h4>
              </div>
              <button class="chefs-menu-week-card-btn" popovertarget="chefs-delivery-{{ current_variant.id }}" type="button">
                {{ "blocks.weekly-menu-choices.show_dishes" | t | default: "Bekijk gerechten" }}
              </button>
            </div>

            <div class="chefs-menu-week-card">
              <div class="chefs-menu-week-card-top">
                {{ product.featured_image | image_url: width: 128 | image_tag: alt: product.title, class: 'chefs-menu-week-card-img' }}
                <h4 class="chefs-menu-week-card-title">{{ "blocks.weekly-menu-choices.week_four" | t | default: "Week 4" }}</h4>
              </div>
              <button class="chefs-menu-week-card-btn" popovertarget="chefs-delivery-{{ current_variant.id }}" type="button">
                {{ "blocks.weekly-menu-choices.show_dishes" | t | default: "Bekijk gerechten" }}
              </button>
            </div>
          </div>
        </chefs-menu-deliveries>

      </div>
    </div>

    <!-- RIGHT COLUMN: SIDEBAR -->
    <div class="meal-builder__sidebar">
      <div class="mb-summary">
        <div class="mb-summary__header">
          <h3>{{ section.settings.sidebar_heading | default: 'Order Summary' }}</h3>
          <p id="sum-subtitle">{{ section.settings.sidebar_subtitle | default: 'Weekly delivery' }}</p>
