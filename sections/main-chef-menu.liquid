        <div class="mb-summary__list-title">{{ section.settings.label_delivery | default: 'DELIVERY' }}</div>
        <ul class="mb-summary__list">
          <li><span>{{ section.settings.label_zone | default: 'Zone' }}</span><span id="sum-zone">{{ sum_zone_default }}</span></li>
          <li><span>{{ section.settings.label_day | default: 'Day' }}</span><span id="sum-day">{{ sum_day_default }}</span></li>
        </ul>

        <div class="mb-summary__list-title">{{ section.settings.label_your_plan | default: 'YOUR PLAN' }}</div>
        <ul class="mb-summary__list">
          <li><span>{{ section.settings.label_days_week | default: 'Days / week' }}</span><span id="sum-days">5</span></li>
          <li><span>{{ section.settings.label_people | default: 'People' }}</span><span id="sum-people">1</span></li>
          <li><span>{{ section.settings.label_duration | default: 'Duration' }}</span><span id="sum-duration">1 Week</span></li>
