        <ul class="mb-summary__list" id="sum-discounts" style="display: none; border-top: 1px solid var(--color-border); padding-top: 16px; margin-top: 16px;">
          <li id="sum-discount-people-row" style="display: none;">
            <span>{{ section.settings.label_discount_people | default: 'Korting voor meerdere personen:' }}</span>
            <span id="sum-discount-people" style="color: var(--color-success); font-weight: 800;">-€0.00</span>
          </li>
          <li id="sum-discount-duration-row" style="display: none;">
            <span>{{ section.settings.label_discount_duration | default: 'Korting voor meerdere weken:' }}</span>
            <span id="sum-discount-duration" style="color: var(--color-success); font-weight: 800;">-€0.00</span>
