        {% assign delivery_date = cart.attributes['Delivery Date'] %}
        {% assign sum_day_default = section.settings.label_day_default | default: 'Not confirmed' %}
        {% assign sum_zone_default = section.settings.label_zone_default | default: 'Not confirmed' %}
        {% if delivery_date != blank %}
          {% assign sum_day_default = delivery_date | date: "%A, %B %e" %}
          {% assign sum_zone_default = section.settings.label_confirmed | default: 'Confirmed' %}
