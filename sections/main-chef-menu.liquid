  </div>

  <!-- Long Plan Confirmation Dialog -->
  <dialog id="mb-confirm-long-plan" class="mb-confirm-modal">
    <div class="mb-confirm-modal__header">
      <div class="mb-confirm-modal__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="16" y1="2" x2="16" y2="6"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="3" y1="10" x2="21" y2="10"></line>
        </svg>
      </div>
      <h3 class="mb-confirm-modal__title">{{ section.settings.confirm_plan_title_prefix | default: "For your" }} <span id="mb-confirm-plan-weeks">12</span>{{ section.settings.confirm_plan_title_suffix | default: "-week plan" }}</h3>
      <p class="mb-confirm-modal__subtitle">{{ section.settings.confirm_plan_subtitle | default: "Here's how your weekly selections work" }}</p>
    </div>
    <div class="mb-confirm-modal__body">
      <ul class="mb-confirm-modal__steps">
        <li class="mb-confirm-modal__step">
          <div class="mb-confirm-modal__step-icon">📋</div>
          <div class="mb-confirm-modal__step-text">
            {{ section.settings.confirm_plan_step1 | default: "<strong>You'll select boxes for the first 4 weeks now.</strong>" }}
          </div>
        </li>
        <li class="mb-confirm-modal__step">
          <div class="mb-confirm-modal__step-icon">🔄</div>
          <div class="mb-confirm-modal__step-text">
            {{ section.settings.confirm_plan_step2 | default: "Your choices for the remaining weeks <strong>can be updated in your account</strong>." }}
          </div>
        </li>
        <li class="mb-confirm-modal__step">
          <div class="mb-confirm-modal__step-icon">✨</div>
          <div class="mb-confirm-modal__step-text">
            {{ section.settings.confirm_plan_step3 | default: "Or your <strong>week 4 selections will automatically repeat</strong>." }}
          </div>
        </li>
      </ul>
    </div>
    <div class="mb-confirm-modal__footer">
      <button type="button" class="mb-confirm-modal__confirm-btn" id="mb-confirm-proceed">{{ section.settings.confirm_plan_btn_proceed | default: "Got it — Place Order" }}</button>
      <button type="button" class="mb-confirm-modal__cancel-btn" id="mb-confirm-cancel">{{ section.settings.confirm_plan_btn_cancel | default: "Go back" }}</button>
    </div>
  </dialog>

</meal-builder>

<script>
  if (!customElements.get('meal-builder')) {
    customElements.define('meal-builder', class MealBuilder extends HTMLElement {

      constructor() {
        super();
        this.state = {
          days: 5,
          people: 1,
          duration: 1,
          boxes: {}, 
          peopleDiscount: 0,
          durationDiscount: 0,
          total: 0,
          planId: null,
          boxType: 'chefs',
          products: {}
        };
      }
      get verified() {
        return (window.postcodeVerified === true || sessionStorage.getItem('postcodeVerified') === 'true') && 
               (window.deliveryDateSelected === true || sessionStorage.getItem('deliveryDateSelected') === 'true');
      }

      triggerVerificationCheck() {
         const picker = document.querySelector('delivery-picker') || document.getElementById('PostcodeChecker-Inline');
         if (picker) { 
           picker.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
           
           const isPostcodeOk = window.postcodeVerified === true || sessionStorage.getItem('postcodeVerified') === 'true';
           if (!isPostcodeOk) {
              if (typeof picker.triggerError === 'function') {
                picker.triggerError(this.dataset.errorDeliveryPostcode || 'Kies een bezorgdatum om verder te gaan.');
              }
              const zipInput = picker.querySelector('input#delivery_zone_zip_code') || picker.querySelector('input');
              if (zipInput) zipInput.focus();
            } else {
               if (typeof picker.triggerError === 'function') {
                 picker.triggerError(this.dataset.errorDeliveryDate || 'Kies eerst een bezorgdatum.');
               }
            }
         }
      }

      connectedCallback() {
        // Move all modals to the document body so they are not affected by parent display:none
        document.querySelectorAll('dialog.mb-modal').forEach(dialog => document.body.appendChild(dialog));

        setTimeout(() => {
          // BUGFIX: Load the selling plans data map emitted by Liquid.
          // This maps plan names -> variant titles -> product IDs -> selling plan IDs.
          const spDataEl = document.getElementById('mb-selling-plans-data');
          if (spDataEl) {
             try {
                this._sellingPlansData = JSON.parse(spDataEl.textContent);
             } catch(e) {
                console.error("Failed to parse mb-selling-plans-data JSON", e);
             }
          }
          
          this.init();
        }, 0);
      }

      init() {
        // --- URL Parameter Initialization ---
        const urlParams = new URLSearchParams(window.location.search);
        let urlDays = urlParams.get('days');
        let urlPeople = urlParams.get('people');
        let urlDurationStr = urlParams.get('duration');
        let urlDuration = urlDurationStr ? parseInt(urlDurationStr, 10) : null;

        if (urlDays) {
           const label = this.querySelector(`#days-selector label[data-value="${urlDays}"]`);
           if (label) {
             this.querySelectorAll('#days-selector label').forEach(l => l.classList.remove('is-active'));
             label.classList.add('is-active');
             const input = label.querySelector('input');
             if (input) input.checked = true;
           }
        }
        if (urlPeople) {
           const label = this.querySelector(`#people-selector label[data-value="${urlPeople}"]`);
           if (label) {
             this.querySelectorAll('#people-selector label').forEach(l => l.classList.remove('is-active'));
             label.classList.add('is-active');
             const input = label.querySelector('input');
             if (input) input.checked = true;
           }
        }
        if (urlDuration) {
           const labels = Array.from(this.querySelectorAll('#duration-selector label'));
           const label = labels.find(l => parseInt(l.dataset.value, 10) === urlDuration);
           if (label) {
             this.querySelectorAll('#duration-selector label').forEach(l => l.classList.remove('is-active'));
             label.classList.add('is-active');
             const input = label.querySelector('input');
             if (input) input.checked = true;
           }
        }

        const activeDays = this.querySelector('#days-selector input:checked');
        const activePeople = this.querySelector('#people-selector input:checked');
        const activeDuration = this.querySelector('#duration-selector input:checked');

        this.state = { 
          days: urlDays ? parseInt(urlDays, 10) : (activeDays ? parseInt(activeDays.value, 10) : 5), 
          people: urlPeople ? parseInt(urlPeople, 10) : (activePeople ? parseInt(activePeople.value, 10) : 1), 
          duration: urlDuration ? urlDuration : (activeDuration ? parseInt(activeDuration.value, 10) : 1), 
          // BUGFIX: Resolve planId from actual product selling plans data, not empty block setting.
          planId: null,
          boxes: {} 
        };
        // Now resolve the initial planId using the selling plans data map
        const initialPlanId = this.resolvePlanId(this.state.duration, this.state.days);
        if (initialPlanId !== null) {
          this.state.planId = initialPlanId;
        } else if (activeDuration && activeDuration.dataset.planId) {
          // Fall back to hardcoded block value if map has no data yet
          this.state.planId = activeDuration.dataset.planId;
        }
        
        // Ensure all initially visible weeks meet the maxBoxes requirement
        const wrappers = this.querySelectorAll('.mb-week-wrapper');
        wrappers.forEach(w => {
          if (parseInt(w.dataset.week) <= this.state.duration) {
             const weekInputs = Array.from(w.querySelectorAll('.mb-qty input'));
             let currentTotal = weekInputs.reduce((sum, inp) => sum + parseInt(inp.value), 0);
             const toAdd = this.maxBoxes - currentTotal;
             if (toAdd > 0) {
               const targetInput = weekInputs.find(inp => parseInt(inp.value) > 0) || weekInputs[0];
               if (targetInput) {
                  targetInput.value = parseInt(targetInput.value) + toAdd;
               }
             }
          }
        });

        const qtyGroups = this.querySelectorAll('.mb-qty');
        qtyGroups.forEach(group => {
          const input = group.querySelector('input');
          const qty = parseInt(input.value);
          if (qty > 0) {
             const productId = group.dataset.productId;
             const price = parseFloat(group.dataset.price) / 100;
             const title = group.dataset.title;
             const weekWrapper = group.closest('.mb-week-wrapper');
             const week = weekWrapper ? weekWrapper.dataset.week : "1";
             const key = `${productId}_${week}`;
             this.state.boxes[key] = { productId, week, qty, price, title };
          }
        });

        this.bindEvents();
        this.updateWeekTabsVisibility();
        this.recalculateDiscounts();
        this.updateUI();
        this.rerenderDialogs();
      }

      recalculateDiscounts() {
        const durDiscounts = {1: 0, 4: 0.07, 12: 0.20, 24: 0.25};
        this.state.durationDiscount = durDiscounts[this.state.duration] || 0;

        const pDiscounts = {1: 0, 2: 0.15, 3: 0.20, 4: 0.30};
        this.state.peopleDiscount = pDiscounts[this.state.people] || 0;
      }

      /**
       * BUGFIX: Resolve the correct Shopify selling_plan ID from the data map
       * emitted server-side by Liquid (mb-selling-plans-data).
       *
       * The subscription_plan blocks have empty selling_plan_id settings because
       * selling plans are tied to product variants, not theme blocks. This method
       * finds the right plan by matching:
       *   - Plan name (contains the week count, e.g. "4 weken", "12 weken")
       *   - Variant title (the days count, e.g. "5", "7")
       *   - Optionally a specific product ID
       *
       * @param {number} durationWeeks - The selected subscription duration in weeks
       * @param {number} daysCount - The selected days per week count
       * @param {string|null} productId - Optional: specific product ID to look up
       * @returns {number|null} - The selling plan ID, or if not found
       */
      resolvePlanId(durationWeeks, daysCount, productId = null) {
        if (!this._sellingPlansData) return null;
        const data = this._sellingPlansData;
        const daysStr = daysCount.toString();
        const weeksNum = parseInt(durationWeeks, 10);

        // For 1-week plans, no selling plan needed (one-time purchase)
        if (weeksNum <= 1) return null;

        // Map weeks to their expected duration and discount percentage values
        const durationSpecs = {
          4: { duration: 4, discount: 7, exclude: [12, 20, 24, 25] },
          12: { duration: 12, discount: 20, exclude: [24, 25] },
          24: { duration: 24, discount: 25, exclude: [12, 20] }
        };

        const spec = durationSpecs[weeksNum] || { duration: weeksNum, discount: null, exclude: [] };

        // Find the plan name that matches the selected duration or discount
        for (const planName of Object.keys(data)) {
          const planNameLower = planName.toLowerCase();
          const numbers = (planNameLower.match(/\d+/g) || []).map(num => parseInt(num, 10));

          // Check if the plan contains any of the excluded numbers for other durations
          const hasExcluded = spec.exclude.some(ex => numbers.includes(ex));
          if (hasExcluded) continue;

          // Check if the plan matches our duration or its discount percentage
          const isMatch = numbers.includes(spec.duration) || (spec.discount !== null && numbers.includes(spec.discount));
          if (!isMatch) continue;

          const variantMap = data[planName];
          if (!variantMap) continue;

          // Find the variant title matching the days count
          const variantKey = Object.keys(variantMap).find(title => parseInt(title, 10) === parseInt(daysStr, 10));
          if (!variantKey) continue;

          const productMap = variantMap[variantKey];
          if (!productMap) continue;

          // If a specific product is requested, look it up directly
          if (productId !== null) {
            const pid = productId.toString();
            if (productMap[pid] !== undefined) return parseInt(productMap[pid], 10);
            continue;
          }

          // Otherwise return the first available plan ID for this variant
          const firstId = Object.values(productMap)[0];
          if (firstId !== undefined) return parseInt(firstId, 10);
        }

        return null;
      }

      get maxBoxes() {
        return this.state.people;
      }

      addToDefault(amount) {
        const allGroups = Array.from(this.querySelectorAll('.mb-qty'));
        const defaultGroups = allGroups.filter(g => {
           const input = g.querySelector('input');
           return input && parseInt(input.value) > 0;
        });

        const targetGroup = defaultGroups.length > 0 ? defaultGroups[0] : allGroups[0];
        if (targetGroup) {
           const input = targetGroup.querySelector('input');
           const weekWrapper = targetGroup.closest('.mb-week-wrapper');
           const week = weekWrapper ? weekWrapper.dataset.week : "1";
           const productId = targetGroup.dataset.productId;
           const price = parseFloat(targetGroup.dataset.price) / 100;
           const title = targetGroup.dataset.title;
           
           const currentQty = parseInt(input.value);
           const newQty = currentQty + amount;
           input.value = newQty;
           this.updateBoxes(productId, week, newQty, price, title);
        }
      }

      removeFromQuantities(amount) {
        let remainingToRemove = amount;
        const allInputs = this.querySelectorAll('.mb-qty input');

        allInputs.forEach(input => {
          if (remainingToRemove <= 0) return;
          const currentQty = parseInt(input.value);
          if (currentQty > 0) {
            const canRemove = Math.min(currentQty, remainingToRemove);
            const newQty = currentQty - canRemove;
            input.value = newQty;
            remainingToRemove -= canRemove;

            const group = input.closest('.mb-qty');
            const weekWrapper = group.closest('.mb-week-wrapper');
            const week = weekWrapper ? weekWrapper.dataset.week : "1";
            const productId = group.dataset.productId;
            const price = parseFloat(group.dataset.price) / 100;
            const title = group.dataset.title;

            this.updateBoxes(productId, week, newQty, price, title);
          }
        });
      }

      handlePeopleChange(oldValue, newValue) {
        const delta = parseInt(newValue, 10) - parseInt(oldValue, 10);
        if (delta > 0) {
           const wrappers = this.querySelectorAll('.mb-week-wrapper');
           wrappers.forEach(w => {
             if (w.style.display !== 'none') {
               const weekInputs = Array.from(w.querySelectorAll('.mb-qty input'));
               let currentTotal = weekInputs.reduce((sum, inp) => sum + parseInt(inp.value), 0);
               const toAdd = this.maxBoxes - currentTotal;
               if (toAdd > 0) {
                 const targetInput = weekInputs.find(inp => parseInt(inp.value) > 0) || weekInputs[0];
                 if (targetInput) {
                    targetInput.value = parseInt(targetInput.value) + toAdd;
                    const group = targetInput.closest('.mb-qty');
                    const productId = group.dataset.productId;
                    const price = parseFloat(group.dataset.price) / 100;
                    const title = group.dataset.title;
                    const week = w.dataset.week;
                    this.updateBoxes(productId, week, parseInt(targetInput.value), price, title);
                 }
               }
             }
           });
        } else if (delta < 0) {
           const wrappers = this.querySelectorAll('.mb-week-wrapper');
           wrappers.forEach(w => {
             const weekInputs = Array.from(w.querySelectorAll('.mb-qty input'));
             let currentTotal = weekInputs.reduce((sum, inp) => sum + parseInt(inp.value), 0);
             let toRemove = currentTotal - this.maxBoxes;
             if (toRemove > 0) {
               weekInputs.forEach(input => {
                 if (toRemove <= 0) return;
                 const qty = parseInt(input.value);
                 if (qty > 0) {
                   const removeAmt = Math.min(qty, toRemove);
                   input.value = qty - removeAmt;
                   toRemove -= removeAmt;
                   const group = input.closest('.mb-qty');
                   const productId = group.dataset.productId;
                   const price = parseFloat(group.dataset.price) / 100;
                   const title = group.dataset.title;
                   const week = w.dataset.week;
                   this.updateBoxes(productId, week, parseInt(input.value), price, title);
                 }
               });
             }
           });
        }
      }

        handleDurationChange(oldValue, newValue) {
          const wrappers = this.querySelectorAll('.mb-week-wrapper');
          wrappers.forEach(w => {
            const weekNum = parseInt(w.dataset.week);
            if (weekNum <= this.state.duration) {
              w.style.display = 'block';
              
              // Ensure this newly revealed week has exactly maxBoxes selected
              const weekInputs = Array.from(w.querySelectorAll('.mb-qty input'));
              let currentTotal = weekInputs.reduce((sum, inp) => sum + parseInt(inp.value), 0);
              
              if (currentTotal < this.maxBoxes) {
                 const toAdd = this.maxBoxes - currentTotal;
                 const targetInput = weekInputs.find(inp => parseInt(inp.value) > 0) || weekInputs[0];
                 if (targetInput) {
                    targetInput.value = parseInt(targetInput.value) + toAdd;
                    const group = targetInput.closest('.mb-qty');
                    this.updateBoxes(group.dataset.productId, w.dataset.week, parseInt(targetInput.value), parseFloat(group.dataset.price)/100, group.dataset.title);
                 }
              } else if (currentTotal > this.maxBoxes) {
                 let toRemove = currentTotal - this.maxBoxes;
                 weekInputs.forEach(input => {
                   if (toRemove <= 0) return;
                   const qty = parseInt(input.value);
                   if (qty > 0) {
                     const removeAmt = Math.min(qty, toRemove);
                     input.value = qty - removeAmt;
                     toRemove -= removeAmt;
                     const group = input.closest('.mb-qty');
                     this.updateBoxes(group.dataset.productId, w.dataset.week, parseInt(input.value), parseFloat(group.dataset.price)/100, group.dataset.title);
                   }
                 });
              }
            } else {
              w.style.display = 'none';
              
              // Zero out all products in hidden weeks so they are removed from summary & cart
              const weekInputs = Array.from(w.querySelectorAll('.mb-qty input'));
              weekInputs.forEach(input => {
                 if (parseInt(input.value) > 0) {
                    input.value = 0;
                    const group = input.closest('.mb-qty');
                    this.updateBoxes(group.dataset.productId, w.dataset.week, 0, parseFloat(group.dataset.price)/100, group.dataset.title);
                 }
              });
            }
          });
        }

      bindEvents() {
        const handleRadioGroup = (containerId, stateKey) => {
          const container = this.querySelector(containerId);
          if(!container) return;
          const labels = container.querySelectorAll('label');
          labels.forEach(label => {
            label.addEventListener('click', (e) => {
              if (e.target.closest('.mb-sub-card__extra-buttons')) return;

              if (!this.verified) {
                 e.preventDefault();
                 e.stopPropagation();
                 this.triggerVerificationCheck();
                 return;
              }

              let linkUrl = label.dataset.link;
              const parsedValue = parseInt(label.dataset.value, 10);

              // Simple URL redirect for 1/4 weeks to Weekly Menu
              if (stateKey === 'duration' && (parsedValue === 1 || parsedValue === 4)) {
                e.preventDefault();
                e.stopPropagation();
                linkUrl = this.dataset.pickAndMixUrl || "/pages/wekelijks-menu";
                window.location.href = `${linkUrl}?duration=${parsedValue}&people=${this.state.people}&days=${this.state.days}`;
                return;
              }

              labels.forEach(l => l.classList.remove('is-active'));
              label.classList.add('is-active');
              
              const input = label.querySelector('input');
              if(input) input.checked = true;

              const oldValue = this.state[stateKey];
              const newValue = parseInt(input ? input.value : label.dataset.value);
              this.state[stateKey] = newValue;
              
              if(stateKey === 'duration') {
                // BUGFIX: Resolve planId dynamically from the selling plans data map
                // (block.settings.selling_plan_id is empty in template — plans come from products).
                // Fall back to the hardcoded block data-plan-id only if map lookup fails.
                const planId = this.resolvePlanId(newValue, this.state.days);
                this.state.planId = planId !== null ? planId : (label.dataset.planId || null);
                this.handleDurationChange(oldValue, newValue);
                this.updateWeekTabsVisibility();
                
                if (window.innerWidth <= 768 && !window._skipSummaryScroll) {
                  const summaryArea = this.querySelector('.mb-summary');
                  if (summaryArea) {
                    summaryArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                  }
                }
              }

              if(stateKey === 'people') {
                this.handlePeopleChange(oldValue, newValue);
              }

              if (stateKey === 'days' || stateKey === 'people' || stateKey === 'duration') {
                this.recalculateDiscounts();
              }

              if (stateKey === 'days') {
                // Re-resolve planId when days change (different variant = different plan IDs)
                const planId = this.resolvePlanId(this.state.duration, newValue);
                if (planId !== null) this.state.planId = planId;
                this.updateUI();
                this.rerenderDialogs();
                this.updatePricesOnCards();
              } else {
                this.updateUI();
              }
            });
          });
        };

        handleRadioGroup('#days-selector', 'days');
        handleRadioGroup('#people-selector', 'people');
        handleRadioGroup('#duration-selector', 'duration');

        this.querySelectorAll('.mb-sub-card__extra-buttons button, .mb-sub-card__extra-buttons a').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const parent = btn.closest('.mb-sub-card');

            if (!this.verified) {
               e.preventDefault();
               e.stopPropagation();
               this.triggerVerificationCheck();
               return;
            }

            const isChefs = btn.classList.contains('btn-chef');
            if (!isChefs) {
              e.stopPropagation();
              return;
            }

            e.preventDefault();
            e.stopPropagation();

            if(!parent.classList.contains('is-active')) {
               window._skipSummaryScroll = true;
               parent.click();
               window._skipSummaryScroll = false;
            }

            this.state.boxType = 'chefs';
            
            const buttons = parent.querySelectorAll('button');
            buttons.forEach(b => b.classList.remove('is-selected'));
            btn.classList.add('is-selected');

            this.updateUI();

            setTimeout(() => {
              const targetSection = document.getElementById('meal-boxes-section');
              if (targetSection) {
                targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
              }
            }, 50);
          });
        });

        const qtyGroups = this.querySelectorAll('.mb-qty');
        qtyGroups.forEach(group => {
          const minus = group.querySelector('.mb-qty__minus');
          const plus = group.querySelector('.mb-qty__plus');
          const input = group.querySelector('input');
          const productId = group.dataset.productId;
          const weekWrapper = group.closest('.mb-week-wrapper');
          const week = weekWrapper ? weekWrapper.dataset.week : "1";

          plus.addEventListener('click', () => {
            if (!this.verified) {
               this.triggerVerificationCheck();
               return;
            }

            const weekInputs = Array.from(weekWrapper.querySelectorAll('.mb-qty input'));
            const currentTotal = weekInputs.reduce((sum, inp) => sum + parseInt(inp.value), 0);

            if (currentTotal < this.maxBoxes) {
              let current = parseInt(input.value);
              input.value = current + 1;
              const price = parseFloat(group.dataset.price) / 100;
              const title = group.dataset.title;
              this.updateBoxes(productId, week, parseInt(input.value), price, title);
            }
          });

          minus.addEventListener('click', () => {
            if (!this.verified) {
               this.triggerVerificationCheck();
               return;
            }
            let current = parseInt(input.value);
            if (current > 0) {
              input.value = current - 1;
              const price = parseFloat(group.dataset.price) / 100;
              const title = group.dataset.title;
              this.updateBoxes(productId, week, parseInt(input.value), price, title);
            }
          });
        });

        const submitBtn = this.querySelector('#place-order-btn');
        if(submitBtn) submitBtn.addEventListener('click', () => this.submitToCart());

        document.addEventListener('delivery-picker:updated', (e) => {
          const sumDay = this.querySelector('#sum-day');
          const sumZone = this.querySelector('#sum-zone');
          if (e.detail.deliveryDate) {
             const d = new Date(e.detail.deliveryDate);
             if (sumDay) {
                const locale = window.Shopify?.locale || document.documentElement.lang || 'nl';
                sumDay.textContent = d.toLocaleDateString(locale, { weekday: 'long', month: 'long', day: 'numeric' });
             }
             if (sumZone) sumZone.textContent = this.dataset.confirmedText || 'Confirmed';
          } else {
             if (sumDay) sumDay.textContent = this.dataset.notConfirmedText || 'Not confirmed';
             if (sumZone) sumZone.textContent = this.dataset.notConfirmedText || 'Not confirmed';
          }
        });
      }

      updateWeekTabsVisibility() {
        const wrappers = this.querySelectorAll('.mb-week-wrapper');
        wrappers.forEach(w => {
          if (parseInt(w.dataset.week) <= this.state.duration) {
            w.style.display = 'block';
          } else {
            w.style.display = 'none';
          }
        });
      }

      updateBoxes(productId, week, qty, price, title) {
        const key = productId + '_' + week;
        if (qty === 0) {
          delete this.state.boxes[key];
        } else {
          this.state.boxes[key] = { productId, week, qty, price, title };
        }
        this.updateUI();
      }

      updatePricesOnCards() {
        const currentDaysStr = this.state.days.toString();
        // Update DOM elements on product cards
        this.querySelectorAll('.mb-product__price').forEach(el => {
           const pid = el.dataset.productId;
           if (!pid || pid.startsWith('dummy')) return;
           const group = el.nextElementSibling;
           if (group && group.classList.contains('mb-qty') && group.dataset.variants) {
             const variantsData = JSON.parse(group.dataset.variants);
             const variantData = variantsData.find(v => parseInt(v.title, 10) === this.state.days);
             if (variantData) {
               // Update UI price text
               el.textContent = '€' + (variantData.price / 100).toFixed(2);
               // Update the data-price so additions are calculated correctly
               group.dataset.price = variantData.price;
             }
           }
        });
        
        // Update data-price on qty inputs so new additions use the right price
        this.querySelectorAll('.mb-qty').forEach(group => {
           const pid = group.dataset.productId;
           if (!pid || pid.startsWith('dummy')) return;
           if (group.dataset.variants) {
             const variantsData = JSON.parse(group.dataset.variants);
             const variantData = variantsData.find(v => parseInt(v.title, 10) === this.state.days);
             if (variantData) {
               group.dataset.price = variantData.price;
             }
           }
        });

        // Update existing box states to reflect new price
        Object.keys(this.state.boxes).forEach(key => {
           const box = this.state.boxes[key];
           if (box.productId.startsWith('dummy')) return;
           const group = this.querySelector(`.mb-qty[data-product-id="${box.productId}"]`);
           if (group && group.dataset.variants) {
             const variantsData = JSON.parse(group.dataset.variants);
             const variantData = variantsData.find(v => parseInt(v.title, 10) === this.state.days);
             if (variantData) {
                box.price = variantData.price / 100;
             }
           }
        });
      }

  rerenderDialogs() {
        if (!this.state.currentVariantId) return;
        const currentVariantIdStr = this.state.currentVariantId.toString();
        
        this.querySelectorAll('.weekly-menu-dishes__show').forEach(btn => {
           btn.setAttribute('popovertarget', 'chefs-delivery-' + currentVariantIdStr);
        });
      }

      updateUI() {
        const sumDays = this.querySelector('#sum-days');
        if(sumDays) sumDays.textContent = this.state.days;
        
        const sumPeople = this.querySelector('#sum-people');
        if(sumPeople) sumPeople.textContent = this.state.people;
        
        const sumDuration = this.querySelector('#sum-duration');
         if(sumDuration) {
           const weekLabel = this.state.duration > 1 
             ? (this.dataset.labelWeekPlural || 'weken') 
             : (this.dataset.labelWeekSingular || 'week');
           sumDuration.textContent = `${this.state.duration} ${weekLabel}`;
         }
        
        const sumDurationLabel = this.querySelector('#sum-duration-label');
        if (sumDurationLabel) {
           if (this.state.duration > 1) {
             const displayWeeks = 4; // Always billed in 4-week cycles for subscriptions
             const weekLabel = displayWeeks > 1 
               ? (this.dataset.labelWeekPlural || 'weken') 
               : (this.dataset.labelWeekSingular || 'week');
             sumDurationLabel.textContent = `${this.dataset.labelPer || 'per'} ${displayWeeks} ${weekLabel}`;
             sumDurationLabel.style.display = 'block';
           } else {
             sumDurationLabel.style.display = 'none';
           }
        }

        const sumSubtitle = this.querySelector('#sum-subtitle');
        if (sumSubtitle) {
           sumSubtitle.style.display = this.state.duration > 1 ? '' : 'none';
        }

        // --- Chef's Menu Box Logic ---
        let baseBoxTotal = 0;
        let productId = null;
        let variantId = null;
        let productTitle = '';

        // Try to find the default product data
        const spDataEl = document.getElementById('mb-products-data');
        if (spDataEl) {
          try {
            const productsData = JSON.parse(spDataEl.textContent);
            const firstProductKey = Object.keys(productsData)[0];
            if (firstProductKey) {
              const prod = productsData[firstProductKey];
              productId = prod.id;
              productTitle = prod.title;
              const variant = prod.variants.find(v => parseInt(v.title) === this.state.days);
              if (variant) {
                const displayWeeks = this.state.duration > 1 ? 4 : 1;
                baseBoxTotal = (variant.price / 100) * this.state.people * displayWeeks;
                variantId = variant.id;
              }
            }
          } catch(e) {}
        }
        
        // Save the variant info for submitToCart
        this.state.currentVariantId = variantId;
        this.state.currentProductId = productId;

        const boxesContainer = this.querySelector('#sum-boxes');
        if(boxesContainer && productTitle) {
          boxesContainer.innerHTML = `<li><span>${this.state.people}x ${productTitle}</span></li>`;
        }

        const durationDiscAmount = baseBoxTotal * this.state.durationDiscount;
        const discountedBase = baseBoxTotal - durationDiscAmount;
        const peopleDiscAmount = discountedBase * this.state.peopleDiscount;
        const totalDiscountAmount = peopleDiscAmount + durationDiscAmount;
        this.state.total = baseBoxTotal - totalDiscountAmount;

        const sumDiscPeopleRow = this.querySelector('#sum-discount-people-row');
        const sumDiscPeople = this.querySelector('#sum-discount-people');
        if (sumDiscPeopleRow && sumDiscPeople) {
          if (peopleDiscAmount > 0) {
            sumDiscPeopleRow.style.display = 'flex';
            sumDiscPeople.textContent = '-€' + peopleDiscAmount.toFixed(2);
          } else {
            sumDiscPeopleRow.style.display = 'none';
          }
        }

        const sumDiscDurationRow = this.querySelector('#sum-discount-duration-row');
        const sumDiscDuration = this.querySelector('#sum-discount-duration');
        if (sumDiscDurationRow && sumDiscDuration) {
          if (durationDiscAmount > 0) {
            sumDiscDurationRow.style.display = 'flex';
            sumDiscDuration.textContent = '-€' + durationDiscAmount.toFixed(2);
          } else {
            sumDiscDurationRow.style.display = 'none';
          }
        }

        const sumDiscountsList = this.querySelector('#sum-discounts');
        if (sumDiscountsList) {
          sumDiscountsList.style.display = totalDiscountAmount > 0 ? 'block' : 'none';
        }

        const totalNode = this.querySelector('#sum-total');
        if(totalNode) totalNode.textContent = '€' + this.state.total.toFixed(2);

        const originalTotalNode = this.querySelector('#sum-original-total');
        if (originalTotalNode) {
          if (totalDiscountAmount > 0) {
            originalTotalNode.style.display = 'inline-block';
            originalTotalNode.textContent = '€' + baseBoxTotal.toFixed(2);
          } else {
            originalTotalNode.style.display = 'none';
          }
        }

        const submitBtn = this.querySelector('#place-order-btn');
        if(submitBtn) {
          if (variantId) {
            submitBtn.classList.add('is-ready');
            submitBtn.disabled = false;
          } else {
            submitBtn.classList.remove('is-ready');
            submitBtn.disabled = true;
          }
        }
      }

      submitToCart() {
        const btn = this.querySelector('#place-order-btn');
        if (!btn || !btn.classList.contains('is-ready')) return;

        if (!this.verified) {
           this.triggerVerificationCheck();
           return;
        }

        if (!this.state.currentVariantId) return;

        // For 12/24 week plans, show confirmation dialog first
        if ((this.state.duration === 12 || this.state.duration === 24) && !this._longPlanConfirmed) {
          const dialog = this.querySelector('#mb-confirm-long-plan');
          if (dialog) {
            const weeksSpan = dialog.querySelector('#mb-confirm-plan-weeks');
            if (weeksSpan) weeksSpan.textContent = this.state.duration;

            const confirmBtn = dialog.querySelector('#mb-confirm-proceed');
            const cancelBtn = dialog.querySelector('#mb-confirm-cancel');

            // Remove previous listeners by cloning
            const newConfirm = confirmBtn.cloneNode(true);
            confirmBtn.parentNode.replaceChild(newConfirm, confirmBtn);
            const newCancel = cancelBtn.cloneNode(true);
            cancelBtn.parentNode.replaceChild(newCancel, cancelBtn);

            newConfirm.addEventListener('click', () => {
              dialog.close();
              this._longPlanConfirmed = true;
              this.submitToCart();
            });
            newCancel.addEventListener('click', () => {
              dialog.close();
            });

            dialog.showModal();
            return;
          }
        }
        this._longPlanConfirmed = false;

        const addingText = this.dataset.addingText || 'Adding...';
        btn.textContent = addingText;
        btn.disabled = true;

        const itemsToAdd = [];
        const resolvedPlanId = this.resolvePlanId(this.state.duration, this.state.days, this.state.currentProductId)
            ?? (this.state.planId && !isNaN(parseInt(this.state.planId, 10)) ? parseInt(this.state.planId, 10) : null);

        const item = {
          id: this.state.currentVariantId,
          quantity: this.state.people,
          properties: {}
        };
        
        if (resolvedPlanId !== null && !isNaN(resolvedPlanId)) {
          item.selling_plan = resolvedPlanId;
        }
        
        itemsToAdd.push(item);

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            items: itemsToAdd,
            sections: document.querySelector('cart-drawer') ? 'cart-drawer,cart-icon-bubble' : undefined,
            sections_url: window.location.pathname
          })
        })
        .then(response => {
          if(!response.ok) throw new Error('Error adding to cart');
          return response.json();
        })
        .then((parsedState) => {
          const addedText = this.dataset.addedText || 'Added to Cart!';
          btn.textContent = addedText;
          const cartDrawer = document.querySelector('cart-drawer');
          if (cartDrawer && parsedState.sections) {
             cartDrawer.renderContents(parsedState);
          } else {
             window.location.href = window.Shopify.routes.root + 'cart';
          }
          setTimeout(() => { 
            btn.textContent = btn.dataset.defaultText || 'Place Order'; 
            btn.disabled = false; 
          }, 2000);
        })
        .catch(error => {
          console.error('Cart error:', error);
          const errorTextMsg = this.dataset.errorText || 'Error — try again';
          btn.textContent = errorTextMsg;
          setTimeout(() => { btn.textContent = btn.dataset.defaultText || 'Place Order'; btn.disabled = false; }, 3000);
        });
      }
    });
  }
</script>

{%- comment -%}
  BUGFIX: Emit a selling plans data map from Liquid so the JS can resolve the
  correct Shopify selling_plan ID for any combination of (duration_weeks, variant_days, product_id).
  Structure: { "<planName>": { "<variantTitle>": { "<productId>": planId } } }
  This is built from actual selling_plan_allocations on each product variant.
{%- endcomment -%}
<script type="application/json" id="mb-selling-plans-data">
  {
    {%- assign sp_first_plan = true -%}
    {%- assign sp_plan_names = ',' -%}

    {%- comment -%} Gather all products from tabs and collection {%- endcomment -%}
    {%- assign sp_products_list = '' -%}
    {%- if product != blank -%}
      {%- assign sp_products_list = sp_products_list | append: product.handle | append: ',' -%}
    {%- endif -%}
    {%- if section.settings.default_product != blank -%}
      {%- unless sp_products_list contains section.settings.default_product.handle -%}
        {%- assign sp_products_list = sp_products_list | append: section.settings.default_product.handle | append: ',' -%}
      {%- endunless -%}
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'week_tab' -%}
        {%- if block.settings.collection != blank -%}
          {%- assign week_collection = block.settings.collection -%}
        {%- else -%}
          {%- assign week_collection = section.settings.collection -%}
        {%- endif -%}
        {%- if week_collection != blank -%}
          {%- for product in week_collection.products -%}
            {%- unless sp_products_list contains product.handle -%}
              {%- assign sp_products_list = sp_products_list | append: product.handle | append: ',' -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if section.settings.collection != blank -%}
      {%- for product in section.settings.collection.products -%}
        {%- unless sp_products_list contains product.handle -%}
          {%- assign sp_products_list = sp_products_list | append: product.handle | append: ',' -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}

    {%- assign sp_products_handles = sp_products_list | split: ',' -%}

    {%- for sp_handle in sp_products_handles -%}
      {%- if sp_handle != blank -%}
        {%- assign sp_product = all_products[sp_handle] -%}
        {%- for sp_variant in sp_product.variants -%}
          {%- for sp_alloc in sp_variant.selling_plan_allocations -%}
            {%- assign sp_plan = sp_alloc.selling_plan -%}
            {%- assign sp_plan_key = sp_plan.name | handleize -%}
            {%- assign lookup_token = ',' | append: sp_plan_key | append: ',' -%}
            {%- unless sp_plan_names contains lookup_token -%}
              {%- unless sp_first_plan -%},{%- endunless -%}
              {{ sp_plan.name | json }}: {
                {%- assign sp_first_var_in_plan = true -%}
                {%- for sp_var2 in sp_product.variants -%}
                  {%- for sp_alloc2 in sp_var2.selling_plan_allocations -%}
                    {%- if sp_alloc2.selling_plan.name == sp_plan.name -%}
                      {%- unless sp_first_var_in_plan -%},{%- endunless -%}
                      {{ sp_var2.title | json }}: {
                        {%- assign sp_first_prod_in_var = true -%}
                        {%- for sp_handle2 in sp_products_handles -%}
                          {%- if sp_handle2 != blank -%}
                            {%- assign sp_product2 = all_products[sp_handle2] -%}
                            {%- for sp_alloc3 in sp_product2.variants -%}
                              {%- if sp_alloc3.title == sp_var2.title -%}
                                {%- for sp_alloc4 in sp_alloc3.selling_plan_allocations -%}
                                  {%- if sp_alloc4.selling_plan.name == sp_plan.name -%}
                                    {%- unless sp_first_prod_in_var -%},{%- endunless -%}
                                    "{{ sp_product2.id }}": {{ sp_alloc4.selling_plan.id | json }}
                                    {%- assign sp_first_prod_in_var = false -%}
                                  {%- endif -%}
                                {%- endfor -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                      }
                      {%- assign sp_first_var_in_plan = false -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
              }
              {%- assign sp_plan_names = sp_plan_names | append: sp_plan_key | append: ',' -%}
              {%- assign sp_first_plan = false -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  }
</script>

<script type="application/json" id="mb-products-data">
{
  {%- assign is_first = true -%}
  {%- assign added_product_ids = ',' -%}

  {%- if product != blank -%}
    "{{ product.id }}": {{ product | json }}
    {%- assign check_id = ',' | append: product.id | append: ',' -%}
    {%- assign added_product_ids = added_product_ids | append: check_id -%}
    {%- assign is_first = false -%}
  {%- endif -%}

  {%- if section.settings.default_product != blank -%}
    {%- assign check_id = ',' | append: section.settings.default_product.id | append: ',' -%}
    {%- unless added_product_ids contains check_id -%}
      {%- if is_first == false -%},{%- endif -%}
      "{{ section.settings.default_product.id }}": {{ section.settings.default_product | json }}
      {%- assign added_product_ids = added_product_ids | append: check_id -%}
      {%- assign is_first = false -%}
    {%- endunless -%}
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- if block.type == 'week_tab' -%}
      {%- if block.settings.collection != blank -%}
        {%- assign week_collection = block.settings.collection -%}
      {%- else -%}
        {%- assign week_collection = section.settings.collection -%}
      {%- endif -%}

      {%- if week_collection != blank -%}
        {%- for product in week_collection.products -%}
          {%- assign check_id = ',' | append: product.id | append: ',' -%}
          {%- unless added_product_ids contains check_id -%}
            {%- if is_first == false -%},{%- endif -%}
            "{{ product.id }}": {{ product | json }}
            {%- assign added_product_ids = added_product_ids | append: check_id -%}
            {%- assign is_first = false -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if section.settings.collection != blank -%}
    {%- for product in section.settings.collection.products -%}
      {%- assign check_id = ',' | append: product.id | append: ',' -%}
      {%- unless added_product_ids contains check_id -%}
        {%- if is_first == false -%},{%- endif -%}
        "{{ product.id }}": {{ product | json }}
        {%- assign added_product_ids = added_product_ids | append: check_id -%}
        {%- assign is_first = false -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}
}
</script>

