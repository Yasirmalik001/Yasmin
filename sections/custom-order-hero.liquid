{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .order-hero--{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    text-align: center;
    color: rgb(var(--color-foreground));
  }

  .order-hero__content {
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .order-hero__caption {
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.2rem;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }


  .order-hero__title span {
    color: {{ section.settings.accent_color }};
  }

  .order-hero__text {
    font-size: 1.6rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7); /* Softened white for readability */
    max-width: 55rem;
    margin: 0;
  }
{%- endstyle -%}

<div class="order-hero--{{ section.id }} color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="order-hero__content">
      {%- if section.settings.caption != blank -%}
        <p class="order-hero__caption">{{ section.settings.caption | escape }}</p>
      {%- endif -%}

      <h2 class="order-hero__title h1">
        {{ section.settings.heading_start | escape }}
        {%- if section.settings.heading_highlight != blank -%}
          <span>{{ section.settings.heading_highlight | escape }}</span>
        {%- endif -%}
      </h2>

      {%- if section.settings.description != blank -%}
        <div class="order-hero__text">
          {{ section.settings.description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order Hero Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Custom Background Color",
      "default": "#1e1a4d"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Heading Accent Color",
      "default": "#ff007f"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption Text",
      "default": "FRESH & HALAL — DELIVERED EVERY SATURDAY"
    },
    {
      "type": "text",
      "id": "heading_start",
      "label": "Heading Start",
      "default": "How Would You Like to "
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Heading Highlight",
      "default": "Order?"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description Text",
      "default": "Choose between a flexible one-time order or a weekly subscription. Both include 60+ authentic Turkish dishes, cooked fresh and never frozen."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Order Hero Section"
    }
  ]
}
{% endschema %}