        </button>

      {%- elsif section.settings.video_url != blank -%}
        <div class="custom-video-hero__iframe-container" style="display: none; width:100%; height:100%; position:absolute; top:0; left:0; z-index:1;"></div>
        
        {%- if section.settings.cover_image != blank -%}
          {{ section.settings.cover_image | image_url: width: 1500 | image_tag: 
            class: 'custom-video-hero__media custom-video-hero__cover',
            loading: 'lazy', 
            widths: '550, 720, 990, 1100, 1500', 
            sizes: '(min-width: 750px) 100vw, 100vw', 
            alt: section.settings.cover_image.alt | escape 
          }}
        {%- else -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <img class="custom-video-hero__media custom-video-hero__cover" src="https://img.youtube.com/vi/{{ section.settings.video_url.id }}/maxresdefault.jpg" alt="Video cover" loading="lazy" />
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg custom-video-hero__media custom-video-hero__cover' }}
          {%- endif -%}
        {%- endif -%}

        <button class="custom-video-hero__play-btn" aria-label="Play video" style="z-index: 3;">
