{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-video-hero__header {
    text-align: left;
    margin-bottom: 2rem;
  }

  .custom-video-hero__caption {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.caption_color }};
    margin-bottom: 0.8rem;
  }

  .custom-video-hero__heading {
    color: {{ section.settings.heading_color }};
  }

  /* Video Wrapper & Web Component */
  custom-hero-video {
    display: block;
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  /* Height Logic dynamically set via Schema */
  {% if section.settings.height_mode == 'fixed' %}
    .section-{{ section.id }}-video {
      height: {{ section.settings.mobile_height }}px;
    }
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-video {
        height: {{ section.settings.desktop_height }}px;
      }
    }
  {% else %}
    .section-{{ section.id }}-video {
      aspect-ratio: 16 / 9;
    }
    @supports not (aspect-ratio: 16 / 9) {
      .section-{{ section.id }}-video {
        padding-bottom: 56.25%;
        height: 0;
      }
    }
  {% endif %}

  .custom-video-hero__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Play Button Overlay */
  .custom-video-hero__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 72px;
    height: 72px;
    border:none;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }

  custom-hero-video:hover .custom-video-hero__play-btn {
    transform: translate(-50%, -50%) scale(1.05);
    border-color: rgba(255, 255, 255, 0.8);
    background-color: rgba(255, 255, 255, 0.2);
  }
  /* Hide native video controls until playing */
  custom-hero-video video::-webkit-media-controls {
    display: none !important;
  }
  custom-hero-video[playing] video::-webkit-media-controls {
    display: flex !important;
  }
{%- endstyle -%}

<div class="custom-video-hero section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="custom-video-hero__header">
      {%- if section.settings.caption != blank -%}
        <span class="custom-video-hero__caption">{{ section.settings.caption }}</span>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="custom-video-hero__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <custom-hero-video 
      class="section-{{ section.id }}-video"
      data-video-type="{% if section.settings.video != blank %}html5{% elsif section.settings.video_url != blank %}{{ section.settings.video_url.type }}{% else %}none{% endif %}"
      {% if section.settings.video_url != blank %}
        data-video-id="{{ section.settings.video_url.id }}"
      {% endif %}
    >
      {%- if section.settings.video != blank -%}
        {%- assign poster_url = section.settings.cover_image | image_url: width: 1500 -%}
        <video 
          class="custom-video-hero__media"
          {% if section.settings.cover_image != blank %}poster="{{ poster_url }}"{% endif %}
          playsinline
        >
          {%- for source in section.settings.video.sources -%}
            <source src="{{ source.url }}" type="{{ source.mime_type }}">
          {%- endfor -%}
        </video>
        <button class="custom-video-hero__play-btn" aria-label="Play video">
