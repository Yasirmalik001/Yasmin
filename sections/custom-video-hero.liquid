<script>
  if (!customElements.get('custom-hero-video')) {
    class CustomHeroVideo extends HTMLElement {
      constructor() {
        super();
        this.videoType = this.getAttribute('data-video-type');
        this.videoId = this.getAttribute('data-video-id');
        this.video = this.querySelector('video');
        this.playBtn = this.querySelector('.custom-video-hero__play-btn');
        this.iframeContainer = this.querySelector('.custom-video-hero__iframe-container');
        this.coverImage = this.querySelector('.custom-video-hero__cover');

        if (this.playBtn) {
          this.playBtn.addEventListener('click', this.playVideo.bind(this));
        }
        
        if (this.video && this.playBtn) {
          this.video.addEventListener('play', () => {
            this.playBtn.style.display = 'none';
            this.setAttribute('playing', '');
          });
          this.video.addEventListener('pause', () => {
            this.playBtn.style.display = 'flex';
          });
        }
      }

      playVideo() {
        if (this.videoType === 'html5' && this.video) {
          this.video.play();
          this.video.setAttribute('controls', 'controls');
        } else if (this.videoType === 'youtube' && this.iframeContainer) {
          this.iframeContainer.innerHTML = `
            <iframe 
              src="https://www.youtube.com/embed/${this.videoId}?autoplay=1&mute=0&controls=1&rel=0" 
              frameborder="0" 
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen 
              style="width: 100%; height: 100%; position: absolute; top:0; left:0; border:0;"
            ></iframe>`;
          this.iframeContainer.style.display = 'block';
          if (this.coverImage) this.coverImage.style.display = 'none';
          this.playBtn.style.display = 'none';
          this.setAttribute('playing', '');
        } else if (this.videoType === 'vimeo' && this.iframeContainer) {
          this.iframeContainer.innerHTML = `
            <iframe 
              src="https://player.vimeo.com/video/${this.videoId}?autoplay=1&muted=0&controls=1" 
              frameborder="0" 
              allow="autoplay; fullscreen; picture-in-picture" 
              allowfullscreen 
              style="width: 100%; height: 100%; position: absolute; top:0; left:0; border:0;"
            ></iframe>`;
          this.iframeContainer.style.display = 'block';
          if (this.coverImage) this.coverImage.style.display = 'none';
          this.playBtn.style.display = 'none';
          this.setAttribute('playing', '');
        }
      }
    }
    customElements.define('custom-hero-video', CustomHeroVideo);
  }
</script>

{% schema %}
{
  "name": "Custom Video Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "SEE IT FOR YOURSELF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "YASEMIN: WHO ARE WE?"
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Hosted Video",
      "info": "Upload an MP4. If selected, it takes priority over the YouTube/Vimeo URL below."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": [
        "youtube",
        "vimeo"
      ],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "YouTube or Vimeo Video URL",
      "info": "Used if no Shopify Hosted Video is uploaded."
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Video Cover Image",
      "info": "Acts as the video poster/thumbnail before clicking play."
    },
    {
      "type": "header",
      "content": "Height Controls"
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Video Height Mode",
      "options": [
        {
          "value": "auto",
          "label": "Auto (16:9 Aspect Ratio)"
        },
        {
          "value": "fixed",
          "label": "Fixed Height"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop Fixed Height",
      "info": "Only applies if 'Fixed Height' is selected above.",
      "default": 500
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 200,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile Fixed Height",
      "info": "Only applies if 'Fixed Height' is selected above.",
      "default": 300
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption Color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#362159"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Custom Video Hero"
    }
  ]
}
{% endschema %}