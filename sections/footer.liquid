{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* General Footer Background and Padding */
  .footer {
    background-color: #1e1554 !important;
    color: #ffffff;
    border-top: none !important;
    margin-top: {{ section.settings.margin_top }}px;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: 0px !important; /* Bottom padding will be handled by the stripe */
  }

  /* Grid/Flex Layout for Blocks */
  .footer__blocks-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .footer-block {
    flex: 1;
    min-width: 200px;
    margin: 0;
  }

  .footer-block--brand_information {
    flex: 2;
    min-width: 280px;
  }

  @media screen and (max-width: 749px) {
    .footer__blocks-wrapper {
      flex-direction: column;
      gap: 3rem;
    }
    .footer-block,
    .footer-block--brand_information {
      flex: 1 1 100%;
      width: 100%;
    }
  }

  /* Heading Styles */
  .footer-block__heading {
    color: #ff00a6 !important; /* Magenta pink */
    font-weight: 700 !important;
    font-size: 1.4rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.12em !important;
    margin-top: 0;
    margin-bottom: 2rem !important;
    line-height: 1.3 !important;
  }

  /* Text & Links Styles */
  .footer-block__details-content .link,
  .footer-block__details-content.rte p,
  .footer-block__details-content.rte a,
  .footer-block__details-content p {
    color: #a7a3c3 !important; /* Soft lavender/blue-gray */
    font-size: 1.4rem !important;
    text-decoration: none !important;
    line-height: 1.8 !important;
    transition: color 0.2s ease;
    margin: 0;
    padding: 0;
  }

  .footer-block__details-content .link:hover,
  .footer-block__details-content.rte a:hover {
    color: #ffffff !important;
  }

  .footer-block__details-content.list-unstyled li {
    margin-bottom: 1rem;
  }

  .footer-block__brand-info .rte {
    color: #a7a3c3 !important;
    font-size: 1.4rem;
    line-height: 1.6;
    margin-top: 1.5rem;
    max-width: 320px;
  }

  /* Social Icons */
  .footer__list-social {
    display: flex;
    gap: 1.2rem;
    margin-top: 2.5rem;
    padding: 0;
    list-style: none;
  }

  .footer__list-social .list-social__link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem !important;
    height: 3.6rem !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 50% !important;
    color: #a7a3c3 !important;
    padding: 0 !important;
    transition: all 0.3s ease;
    text-decoration: none;
    background: transparent !important;
  }

  .footer__list-social .list-social__link:hover {
    border-color: #ffffff !important;
    color: #ffffff !important;
  }

  .footer__list-social .list-social__link svg {
    width: 1.6rem;
    height: 1.6rem;
    fill: currentColor;
  }

  /* Middle Row: Languages & Payments */
  .footer__content-middle {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  .footer__middle-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }

  /* Language Selector Capsule Pills */
  .footer__language-circles {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }

  .footer__language-circles .language-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 1.4rem;
    height: auto;
    width: auto;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    border-radius: 2rem !important;
    background: transparent;
    color: #a7a3c3 !important;
    font-size: 1.2rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    text-transform: uppercase;
  }

  .footer__language-circles .language-circle.active,
  .footer__language-circles .language-circle:hover {
    color: #ffffff !important;
  }

  .footer__language-circles .language-circle.active {
    background-color: #ff00a6 !important; /* Pink background */
    border-color: #ff00a6 !important;
    font-weight: 700;
  }

  /* Custom Payment Badges */
  .list-payment-custom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .payment-badge-custom {
    background: #ffffff !important;
    color: #1e1554 !important; /* Dark blue/purple text */
    font-size: 1.1rem;
    font-weight: 700;
    padding: 0.5rem 1.2rem;
    border-radius: 0.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.8rem;
  }

  /* Bottom Stripe (Copyright & Policies) */
  .footer__bottom-stripe {
    background-color: #130d37 !important; /* Darker navy */
    padding: 2rem 0;
  }

  .footer__bottom-stripe-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .footer__copyright-custom span {
    color: #a7a3c3 !important;
    font-size: 1.2rem;
  }

  .footer__policies-custom {
    display: flex;
    gap: 2.5rem;
  }

  .footer__policy-link {
    color: #a7a3c3 !important;
    font-size: 1.2rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__policy-link:hover {
    color: #ffffff !important;
  }

  @media screen and (max-width: 749px) {
    .footer__middle-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 2.5rem;
    }
    .footer__bottom-stripe-container {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .footer__policies-custom {
      flex-direction: column;
      gap: 1rem;
    }
  }
{%- endstyle -%}

<footer class="footer color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif

    if settings.brand_image == blank and settings.brand_headline == blank and settings.brand_description == blank
      assign brand_empty = true
    endif

    if section.blocks.size == 1 and section.blocks[0].type == 'brand_information' and brand_empty and has_social_icons == false and section.settings.newsletter_enable == false and section.settings.enable_follow_on_shop == false
      assign only_empty_brand = true
    endif
  -%}
  {%- if section.blocks.size > 0
    or section.settings.newsletter_enable
    or section.settings.show_social
    and has_social_icons == true
    or section.settings.enable_follow_on_shop
  -%}
    {%- unless only_empty_brand -%}
      <div class="footer__content-top page-width">
        {%- if section.blocks.size > 0 -%}
          {%- liquid
            if section.blocks.size == 9
              assign footer_grid_class = 'grid--3-col-tablet'
            elsif section.blocks.size > 6
              assign footer_grid_class = 'grid--4-col-desktop'
            elsif section.blocks.size > 4
              assign footer_grid_class = 'grid--3-col-tablet'
            endif
          -%}
          <div
            class="footer__blocks-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
            {% if settings.animations_reveal_on_scroll %}
              data-cascade
            {% endif %}
          >
            {%- for block in section.blocks -%}
              <div
                class="footer-block footer-block--{{ block.type }} grid__item{% if block.type == 'link_list' %} footer-block--menu{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                {{ block.shopify_attributes }}
                {% if settings.animations_reveal_on_scroll %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
              >
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer-block__heading inline-richtext">{{- block.settings.heading -}}</h2>
                {%- endif -%}

                {%- case block.type -%}
                  {%- when '@app' -%}
                    {% render block %}
                  {%- when 'text' -%}
                    <div class="footer-block__details-content rte">
                      {{ block.settings.subtext }}
                    </div>
                  {%- when 'link_list' -%}
                    <ul class="footer-block__details-content list-unstyled">
                      {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                        {%- for link in block.settings.menu.links -%}
                          <li>
                            <a
                              href="{{ link.url }}"
                              class="link link--text list-menu__item list-menu__item--link{% if link.active %} list-menu__item--active{% endif %}"
                            >
                              {{ link.title | escape }}
                            </a>
                          </li>
                        {%- endfor -%}
                      {%- else -%}
                        {%- assign heading_downcase = block.settings.heading | downcase -%}
                        {%- if heading_downcase contains 'populaire' -%}
                          <li><a href="/collections/maaltijdabonnement" class="link link--text list-menu__item list-menu__item--link">Maaltijdabonnement</a></li>
                          <li><a href="/collections/turkse-maaltijden" class="link link--text list-menu__item list-menu__item--link">Turkse Maaltijden</a></li>
                          <li><a href="/collections/halal-maaltijdbox" class="link link--text list-menu__item list-menu__item--link">Halal Maaltijdbox</a></li>
                          <li><a href="/collections/kant-en-klaar" class="link link--text list-menu__item list-menu__item--link">Kant-en-Klaar Maaltijden</a></li>
                          <li><a href="/collections/halal-vleesgerechten" class="link link--text list-menu__item list-menu__item--link">Halal Vleesgerechten</a></li>
                          <li><a href="/collections/turkse-soepen" class="link link--text list-menu__item list-menu__item--link">Turkse Soepen</a></li>
                        {%- elsif heading_downcase contains 'over' -%}
                          <li><a href="/pages/hoe-werkt-het" class="link link--text list-menu__item list-menu__item--link">Hoe Werkt het</a></li>
                          <li><a href="/pages/ons-verhaal" class="link link--text list-menu__item list-menu__item--link">Ons Verhaal</a></li>
                          <li><a href="/pages/abonnementen-prijzen" class="link link--text list-menu__item list-menu__item--link">Abonnementen & Prijzen</a></li>
                          <li><a href="/blogs/turkse-keuken" class="link link--text list-menu__item list-menu__item--link">Turkse Keuken Blog</a></li>
                          <li><a href="/pages/veelgestelde-vragen" class="link link--text list-menu__item list-menu__item--link">Veelgestelde Vragen</a></li>
                          <li><a href="/pages/contact" class="link link--text list-menu__item list-menu__item--link">Contact</a></li>
                        {%- elsif heading_downcase contains 'bezorggebieden' -%}
                          <li><a href="/pages/halal-bezorging-nederland" class="link link--text list-menu__item list-menu__item--link">🇳🇱 Halal Bezorging Nederland</a></li>
                          <li><a href="/pages/turkische-mahlzeiten-de" class="link link--text list-menu__item list-menu__item--link">🇩🇪 Türkische Mahlzeiten DE</a></li>
                          <li><a href="/pages/repas-turcs-belgique" class="link link--text list-menu__item list-menu__item--link">🇧🇪 Repas Turcs Belgique</a></li>
                          <li><a href="/pages/turkish-meals-europe" class="link link--text list-menu__item list-menu__item--link">🌐 Turkish Meals Europe</a></li>
                          <li><a href="/pages/turk-yemekleri-siparis" class="link link--text list-menu__item list-menu__item--link">🇹🇷 Türk Yemekleri Sipariş</a></li>
                        {%- endif -%}
                      {%- endif -%}
                    </ul>
                  {%- when 'brand_information' -%}
                    <div class="footer-block__brand-info">
                      {%- if settings.brand_image != blank -%}
                        {%- assign brand_image_height = settings.brand_image_width
                          | divided_by: settings.brand_image.aspect_ratio
                        -%}
                        <div
                          class="footer-block__image-wrapper"
                          style="max-width: min(100%, {{ settings.brand_image_width }}px);"
                        >
                          {{
                            settings.brand_image
                            | image_url: width: 1100
                            | image_tag:
                              loading: 'lazy',
                              widths: '50, 100, 150, 200, 300, 400, 550, 800, 1100',
                              height: brand_image_height,
                              width: settings.brand_image_width
                          }}
                        </div>
                      {%- endif -%}
                      {%- if settings.brand_headline != blank -%}
                        <h2 class="footer-block__heading rte">{{ settings.brand_headline }}</h2>
                      {%- endif -%}
                      {%- if settings.brand_description != blank -%}
                        <div class="rte">{{ settings.brand_description }}</div>
                      {%- endif -%}
                      {%- if block.settings.show_social and has_social_icons -%}
                        {%- render 'social-icons', class: 'footer__list-social' -%}
                      {%- endif -%}
                    </div>
                  {%- when 'image' -%}
                      <div class="footer-block__details-content footer-block-image {{ block.settings.alignment }}">
                        {%- if block.settings.image != blank -%}
                          {%- assign image_size_2x = block.settings.image_width | times: 2 | at_most: 5760 -%}
                          <div
                            class="footer-block__image-wrapper"
                            style="max-width: min(100%, {{ block.settings.image_width }}px);"
                          >
                            <img decoding="async"
                              srcset="{{ block.settings.image | image_url: width: block.settings.image_width }}, {{ block.settings.image | image_url: width: image_size_2x }} 2x"
                              src="{{ block.settings.image | image_url: width: 760 }}"
                              alt="{{ block.settings.image.alt | escape }}"
                              loading="lazy"
                              width="{{ block.settings.image.width }}"
                              height="{{ block.settings.image.height }}"
                            >
                          </div>
                        {%- else -%}
                          {{ 'image' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
                        {%- endif -%}
                      </div>

                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        <div
          class="footer-block--newsletter{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
          {% if settings.animations_reveal_on_scroll %}
            data-cascade
          {% endif %}
        >
          {%- if section.settings.newsletter_enable -%}
            <div class="footer-block__newsletter">
              {%- if section.settings.newsletter_heading != blank -%}
                <h2 class="footer-block__heading inline-richtext">{{ section.settings.newsletter_heading }}</h2>
              {%- endif -%}
              {%- form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="newsletter-form__field-wrapper">
                  <div class="field">
                    <input
                      id="NewsletterForm--{{ section.id }}"
                      type="email"
                      name="contact[email]"
                      class="field__input"
                      value="{{ form.email }}"
                      aria-required="true"
                      autocorrect="off"
                      autocapitalize="off"
                      autocomplete="email"
                      {% if form.errors %}
                        autofocus
                        aria-invalid="true"
                        aria-describedby="ContactFooter-error"
                      {% elsif form.posted_successfully? %}
                        aria-describedby="ContactFooter-success"
                      {% endif %}
                      placeholder="{{ 'newsletter.label' | t }}"
                      required
                    >
                    <label class="field__label" for="NewsletterForm--{{ section.id }}">
                      {{ 'newsletter.label' | t }}
                    </label>
                    <button
                      type="submit"
                      class="newsletter-form__button field__button"
                      name="commit"
                      id="Subscribe"
                      aria-label="{{ 'newsletter.button_label' | t }}"
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-arrow.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>
                  {%- if form.errors -%}
                    <small class="newsletter-form__message form__message" id="ContactFooter-error">
                      <span class="svg-wrapper">
                        {{- 'icon-error.svg' | inline_asset_content -}}
                      </span>
                      {{- form.errors.translated_fields.email | capitalize }}
                      {{ form.errors.messages.email -}}
                    </small>
                  {%- endif -%}
                </div>
                {%- if form.posted_successfully? -%}
                  <h3
                    class="newsletter-form__message newsletter-form__message--success form__message"
                    id="ContactFooter-success"
                    tabindex="-1"
                    autofocus
                  >
                    <span class="svg-wrapper">
                      {{- 'icon-success.svg' | inline_asset_content -}}
                    </span>
                    {{- 'newsletter.success' | t }}
                  </h3>
                {%- endif -%}
              {%- endform -%}
            </div>
          {%- endif -%}

          {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
            <div class="footer__follow-on-shop">
              {{ shop | login_button: action: 'follow' }}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endunless -%}
  {%- endif -%}

  {%- comment -%} Middle Row: Languages & Payments {%- endcomment -%}
  <div class="footer__content-middle page-width">
    <div class="footer__middle-row">
      {%- comment -%} Languages on the Left {%- endcomment -%}
      <div class="footer__languages-container">
        {%- if localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <div class="footer__language-circles">
                {%- for language in localization.available_languages -%}
                  <button type="submit" name="locale_code" value="{{ language.iso_code }}" class="language-circle {% if language.iso_code == localization.language.iso_code %}active{% endif %}">
                    {{ language.iso_code | upcase }}
                  </button>
                {%- endfor -%}
              </div>
            {%- endform -%}
          </localization-form>
        {%- else -%}
          <div class="footer__language-circles">
            <span class="language-circle active">NL</span>
            <span class="language-circle">EN</span>
            <span class="language-circle">TR</span>
            <span class="language-circle">DE</span>
            <span class="language-circle">FR</span>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Payments on the Right {%- endcomment -%}
      {%- if section.settings.payment_enable -%}
        <div class="footer__payment-custom">
          <ul class="list-payment-custom" role="list">
            <li class="payment-badge-custom">iDEAL</li>
            <li class="payment-badge-custom">Bancontact</li>
            <li class="payment-badge-custom">PayPal</li>
            <li class="payment-badge-custom">Visa</li>
            <li class="payment-badge-custom">Mastercard</li>
            <li class="payment-badge-custom">Apple Pay</li>
            <li class="payment-badge-custom">Google Pay</li>
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Very Bottom Row: Copyright & Policies (Dark Navy Bar) {%- endcomment -%}
  <div class="footer__bottom-stripe">
    <div class="page-width footer__bottom-stripe-container">
      <div class="footer__copyright-custom">
        <span>&copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | remove: '<p>' | remove: '</p>' }}</span>
      </div>
      <div class="footer__policies-custom">
        <a href="/policies/privacy-policy" class="footer__policy-link">Privacybeleid</a>
        <a href="/policies/terms-of-service" class="footer__policy-link">Algemene Voorwaarden</a>
        <a href="/pages/cookiebeleid" class="footer__policy-link">Cookiebeleid</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Width",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            {
              "value": "",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content",
      "info": "t:sections.footer.settings.header__1.info"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
