{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-installation {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .custom-installation {
      flex-direction: row;
      align-items: center;
    }
    .custom-installation__content {
      width: 45%;
      padding-right: 5%;
    }
    .custom-installation__media-wrapper {
      width: 55%;
    }
  }

  .custom-installation__subheading {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-transform: uppercase;
    font-size: 1.3rem;
    letter-spacing: 0.15rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .custom-installation__subheading::before {
    content: '';
    display: block;
    width: 24px;
    height: 2px;
    background-color: currentColor;
  }

  .custom-installation__heading {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }

  .custom-installation__text {
    margin-bottom: 4rem;
    color: rgba(var(--color-foreground), 0.8);
    font-size: 1.4rem;
    line-height: 1.6;
  }

  .custom-installation__steps {
    position: relative;
  }

  /* Connecting Vertical Line */
  .custom-installation__steps::before {
    content: '';
    position: absolute;
    top: 20px;
    bottom: 30px;
    left: 20px;
    width: 2px;
    background-color: rgba(var(--color-foreground), 0.2);
    transform: translateX(-50%);
    z-index: 1;
  }

  .custom-installation__step {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.5rem;
    position: relative;
  }

  .custom-installation__step:last-child {
    margin-bottom: 0;
  }

  .custom-installation__step-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgb(var(--color-background));
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .custom-installation__step-icon img,
  .custom-installation__step-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .custom-installation__step-content {
    padding-top: 0.5rem;
  }

  .custom-installation__step-content h4 {
    margin: 0 0 0.8rem;
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1rem;
    color: rgb(var(--color-foreground));
  }

  .custom-installation__step-content p {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.5;
    color: rgba(var(--color-foreground), 0.7);
  }

  .custom-installation__media {
    border-radius: 1rem; /* Soft rounded corners matching the reference */
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .custom-installation__media img,
  .custom-installation__media video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    <div class="custom-installation">
      
      <div class="custom-installation__content">
        {%- if section.settings.subheading != blank -%}
          <div class="custom-installation__subheading" style="color: {{ section.settings.subheading_color }}">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}
        
        {%- if section.settings.heading != blank -%}
          <h2 class="custom-installation__heading {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="custom-installation__text rte">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        <div class="custom-installation__steps">
          {%- for block in section.blocks -%}
            <div class="custom-installation__step" {{ block.shopify_attributes }}>
              <div class="custom-installation__step-icon">
                {%- if block.settings.icon != blank -%}
                  {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy' }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="custom-installation__step-content">
                {%- if block.settings.title != blank -%}
                  <h4>{{ block.settings.title }}</h4>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p>{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="custom-installation__media-wrapper">
        <div class="custom-installation__media">
          {%- if section.settings.video != blank -%}
            {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '1000x' }}
          {%- elsif section.settings.image != blank -%}
            {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 55vw, 100vw' }}
          {%- else -%}
            {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Installation Steps",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Installation"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color Override",
      "default": "#C85A48"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "1 Minute Installation"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description text",
      "default": "<p>No tools, no instructions, no extra hands. Watch the full step-by-step guide below.</p>"
    },
    {
      "type": "header",
      "content": "Media Configuration"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video",
      "info": "Autoplays silently. Overrides the image if selected."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback Image"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Step Icon / Number Image",
          "info": "Upload the circle numbered graphic here."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Position"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Place the cover over the seat and align with the headrest."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Installation Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "POSITION",
            "text": "Place the cover over the seat and align with the headrest."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "STRAP IN",
            "text": "Tuck the elastic straps under the seat and snap them in place."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "ADJUST",
            "text": "Pull tight to remove wrinkles for a snug, factory-fit look."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "ENJOY THE RIDE",
            "text": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}