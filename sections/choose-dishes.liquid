{% comment %} {%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .choose-dishes {
    --color-purple-dark: #3a225f;
    --color-purple-light: #7a6a91;
    --color-accent-orange: #ff8a3d;
    --color-bg-orange: #fff1e5;
    --color-border: #f0f0f0;
    font-family: var(--font-body-family);
  }

  .cd-header {
    margin-bottom: 4rem;
  }

  .cd-header h1 {
    font-size: 3.2rem;
    font-weight: 900;
    color: var(--color-purple-dark);
    margin: 0 0 1rem 0;
  }

  .cd-header p {
    font-size: 1.6rem;
    color: var(--color-purple-light);
    line-height: 1.6;
    max-width: 80rem;
    margin: 0;
  }

  .cd-layout {
    display: grid;
    grid-template-columns: 24rem 1fr;
    gap: 4rem;
    align-items: start;
  }

  .cd-sidebar {
    position: sticky;
    top: 12rem;
  }

  .cd-filter-section {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.6rem;
    padding: 2.4rem;
    margin-bottom: 2.4rem;
  }

  .cd-filter-label {
    font-size: 1.2rem;
    font-weight: 800;
    text-transform: uppercase;
    color: #b0a8c0;
    letter-spacing: 0.1rem;
    margin-bottom: 2rem;
    display: block;
  }

  .cd-filter-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .cd-filter-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    cursor: pointer;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-purple-dark);
  }

  .cd-filter-checkbox {
    width: 2.2rem;
    height: 2.2rem;
    border: 1px solid #dcd1ed;
    border-radius: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .cd-filter-item.is-active .cd-filter-checkbox {
    background-color: var(--color-purple-dark);
    border-color: var(--color-purple-dark);
  }

  .cd-filter-item.is-active .cd-filter-checkbox::after {
    content: '';
    width: 0.6rem;
    height: 1.1rem;
    border: solid white;
    border-width: 0 0.2rem 0.2rem 0;
    transform: rotate(45deg);
    margin-top: -0.2rem;
  }

  .cd-dietary-pills {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cd-dietary-pill {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    padding: 1rem 1.6rem;
    border: 1px solid var(--color-border);
    border-radius: 2.4rem;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-purple-dark);
    cursor: pointer;
    transition: all 0.2s;
  }

  .cd-dietary-pill::before {
    content: '';
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
  }

  .cd-dietary-pill.vegan::before { background-color: #4CAF50; }
  .cd-dietary-pill.vegetarian::before { background-color: #8BC34A; }
  .cd-dietary-pill.gluten-free::before { background-color: #FFC107; }
  .cd-dietary-pill.lactose-free::before { background-color: #03A9F4; }
  .cd-dietary-pill.meat-based::before { background-color: #F44336; }

  .cd-dietary-pill.is-active {
    border-color: var(--color-purple-dark);
    background-color: #f1ecf9;
  }

  .cd-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(28rem, 1fr));
    gap: 2.4rem;
  }

  .cd-card {
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: 1.6rem;
    overflow: visible;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: all 0.3s ease;
  }

  .cd-card:hover {
    box-shadow: 0 1rem 3rem rgba(0,0,0,0.06);
  }

  .cd-card__image-container {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: #f9f9f9;
  }

  .cd-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .cd-card:hover .cd-card__image {
    transform: scale(1.05);
  }

  .cd-card__body {
    padding: 2.4rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .cd-card__category {
    font-size: 1.1rem;
    font-weight: 800;
    text-transform: uppercase;
    color: var(--color-accent-orange);
    background-color: var(--color-bg-orange);
    padding: 0.4rem 0.8rem;
    border-radius: 0.4rem;
    margin-bottom: 1.2rem;
    letter-spacing: 0.05rem;
  }

  .cd-card__title {
    font-size: 1.8rem;
    font-weight: 800;
    color: #111;
    margin: 0 0 0.6rem 0;
  }

  .cd-card__price {
    font-size: 1.5rem;
    font-weight: 500;
    color: #777;
    margin-bottom: 2rem;
  }

  .cd-card__add {
    margin-top: auto;
    width: 100%;
    padding: 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: 3rem;
    background: transparent;
    color: #333;
    font-size: 1.4rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .cd-card__add:hover {
    border-color: #999;
    background-color: #fafafa;
  }

  .cd-actions-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #fff;
    padding: 2rem;
    border-top: 1px solid var(--color-border);
    z-index: 100;
    box-shadow: 0 -1rem 3rem rgba(0,0,0,0.03);
  }

  .cd-actions-container {
    max-width: var(--page-width);
    margin: 0 auto;
    display: flex;
    justify-content: flex-end;
    gap: 1.6rem;
  }

  .cd-btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.4rem 3.2rem;
    border: 1px solid #dcd1ed;
    border-radius: 3rem;
    background: #fff;
    color: var(--color-purple-dark);
    font-size: 1.6rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
  }

  .cd-btn-back:hover {
    border-color: var(--color-purple-dark);
    background-color: #fcfaff;
  }

  .cd-btn-order {
    padding: 1.4rem 4.8rem;
    background-color: var(--color-purple-dark);
    color: #fff;
    border: none;
    border-radius: 3rem;
    font-size: 1.6rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
  }

  .cd-btn-order:hover {
    background-color: #2a1845;
    transform: translateY(-0.2rem);
  }

  @media (max-width: 990px) {
    .cd-layout { grid-template-columns: 1fr; }
    .cd-sidebar { position: static; margin-bottom: 3rem; }
  }
{%- endstyle -%}

<choose-dishes class="choose-dishes" id="ChooseDishes-{{ section.id }}">
  <div class="page-width section-{{ section.id }}-padding">
    
    {%- render 'postcode-checker-integrated' -%}

    <div class="cd-header">
      <h1>{{ section.settings.heading }}</h1>
      <p>{{ section.settings.subheading }}</p>
    </div>

    <div class="cd-layout">
      <aside class="cd-sidebar">
        <div class="cd-filter-section">
          <span class="cd-filter-label">{{ section.settings.filter_type_label }}</span>
          <ul class="cd-filter-list">
            {%- assign types = section.settings.filter_types | split: ',' -%}
            {%- for type in types -%}
              <li class="cd-filter-item" data-filter-type="{{ type | strip }}">
                <span class="cd-filter-checkbox"></span>
                {{ type | strip }}
              </li>
            {%- endfor -%}
          </ul>
        </div>

        <div class="cd-filter-section">
          <span class="cd-filter-label">{{ section.settings.filter_diet_label }}</span>
          <div class="cd-dietary-pills">
             {%- assign diet_filters = section.settings.diet_filters_list | split: ',' -%}
             {%- for diet in diet_filters -%}
                <div class="cd-dietary-pill {{ diet | handle }}" data-filter-diet="{{ diet | strip }}">{{ diet | strip }}</div>
             {%- endfor -%}
          </div>
        </div>
      </aside>

      <main class="cd-main">
        <div class="cd-grid" id="ProductGrid">
          {%- assign collection = section.settings.collection -%}
          {%- if collection != blank and collection.products.size > 0 -%}
            {%- for product in collection.products -%}
              {%- assign diet_tags = "" -%}
              {%- for tag in product.tags -%}
                {%- assign t = tag | downcase -%}
                {%- if t contains 'vegan' or t contains 'vegetarian' or t contains 'gluten-free' or t contains 'lactose-free' or t contains 'meat-based' -%}
                  {%- assign diet_tags = diet_tags | append: tag | append: "," -%}
                {%- endif -%}
              {%- endfor -%}
              
              <div class="cd-card" 
                data-type="{{ product.type }}" 
                data-diets="{{ diet_tags | split: ',' | compact | join: ',' }}"
              >
                <div class="cd-card__image-container" style="position: relative; border-radius: 1.6rem 1.6rem 0 0; overflow: hidden;">
                  {%- if product.featured_image != blank -%}
                    <img decoding="async" 
                      src="{{ product.featured_image | image_url: width: 800 }}" 
                      alt="{{ product.title | escape }}" 
                      class="cd-card__image"
                      loading="lazy"
                      width="600"
                      height="450"
                    >
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'cd-card__image' }}
                  {%- endif -%}
                </div>

                <!-- Ingredients Info Dropdown -->
                <div class="product-info-icon-wrapper" tabindex="0">
                  <button class="product-info-icon-btn" aria-label="Ingredients">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                      <path d="M8.9375 0C7.16983 0 5.44186 0.524175 3.9721 1.50624C2.50233 2.48831 1.35679 3.88415 0.680331 5.51727C0.00387248 7.15038 -0.17312 8.94742 0.171736 10.6811C0.516591 12.4148 1.36781 14.0073 2.61774 15.2573C3.86767 16.5072 5.46018 17.3584 7.19388 17.7033C8.92759 18.0481 10.7246 17.8711 12.3577 17.1947C13.9909 16.5182 15.3867 15.3727 16.3688 13.9029C17.3508 12.4331 17.875 10.7052 17.875 8.9375C17.8725 6.5679 16.9301 4.29606 15.2545 2.6205C13.5789 0.944933 11.3071 0.00250234 8.9375 0ZM8.9375 16.5C7.44178 16.5 5.97965 16.0565 4.736 15.2255C3.49236 14.3945 2.52305 13.2134 1.95066 11.8315C1.37828 10.4497 1.22851 8.92911 1.52032 7.46213C1.81212 5.99515 2.53237 4.64764 3.59001 3.59001C4.64764 2.53237 5.99515 1.81211 7.46213 1.52031C8.92912 1.22851 10.4497 1.37827 11.8315 1.95066C13.2134 2.52305 14.3945 3.49235 15.2255 4.736C16.0565 5.97965 16.5 7.44178 16.5 8.9375C16.4977 10.9425 15.7002 12.8647 14.2825 14.2825C12.8647 15.7002 10.9425 16.4977 8.9375 16.5ZM9.96875 8.9375C9.96875 9.14146 9.90827 9.34084 9.79496 9.51043C9.68164 9.68002 9.52058 9.8122 9.33215 9.89025C9.14371 9.9683 8.93636 9.98873 8.73632 9.94893C8.53627 9.90914 8.35252 9.81093 8.2083 9.6667C8.06408 9.52248 7.96586 9.33873 7.92607 9.13869C7.88628 8.93864 7.9067 8.73129 7.98475 8.54286C8.06281 8.35442 8.19498 8.19336 8.36457 8.08005C8.53416 7.96673 8.73354 7.90625 8.9375 7.90625C9.21101 7.90625 9.47331 8.0149 9.66671 8.2083C9.8601 8.40169 9.96875 8.664 9.96875 8.9375ZM9.96875 5.15625C9.96875 5.36021 9.90827 5.55959 9.79496 5.72918C9.68164 5.89877 9.52058 6.03095 9.33215 6.109C9.14371 6.18705 8.93636 6.20748 8.73632 6.16769C8.53627 6.12789 8.35252 6.02968 8.2083 5.88545C8.06408 5.74123 7.96586 5.55748 7.92607 5.35744C7.88628 5.15739 7.9067 4.95004 7.98475 4.76161C8.06281 4.57317 8.19498 4.41211 8.36457 4.2988C8.53416 4.18548 8.73354 4.125 8.9375 4.125C9.21101 4.125 9.47331 4.23365 9.66671 4.42705C9.8601 4.62044 9.96875 4.88275 9.96875 5.15625ZM9.96875 12.7188C9.96875 12.9227 9.90827 13.1221 9.79496 13.2917C9.68164 13.4613 9.52058 13.5934 9.33215 13.6715C9.14371 13.7496 8.93636 13.77 8.73632 13.7302C8.53627 13.6904 8.35252 13.5922 8.2083 13.448C8.06408 13.3037 7.96586 13.12 7.92607 12.9199C7.88628 12.7199 7.9067 12.5125 7.98475 12.3241C8.06281 12.1357 8.19498 11.9746 8.36457 11.8613C8.53416 11.748 8.73354 11.6875 8.9375 11.6875C9.21101 11.6875 9.47331 11.7962 9.66671 11.9895C9.8601 12.1829 9.96875 12.4452 9.96875 12.7188Z" fill="#534AB7"/>
                    </svg>
                  </button>
                  <div class="product-info-dropdown">
                    <ul>
                      {%- if product.metafields.custom.ingredients.value != blank -%}
                        {%- assign ingredients_list = product.metafields.custom.ingredients.value | split: ',' -%}
                        {%- for ingredient in ingredients_list -%}
                          {%- assign ingredient_stripped = ingredient | strip -%}
                          {%- if ingredient_stripped != blank -%}
                            <li><svg viewBox="0 0 24 24" width="14" height="14" fill="#534AB7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> {{ ingredient_stripped }}</li>
                          {%- endif -%}
                        {%- endfor -%}
                      {%- else -%}
                        <li><svg viewBox="0 0 24 24" width="14" height="14" fill="#534AB7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> {{ section.settings.placeholder_ingredient_1 | default: "Ingredient 1" }}</li>
                        <li><svg viewBox="0 0 24 24" width="14" height="14" fill="#534AB7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> {{ section.settings.placeholder_ingredient_2 | default: "Ingredient 2" }}</li>
                        <li><svg viewBox="0 0 24 24" width="14" height="14" fill="#534AB7"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg> {{ section.settings.placeholder_ingredient_3 | default: "Ingredient 3" }}</li>
                      {%- endif -%}
                    </ul>
                  </div>
                </div>
                <div class="cd-card__body">
                  <span class="cd-card__category">
                    {{ product.type | upcase | default: 'DISH' }}
                  </span>
                  <h3 class="cd-card__title">{{ product.title }}</h3>
                  <div class="cd-card__price">{{ product.price | money }}</div>
                  <button class="cd-card__add" data-variant-id="{{ product.variants.first.id }}">
                    {{ section.settings.add_to_order_text }}
                  </button>
                </div>
              </div>
            {%- endfor -%}
          {%- else -%}
             {%- for i in (1..8) -%}
                <div class="cd-card" data-type="{{ section.settings.placeholder_category }}" data-diets="">
                   <div class="cd-card__image-container">
                      {{ 'product-' | append: i | placeholder_svg_tag: 'cd-card__image' }}
                   </div>
                   <div class="cd-card__body">
                      <span class="cd-card__category">{{ section.settings.placeholder_category }}</span>
                      <h3 class="cd-card__title">{{ section.settings.placeholder_title }}</h3>
                      <div class="cd-card__price">{{ section.settings.placeholder_price }}</div>
                      <button class="cd-card__add">{{ section.settings.placeholder_button }}</button>
                   </div>
                </div>
             {%- endfor -%}
          {%- endif -%}
        </div>
      </main>
    </div>
  </div>

  <div class="cd-actions-bar">
    <div class="cd-actions-container">
      <a href="{{ section.settings.back_url }}" class="cd-btn-back">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        {{ section.settings.back_text }}
      </a>
      <button class="cd-btn-order" id="PlaceOrderBtn">{{ section.settings.place_order_text }}</button>
    </div>
  </div>
</choose-dishes>

<script>
  if (!customElements.get('choose-dishes')) {
    customElements.define('choose-dishes', class ChooseDishes extends HTMLElement {
      constructor() {
        super();
        this.activeFilters = { types: new Set(), diets: new Set() };
      }
      get verified() { return window.postcodeVerified === true; }
      connectedCallback() {
        this.initFiltering();
        this.initCart();
      }
      initFiltering() {
        const typeItems = this.querySelectorAll('[data-filter-type]');
        const dietPills = this.querySelectorAll('[data-filter-diet]');
        typeItems.forEach(item => {
          item.addEventListener('click', () => {
            const type = item.getAttribute('data-filter-type');
            if (this.activeFilters.types.has(type)) { this.activeFilters.types.delete(type); item.classList.remove('is-active'); }
            else { this.activeFilters.types.add(type); item.classList.add('is-active'); }
            this.applyFilters();
          });
        });
        dietPills.forEach(pill => {
          pill.addEventListener('click', () => {
            const diet = pill.getAttribute('data-filter-diet');
            if (this.activeFilters.diets.has(diet)) { this.activeFilters.diets.delete(diet); pill.classList.remove('is-active'); }
            else { this.activeFilters.diets.add(diet); pill.classList.add('is-active'); }
            this.applyFilters();
          });
        });
      }
      applyFilters() {
        const cards = this.querySelectorAll('.cd-card');
        const hasTypeFilters = this.activeFilters.types.size > 0;
        const hasDietFilters = this.activeFilters.diets.size > 0;
        cards.forEach(card => {
          const cardType = card.getAttribute('data-type');
          const cardDiets = card.getAttribute('data-diets').split(',').filter(d => d !== "");
          const typeMatch = !hasTypeFilters || this.activeFilters.types.has(cardType);
          const dietMatch = !hasDietFilters || [...this.activeFilters.diets].some(d => cardDiets.includes(d));
          if (typeMatch && dietMatch) { card.style.display = ''; card.style.opacity = '1'; }
          else { card.style.display = 'none'; card.style.opacity = '0'; }
        });
      }
      initCart() {
        this.addEventListener('click', (e) => {
          const addBtn = e.target.closest('.cd-card__add');
          if (addBtn) {
            if (!this.verified) {
               const input = document.getElementById('PostcodeChecker-Inline');
               if (input) { input.focus(); input.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
               return;
            }
            const variantId = addBtn.getAttribute('data-variant-id');
            if (variantId) this.addToCart(variantId, addBtn);
          }
          const orderBtn = e.target.closest('#PlaceOrderBtn');
          if (orderBtn) { window.location.href = '/cart'; }
        });
      }
      async addToCart(id, btn) {
        const originalText = btn.textContent;
        btn.textContent = {{ section.settings.js_adding_text | default: 'Adding...' | json }};
        btn.disabled = true;
        try {
          const res = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ items: [{ id, quantity: 1 }] })
          });
          if (res.ok) {
            btn.textContent = {{ section.settings.js_added_text | default: 'Added ✓' | json }};
            btn.style.backgroundColor = 'var(--color-purple-dark)';
            btn.style.color = '#fff';
            document.dispatchEvent(new CustomEvent('cart:updated'));
            setTimeout(() => { btn.textContent = originalText; btn.style.backgroundColor = ''; btn.style.color = ''; btn.disabled = false; }, 1500);
          }
        } catch (e) {
          btn.textContent = {{ section.settings.js_error_text | default: 'Error' | json }};
          setTimeout(() => { btn.textContent = originalText; btn.disabled = false; }, 1500);
        }
      }
    });
  }
</script>

{% schema %}
{
  "name": "Choose Dishes",
  "settings": [
    {
      "type": "header",
      "content": "Postcode Checker Settings"
    },
    { "type": "color", "id": "pc_color_primary", "label": "Primary Color", "default": "#452b69" },
    { "type": "color", "id": "pc_color_container_bg", "label": "Container Background", "default": "#f1ecf9" },
    { "type": "color", "id": "pc_color_pill_bg", "label": "Pill Background", "default": "#ffffff" },
    { "type": "color", "id": "pc_color_error", "label": "Error Color", "default": "#cc486b" },
    { "type": "text", "id": "pc_label_text", "label": "Label Text", "default": "ENTER YOUR POSTCODE" },
    { "type": "text", "id": "pc_badge_text", "label": "Badge Text", "default": "REQUIRED" },
