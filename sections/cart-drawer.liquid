{%- render 'cart-drawer' -%}

{% schema %}
{
  "name": "t:sections.cart-drawer.name",
  "tag": "div",
  "class": "cart-drawer-section",
  "settings": [
    {
      "type": "header",
      "content": "Text Labels"
    },
    {
      "type": "text",
      "id": "cart_title",
      "label": "Cart Title",
      "default": "Jouw winkelwagen"
    },
    {
      "type": "text",
      "id": "free_delivery_text",
      "label": "Free Delivery Text",
      "default": "Gratis bezorging op deze bestelling"
    },
    {
      "type": "text",
      "id": "coupon_placeholder",
      "label": "Coupon Placeholder",
      "default": "Kortingscode"
    },
    {
      "type": "text",
      "id": "coupon_button_label",
      "label": "Coupon Button Label",
      "default": "Toepassen"
    },
    {
      "type": "text",
      "id": "subtotal_label",
      "label": "Subtotal Label",
      "default": "Subtotaal"
    },
    {
      "type": "text",
      "id": "meals_label",
      "label": "Meals Label",
      "default": "maaltijden"
    },
    {
      "type": "text",
      "id": "delivery_label",
      "label": "Delivery Label",
      "default": "Bezorging"
    },
    {
      "type": "text",
      "id": "free_label",
      "label": "Free Label",
      "default": "Gratis"
    },
    {
      "type": "text",
      "id": "total_label",
      "label": "Total Label",
      "default": "Totaal"
    },
    {
      "type": "text",
      "id": "checkout_label",
      "label": "Checkout Button Label",
      "default": "Afrekenen"
    },
    {
      "type": "text",
      "id": "view_cart_label",
      "label": "View Cart Button Label",
      "default": "Bekijk winkelwagen"
    },
    {
      "type": "text",
      "id": "secure_checkout_text",
      "label": "Secure Checkout Text",
      "default": "Veilig betalen · iDEAL · Mollie · PayPal"
    },
    {
      "type": "header",
      "content": "JS Messages"
    },
    {
      "type": "text",
      "id": "js_applying_text",
      "label": "JS: Applying Text",
      "default": "Toepassen..."
    },
    {
      "type": "text",
      "id": "js_error_text",
      "label": "JS: Error Text",
      "default": "Fout"
    }
  ]
}
{% endschema %}