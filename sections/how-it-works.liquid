{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .how-it-works {
    position: relative;
    overflow-x: hidden; /* Prevents horizontal scroll from floating image */
  }

  /* Floating Decorative Image */
.how-it-works__floating-image {
    position: absolute;
    top: 0;
    right: -12%;
    height: 100%;
    width: auto;
    max-width: 515px;
    object-fit: contain;
    object-position: right center;
    pointer-events: none;
    z-index: 0;
}

  @media screen and (max-width: 990px) {
    .how-it-works__floating-image {
    display: none;
    }
  }

  /* Header Styles */
  .how-it-works__header {
    text-align: left;
    margin-bottom: 4rem;
    position: relative;
    z-index: 1;
    max-width: 800px;
  }

  .how-it-works__caption {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #6046b6;
    margin-bottom: 1rem;
  }
  .how-it-works__text {
    font-size: 1.4rem;
    color: #666666;
    margin: 0;
  }

  /* Steps Grid Layout */
  .how-it-works__steps-wrapper {
    position: relative;
    z-index: 1;
  }

  .how-it-works__steps {
    display: flex;
    flex-direction: column;
    gap: 2.5rem; /* Tighter gap on mobile */
    position: relative;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  /* Desktop Steps Layout */
  @media screen and (min-width: 750px) {
    .how-it-works__steps {
      flex-direction: row;
      justify-content: space-between;
      gap: 2rem;
    }

    /* The Connecting Line */
    .how-it-works__steps::before {
      content: '';
      position: absolute;
      top: 45px; /* Half of the 90px icon box */
      left: 12.5%;
      width: 75%;
      height: 1px;
      background-color: #e8e2f4;
      z-index: -1;
    }
  }

  /* INDIVIDUAL STEP STYLES */
  .how-it-works__step {
    display: flex;
    flex-direction: row; /* Mobile: Side by side */
    align-items: flex-start;
    text-align: left;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .how-it-works__step {
      flex: 1;
      flex-direction: column; /* Desktop: Stacked */
      align-items: center;
      text-align: center;
      max-width: 280px;
      margin: 0 auto;
    }
  }

  .how-it-works__step-content {
    display: flex;
    flex-direction: column;
    gap: 7px;
  }

  .how-it-works__step-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px; /* Mobile size */
    height: 52px; /* Mobile size */
    background-color: #614193;
    border-radius: 10px;
    color: #ffffff;
    flex-shrink: 0;
  }

  @media screen and (min-width: 750px) {
    .how-it-works__step-icon {
      width: 80px;
      height: 80px;
      border-radius: 12px;
    }
  }

  .how-it-works__step-icon svg {
    width: 28px;
    height: 28px;
    stroke-width: 1.5;
  }

  .how-it-works__step-number {
    font-size: 1.4rem;
    font-weight: 700;
    color: #6046b6;
    margin-bottom: 0.2rem;
  }

.how-it-works__step-title {
    font-size: 1.7rem;
    font-weight: 700;
    color: #2c2c2c;
    margin: 0;
    font-family: "DM Sans", sans-serif;
}

  .how-it-works__step-text {
    font-size: 1.3rem;
    line-height: 1.5;
    color: #666666;
    margin: 0;
  }
{%- endstyle -%}

<div class="how-it-works section-{{ section.id }}-padding">
  
  {%- if section.settings.floating_image != blank -%}
    {{ section.settings.floating_image | image_url: width: 1600 | image_tag: 
      class: 'how-it-works__floating-image', 
      loading: 'lazy', 
      alt: section.settings.floating_image.alt | default: "decorative background image" | escape 
    }}
  {%- endif -%}

  <div class="page-width">
    
    <div class="how-it-works__header">
      {%- if section.settings.caption != blank -%}
        <span class="how-it-works__caption">{{ section.settings.caption }}</span>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="how-it-works__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <p class="how-it-works__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="how-it-works__steps-wrapper">
      <ul class="how-it-works__steps">
        {%- for block in section.blocks -%}
          <li class="how-it-works__step" {{ block.shopify_attributes }}>
            <div class="how-it-works__step-icon">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            
            <div class="how-it-works__step-content">
              {%- if block.settings.step_number != blank -%}
                <div class="how-it-works__step-number">{{ block.settings.step_number }}</div>
              {%- endif -%}
              
              {%- if block.settings.title != blank -%}
                <h3 class="how-it-works__step-title">{{ block.settings.title }}</h3>
              {%- endif -%}
              
              {%- if block.settings.text != blank -%}
                <p class="how-it-works__step-text">{{ block.settings.text }}</p>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>

  </div>
</div>

{% schema %}
