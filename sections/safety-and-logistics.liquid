{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Header Styles */
  .safety-logistics__header {
    margin-bottom: 2.5rem;
    max-width: 900px;
  }

  .safety-logistics__caption {
    display: block;
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ section.settings.caption_color }};
    margin-bottom: 1rem;
  }

  .safety-logistics__heading {
    margin: 0 0 1rem 0;
    color: rgb(var(--color-foreground));
    font-family: var(--font-heading-family);
    font-weight: 900;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .safety-logistics__desc {
    font-size: 1.5rem;
    color: rgba(var(--color-foreground), 0.75);
    margin: 0;
  }

  .safety-logistics__divider {
    border: none;
    border-top: 1px solid rgba(var(--color-foreground), 0.08);
    margin: 3rem 0;
  }

  /* Grid & Cards - MOBILE SLIDER */
  .safety-logistics__grid {
    display: flex;
    flex-wrap: nowrap;
    gap: 1.5rem;
    margin-bottom: 3rem;
    list-style: none;
    
    /* Edge-to-edge horizontal scrolling */
    margin-left: -1.5rem !important;
    margin-right: -1.5rem !important;
    padding: 0 1.5rem 2rem 1.5rem !important; 
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 1.5rem;
    -webkit-overflow-scrolling: touch;
    
    /* Hide scrollbar */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
  }

  .safety-logistics__grid::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  /* Grid & Cards - DESKTOP */
  @media screen and (min-width: 750px) {
    .safety-logistics__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      margin-left: 0 !important;
      margin-right: 0 !important;
      padding: 0 !important;
      overflow-x: visible;
    }
  }

  @media screen and (min-width: 990px) {
    .safety-logistics__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .sl-card {
    background: rgb(var(--color-background));
    border: 1px solid rgba(var(--color-foreground), 0.08);
    border-radius: 12px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    
    /* Mobile sizing to show ~1.3 items */
    width: 75vw;
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  @media screen and (min-width: 750px) {
    .sl-card {
      width: 100%; /* Resets for desktop grid */
      height: 100%;
    }
  }

  .sl-card__icon-wrapper {
    width: 48px;
    height: 48px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .sl-card__icon-wrapper svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .sl-card__badge {
    display: inline-block;
    padding: 4px 10px;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .sl-card__title {
    font-size: 2.4rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 1rem 0;
    font-family: inherit;
  }

  .sl-card__text {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
    line-height: 1.5;
  }

  /* Banner Styles */
  .safety-banner {
    border-radius: 12px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .safety-banner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 2rem 3rem;
    }
  }

  .safety-banner__left {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
  }

  .safety-banner__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .safety-banner__icon svg {
    width: 20px;
    height: 20px;
    color: rgb(var(--color-foreground));
    stroke-width: 3;
  }

  .safety-banner__title {
    font-size: 1.5rem;
    font-weight: 700;
    color: rgb(var(--color-foreground));
    margin: 0 0 0.5rem 0;
  }

  .safety-banner__text {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.8);
    margin: 0;
  }

  .safety-banner__tags {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .safety-banner__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 800;
    color: #ffffff; /* Explicit white for brand tags */
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .safety-banner__tag svg {
    width: 12px;
    height: 12px;
    fill: currentColor;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="safety-logistics__header">
      {%- if section.settings.caption != blank -%}
        <span class="safety-logistics__caption">{{ section.settings.caption }}</span>
      {%- endif -%}
      
      {%- if section.settings.heading != blank -%}
        <h2 class="safety-logistics__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}
      
      {%- if section.settings.text != blank -%}
        <p class="safety-logistics__desc">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <hr class="safety-logistics__divider">

    {%- if section.blocks.size > 0 -%}
      <ul class="safety-logistics__grid">
        {%- for block in section.blocks -%}
          <li class="sl-card" {{ block.shopify_attributes }}>
            <div class="sl-card__icon-wrapper" style="background-color: {{ block.settings.theme_color_light }}; color: {{ block.settings.theme_color_dark }};">
              {{ block.settings.custom_svg }}
            </div>
            
            {%- if block.settings.badge_text != blank -%}
              <div class="sl-card__badge" style="background-color: {{ block.settings.theme_color_light }}; color: {{ block.settings.theme_color_dark }};">
                {{ block.settings.badge_text }}
              </div>
            {%- endif -%}
            
            {%- if block.settings.title != blank -%}
              <h3 class="sl-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            
            {%- if block.settings.text != blank -%}
              <p class="sl-card__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.show_banner -%}
      <div class="safety-banner color-{{ section.settings.banner_color_scheme }} gradient">
        <div class="safety-banner__left">
          <div class="safety-banner__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
          </div>
          
          <div class="safety-banner__content">
            <h4 class="safety-banner__title">{{ section.settings.banner_title }}</h4>
            <p class="safety-banner__text">{{ section.settings.banner_text }}</p>
          </div>
        </div>

        <div class="safety-banner__tags">
          {%- if section.settings.banner_tag_1 != blank -%}
            <span class="safety-banner__tag" style="background-color: {{ section.settings.banner_tag_1_bg }};">
              {{ section.settings.banner_tag_1 }}
            </span>
          {%- endif -%}
          
          {%- if section.settings.banner_tag_2 != blank -%}
            <span class="safety-banner__tag" style="background-color: {{ section.settings.banner_tag_2_bg }};">
              {%- if section.settings.show_snowflake -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"></line><line x1="12" y1="2" x2="16" y2="6"></line><line x1="12" y1="2" x2="8" y2="6"></line><line x1="12" y1="22" x2="16" y2="18"></line><line x1="12" y1="22" x2="8" y2="18"></line><line x1="2" y1="12" x2="22" y2="12"></line><line x1="2" y1="12" x2="6" y2="8"></line><line x1="2" y1="12" x2="6" y2="16"></line><line x1="22" y1="12" x2="18" y2="8"></line><line x1="22" y1="12" x2="18" y2="16"></line><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line><line x1="4.93" y1="19.07" x2="19.07" y2="4.93"></line></svg>
              {%- endif -%}
              {{ section.settings.banner_tag_2 }}
            </span>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
