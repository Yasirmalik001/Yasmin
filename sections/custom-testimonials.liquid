{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-grid.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    overflow: hidden; 
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Header & Overall Score Layout */
  .custom-testimonials__header {
    display: flex;
    flex-direction: column;
    gap: 0rem;
    margin-bottom: 3rem;
  }

  .custom-testimonials__overall {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

 .custom-testimonials__overall-score {
    font-family: Barlow, sans-serif;
    font-weight: 900;
    font-size: 48px;
    color: #442C6C;
    line-height: 100%;
}

  .custom-testimonials__overall-right {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .custom-testimonials__stars {
    display: inline-flex;
  }

  .custom-testimonials__stars svg {
    width: 18px;
    height: 18px;
    color: {{ section.settings.accent_color }};
    fill: currentColor;
  }

  .custom-testimonials__overall-text {
    font-size: 1.1rem;
    opacity: 0.7;
  }

  @media screen and (min-width: 750px) {
    .custom-testimonials__header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
    
    .custom-testimonials__overall {
      text-align: right;
    }
  }

  /* -------------------------
     PURE CSS MARQUEE SLIDER 
     ------------------------- */
  .custom-testimonials__marquee-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    /* Allow full bleed outside page-width if needed, or keep bounded */
    margin: 0 auto;
  }

  /* Left and Right Fades */
  .custom-testimonials__marquee-container::before,
  .custom-testimonials__marquee-container::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: {{ section.settings.fade_width }}px;
    z-index: 2;
    pointer-events: none; /* Let clicks pass through to cards */
  }

  .custom-testimonials__marquee-container::before {
    left: 0;
    background: linear-gradient(to right, rgb(var(--color-background)) 0%, rgba(var(--color-background), 0) 100%);
  }

  .custom-testimonials__marquee-container::after {
    right: 0;
    background: linear-gradient(to left, rgb(var(--color-background)) 0%, rgba(var(--color-background), 0) 100%);
  }

  .custom-testimonials__marquee-track {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    width: max-content;
    animation: marquee-scroll {{ section.settings.marquee_speed }}s linear infinite;
  }

  {% if section.settings.pause_on_hover %}
  .custom-testimonials__marquee-container:hover .custom-testimonials__marquee-track {
    animation-play-state: paused;
  }
  {% endif %}

  .custom-testimonials__marquee-group {
    display: flex;
    gap: {{ section.settings.card_gap }}px;
    flex-shrink: 0;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Translate exactly 50% of the track width minus half the gap */
      transform: translateX(calc(-50% - ({{ section.settings.card_gap }}px / 2)));
    }
  }

  /* Card Styles */
  .custom-testimonial-card {
    background: #ffffff;
    color: #121212; 
    border-radius: 12px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    /* Fixed widths prevent flex shrinking inside the marquee */
    width: 85vw;
    max-width: 350px; 
    flex-shrink: 0;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
  }

  @media screen and (min-width: 750px) {
    .custom-testimonial-card {
      width: 400px;
      max-width: 400px;
    }
  }

  .custom-testimonial-card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.5rem;
  }

  .custom-testimonial-card__name {
    font-family: inherit;
    font-weight: 700;
    margin: 0;
    font-size: 1.4rem;
  }

  .custom-testimonial-card__verified {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.1rem;
    color: #8c8c8c;
    margin-bottom: 2rem;
  }

  .custom-testimonial-card__verified-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background-color: {{ section.settings.accent_color }};
    border-radius: 50%;
  }

  .custom-testimonial-card__text {
    font-size: 1.4rem;
    color: #555555;
    line-height: 1.5;
    margin: 0 0 3rem 0;
    flex-grow: 1;
    white-space: normal; /* Restore standard text wrapping inside card */
  }

  .custom-testimonial-card__date {
    font-size: 1.1rem;
    color: #b3b3b3;
    margin: 0;
  }
{%- endstyle -%}

<div class="custom-testimonials color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding isolate">
  <div class="page-width">
    
    <div class="custom-testimonials__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="custom-testimonials__heading h2">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <div class="custom-testimonials__overall">
        {%- if section.settings.overall_score != blank -%}
          <div class="custom-testimonials__overall-score">{{ section.settings.overall_score }}</div>
        {%- endif -%}
        
        <div class="custom-testimonials__overall-right">
          <div class="custom-testimonials__stars">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          {%- if section.settings.overall_text != blank -%}
            <div class="custom-testimonials__overall-text">{{ section.settings.overall_text }}</div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  <!-- Marquee Structure -->
  <div class="custom-testimonials__marquee-container">
    <div class="custom-testimonials__marquee-track">
      
      {%- capture card_content -%}
        {%- for block in section.blocks -%}
          <div class="custom-testimonial-card" {{ block.shopify_attributes }}>
            <div class="custom-testimonial-card__top">
              <h3 class="custom-testimonial-card__name">{{ block.settings.author_name }}</h3>
              <div class="custom-testimonials__stars">
                {%- for i in (1..5) -%}
                  <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endfor -%}
              </div>
            </div>

            <div class="custom-testimonial-card__verified">
              <span class="custom-testimonial-card__verified-dot"></span>
              {{ block.settings.verified_text }}
            </div>

            <p class="custom-testimonial-card__text">{{ block.settings.review_text }}</p>

            <div class="custom-testimonial-card__date">{{ block.settings.date }}</div>
          </div>
        {%- endfor -%}
      {%- endcapture -%}

      <!-- Group 1 -->
      <div class="custom-testimonials__marquee-group">
        {{ card_content }}
      </div>
      <!-- Group 2 (Duplicate for infinite seamless loop) -->
      <div class="custom-testimonials__marquee-group" aria-hidden="true">
        {{ card_content }}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Loved Across the Diaspora"
    },
    {
      "type": "header",
      "content": "Overall Rating"
    },
    {
      "type": "text",
      "id": "overall_score",
      "label": "Overall Score",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "overall_text",
      "label": "Overall Review Text",
      "default": "op basis van 2.500+ beoordelingen"
    },
    {
      "type": "header",
      "content": "Marquee Settings"
    },
    {
      "type": "range",
      "id": "marquee_speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "sec",
      "label": "Scroll Speed",
      "default": 30,
      "info": "Higher number means slower speed."
    },
    {
      "type": "range",
      "id": "card_gap",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Gap between cards",
      "default": 24
    },
    {
      "type": "range",
      "id": "fade_width",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Left/Right Fade Width",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Stars & Dots)",
      "default": "#ff007f"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review Card",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Name"
        },
        {
          "type": "text",
          "id": "verified_text",
          "label": "Verified Text",
          "default": "Geverifieerde bestelling"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Quote",
          "default": "Write a review here."
        },
        {
          "type": "text",
          "id": "date",
          "label": "Date",
          "default": "28.04.2025"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "author_name": "Fatma K.",
            "review_text": "\"Finally a service that tastes exactly like my mother's cooking. Karnıyarık was perfect. Highly recommend the subscription!\""
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Ervin T.",
            "review_text": "\"Living in Germany I always missed proper Turkish food. Yasemin solves that completely. Fresh every week, never disappointed.\""
          }
        },
        {
          "type": "review",
          "settings": {
            "author_name": "Holger M.",
            "review_text": "\"The Chef Box is incredible value. Restaurant-level quality — my whole family loves it. Changed our weekly routine.\""
          }
        }
      ]
    }
  ]
}
{% endschema %}