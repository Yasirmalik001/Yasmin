{%- comment -%}
  BUGFIX: Emit a selling plans data map from Liquid so the JS can resolve the
  correct Shopify selling_plan ID for any combination of (duration_weeks, variant_days, product_id).
  Structure: { "<planName>": { "<variantTitle>": { "<productId>": planId } } }
  This is built from actual selling_plan_allocations on each product variant.
{%- endcomment -%}
<script type="application/json" id="mb-selling-plans-data">
  {
    {%- assign sp_first_plan = true -%}
    {%- assign sp_plan_names = ',' -%}

    {%- comment -%} Gather all products from tabs and collection {%- endcomment -%}
    {%- assign sp_products_list = '' -%}
    {%- if section.settings.default_product != blank -%}
      {%- assign sp_products_list = sp_products_list | append: section.settings.default_product.handle | append: ',' -%}
    {%- endif -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'week_tab' -%}
        {%- if block.settings.collection != blank -%}
          {%- assign week_collection = block.settings.collection -%}
        {%- else -%}
          {%- assign week_collection = section.settings.collection -%}
        {%- endif -%}
        {%- if week_collection != blank -%}
          {%- for product in week_collection.products -%}
            {%- unless sp_products_list contains product.handle -%}
              {%- assign sp_products_list = sp_products_list | append: product.handle | append: ',' -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
    {%- if section.settings.collection != blank -%}
      {%- for product in section.settings.collection.products -%}
        {%- unless sp_products_list contains product.handle -%}
          {%- assign sp_products_list = sp_products_list | append: product.handle | append: ',' -%}
        {%- endunless -%}
      {%- endfor -%}
    {%- endif -%}

    {%- assign sp_products_handles = sp_products_list | split: ',' -%}

    {%- for sp_handle in sp_products_handles -%}
      {%- if sp_handle != blank -%}
        {%- assign sp_product = all_products[sp_handle] -%}
        {%- for sp_variant in sp_product.variants -%}
          {%- for sp_alloc in sp_variant.selling_plan_allocations -%}
            {%- assign sp_plan = sp_alloc.selling_plan -%}
            {%- assign sp_plan_key = sp_plan.name | handleize -%}
            {%- assign lookup_token = ',' | append: sp_plan_key | append: ',' -%}
            {%- unless sp_plan_names contains lookup_token -%}
              {%- unless sp_first_plan -%},{%- endunless -%}
              {{ sp_plan.name | json }}: {
                {%- assign sp_first_var_in_plan = true -%}
                {%- for sp_var2 in sp_product.variants -%}
                  {%- for sp_alloc2 in sp_var2.selling_plan_allocations -%}
                    {%- if sp_alloc2.selling_plan.name == sp_plan.name -%}
                      {%- unless sp_first_var_in_plan -%},{%- endunless -%}
                      {{ sp_var2.title | json }}: {
                        {%- assign sp_first_prod_in_var = true -%}
                        {%- for sp_handle2 in sp_products_handles -%}
                          {%- if sp_handle2 != blank -%}
                            {%- assign sp_product2 = all_products[sp_handle2] -%}
                            {%- for sp_alloc3 in sp_product2.variants -%}
                              {%- if sp_alloc3.title == sp_var2.title -%}
                                {%- for sp_alloc4 in sp_alloc3.selling_plan_allocations -%}
                                  {%- if sp_alloc4.selling_plan.name == sp_plan.name -%}
                                    {%- unless sp_first_prod_in_var -%},{%- endunless -%}
                                    {{ sp_product2.id | json }}: {{ sp_alloc4.selling_plan.id | json }}
                                    {%- assign sp_first_prod_in_var = false -%}
                                  {%- endif -%}
                                {%- endfor -%}
                              {%- endif -%}
                            {%- endfor -%}
                          {%- endif -%}
                        {%- endfor -%}
                      }
                      {%- assign sp_first_var_in_plan = false -%}
                    {%- endif -%}
                  {%- endfor -%}
                {%- endfor -%}
              }
              {%- assign sp_plan_names = sp_plan_names | append: sp_plan_key | append: ',' -%}
              {%- assign sp_first_plan = false -%}
            {%- endunless -%}
          {%- endfor -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endfor -%}
  }
</script>

<script type="application/json" id="default-product-selling-plans">
  {%- assign current_product = section.settings.default_product -%}
  {%- if current_product != blank -%}
    {%- assign variants_output = '' -%}
    {%- for variant in current_product.variants -%}
      {%- if variant.selling_plan_allocations.size > 0 -%}
        {%- if variants_output != '' -%}{%- assign variants_output = variants_output | append: ',' -%}{%- endif -%}
        {%- assign selling_plans_output = '' -%}
        {%- for allocation in variant.selling_plan_allocations -%}
          {%- assign sp = allocation.selling_plan -%}
          {%- if selling_plans_output != '' -%}{%- assign selling_plans_output = selling_plans_output | append: ',' -%}{%- endif -%}
          {%- capture sp_json -%}
            { "id": {{ sp.id | json }}, "name": {{ sp.name | json }}, "price": {{ allocation.price | json }}, "compareAtPrice": {{ allocation.compare_at_price | json }} }
          {%- endcapture -%}
          {%- assign selling_plans_output = selling_plans_output | append: sp_json -%}
        {%- endfor -%}
        {%- capture variant_json -%}
          { "id": {{ variant.id | json }}, "title": {{ variant.title | json }}, "sellingPlans": [{{ selling_plans_output }}] }
        {%- endcapture -%}
        {%- assign variants_output = variants_output | append: variant_json -%}
      {%- endif -%}
    {%- endfor -%}
    [{{ variants_output }}]
  {%- else -%}
    []
  {%- endif -%}
</script>

<script type="application/json" id="mb-products-data">
{
  {%- assign is_first = true -%}
  {%- assign added_product_ids = ',' -%}

  {%- if section.settings.default_product != blank -%}
    "{{ section.settings.default_product.id }}": {{ section.settings.default_product | json }}
    {%- assign check_id = ',' | append: section.settings.default_product.id | append: ',' -%}
    {%- assign added_product_ids = added_product_ids | append: check_id -%}
    {%- assign is_first = false -%}
  {%- endif -%}

  {%- for block in section.blocks -%}
    {%- if block.type == 'week_tab' -%}
      {%- if block.settings.collection != blank -%}
        {%- assign week_collection = block.settings.collection -%}
      {%- else -%}
        {%- assign week_collection = section.settings.collection -%}
      {%- endif -%}

      {%- if week_collection != blank -%}
        {%- for product in week_collection.products -%}
          {%- assign check_id = ',' | append: product.id | append: ',' -%}
          {%- unless added_product_ids contains check_id -%}
            {%- if is_first == false -%},{%- endif -%}
            "{{ product.id }}": {{ product | json }}
            {%- assign added_product_ids = added_product_ids | append: check_id -%}
            {%- assign is_first = false -%}
          {%- endunless -%}
        {%- endfor -%}
      {%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if section.settings.collection != blank -%}
    {%- for product in section.settings.collection.products -%}
      {%- assign check_id = ',' | append: product.id | append: ',' -%}
      {%- unless added_product_ids contains check_id -%}
        {%- if is_first == false -%},{%- endif -%}
        "{{ product.id }}": {{ product | json }}
        {%- assign added_product_ids = added_product_ids | append: check_id -%}
        {%- assign is_first = false -%}
      {%- endunless -%}
    {%- endfor -%}
  {%- endif -%}
}
</script>

