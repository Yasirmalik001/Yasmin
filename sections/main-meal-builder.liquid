

{%- style -%}
  .meal-builder-wrapper {
    --color-primary: #5243C0;
    --color-primary-light: #F4F3FA;
    --color-primary-hover: #4032A0;
    --color-success: #00B359; 
    --color-pink: #FF007F; 
    --color-border: #E5E7EB;
    --color-text-main: #111827;
    --color-text-muted: #6B7280;
    font-family: 'DM Sans', sans-serif;
  }

  .meal-builder-wrapper * {
    font-family: 'DM Sans', sans-serif;
  }
.mb-modal__dish-tags {
    display:flex;
    gap:6px;
    flex-wrap:wrap;
}

.mb-modal__dish-tag {
    padding:4px 10px;
    border-radius:6px;
    font-size:12px;
    font-weight:600;
    line-height:1;
}

/* Tag 1 */
.mb-modal__dish-tag:nth-child(1) {
    background:#E4F2D8;
    color:#4E7B2D;
}
.mb-summary__total * {
    font-weight: 800;
font-family: Barlow, sans-serif;
}
/* Tag 2 */
.mb-modal__dish-tag:nth-child(2) {
    background:#F8E8D3;
    color:#9A6A17;
}

.mb-modal__dish-tag:nth-child(3) {
    background: lightblue;
    color: darkblue;
}
.meal-builder-wrapper h2,
.meal-builder-wrapper h2 * {
    font-family: Barlow, sans-serif !important;
}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* --- Layout --- */
  .meal-builder {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  @media screen and (min-width: 990px) {
    .meal-builder {
      flex-direction: row;
      align-items: flex-start;
      gap: 5rem;
      justify-content: space-between;
    }
    .meal-builder__sidebar {
      width: 320px;
      flex-shrink: 0;
    }
  }
  .meal-builder__main {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1050px;
  }
  .meal-builder__sidebar {
    position: sticky;
    top: 12rem;
  }

  /* --- Typography & Headers --- */
  .mb-section-header { margin-bottom: 1.5rem; }
  .mb-section-header h2 {
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--color-text-main);
  }
  .mb-section-header p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* --- Postcode Checker --- */
  .postcode-checker__container {
    background-color: var(--color-primary-light);
    border: 1px solid var(--color-primary);
    border-radius: 8px;
    padding: 2rem;
    max-width: 100%;
    margin-bottom: 1.2rem;
  }
  .postcode-checker__header {
    display: flex; align-items: center; gap: 1rem; margin-bottom: 1.2rem;
  }
  .postcode-checker__label {
    font-size: 12px; font-weight: 700; letter-spacing: 0.5px;
    text-transform: uppercase; color: var(--color-primary); margin: 0;
  }
  .postcode-checker__badge {
    background-color: var(--color-primary); color: #ffffff;
    font-size: 10px; font-weight: 700; padding: 3px 8px;
    border-radius: 4px; text-transform: uppercase;
  }
  .postcode-checker__input-group {
    display: flex; align-items: stretch; background-color: #ffffff;
    border: 1px solid var(--color-primary); border-radius: 6px; overflow: hidden;
  }
  .postcode-checker__prefix {
    display: flex; align-items: center; gap: 8px; padding: 0 16px;
    background-color: #ffffff;
    border-right: 1px solid var(--color-primary);
    font-size: 14px; font-weight: 700; color: var(--color-primary);
  }
  .postcode-checker__prefix-flag-img {
    width: 20px; height: 14px; object-fit: cover; border-radius: 2px;
  }
  .postcode-checker__input {
    flex-grow: 1; border: none; padding: 14px 16px; width: 100%;
    font-size: 14px; color: var(--color-text-main); background: transparent;
  }
  .postcode-checker__input:focus { outline: none; }
  .postcode-checker__submit {
    background-color: var(--color-primary); color: #ffffff; border: none;
    padding: 0 24px; font-size: 14px; font-weight: 700; cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
  }
  .postcode-checker__submit:hover { background-color: var(--color-primary-hover); }
  .postcode-checker__message { font-size: 13px; font-weight: 600; margin: 8px 0 0 0; display: none; }
  .postcode-checker__message.is-error { color: #d32f2f; display: block; }
  .postcode-checker__message.is-success { color: var(--color-success); display: block; }
  
  .postcode-checker__footer { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; margin-top: 16px; }
  .postcode-checker__footer-label { font-size: 13px; color: var(--color-text-muted); }
  .postcode-checker__pills { display: flex; flex-wrap: wrap; gap: 8px; list-style: none; padding: 0; margin: 0; }
  .postcode-checker__pill {
    display: inline-flex; align-items: center; gap: 6px;
    background-color: #EFEAF6; color: var(--color-primary);
    font-size: 12px; font-weight: 700; padding: 4px; border-radius: 20px;
  }
.postcode-checker__pill-flag {
    width: 100%;
    height: 20px;
    object-fit: cover;
    border-radius: 2px;
}

  /* --- Radio Tiles (Days & People) --- */
  .mb-tiles {
    display: flex; gap: 16px; flex-wrap: wrap;
  }
  .mb-tile {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    min-width: 80px; height: 90px;
    padding: 0 16px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; background: #ffffff;
    transition: all 0.2s;
  }
  .mb-tile input { display: none; }
  .mb-tile__val { font-size: 24px; font-weight: 800; color: var(--color-text-main); line-height: 1; margin-bottom: 4px; text-align: center; }
  .mb-tile__label { font-size: 13px; color: var(--color-text-muted); text-align: center; }
  .mb-tile__discount {
    position: absolute; top: -10px; right: -10px; background: var(--color-success); color: #fff;
    font-size: 10px; font-weight: 800; padding: 4px 8px; border-radius: 12px; white-space: nowrap; z-index: 2;
  }
  .mb-tile.is-active {
    border-color: var(--color-primary); background: var(--color-primary);
  }
  .mb-tile.is-active .mb-tile__val,
  .mb-tile.is-active .mb-tile__label {
    color: #ffffff;
  }

  /* --- Subscription Length (Cards) --- */
  .mb-subs {
    display: grid; grid-template-columns: 1fr; gap: 16px;
  }
  @media screen and (min-width: 750px) {
    .mb-subs { grid-template-columns: 1fr 1fr; }
  }
  .mb-sub-card {
    border: 1px solid var(--color-border); border-radius: 12px;
    padding: 24px; background: #ffffff; cursor: pointer;
    display: flex; flex-direction: column;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 120px;
    overflow: hidden;
  }
  .mb-sub-radio {
    width: 20px; height: 20px; border-radius: 50%; border: 1px solid #D1D5DB;
    margin-top: 16px; display: block; position: relative;
    transition: all 0.2s;
  }
  .mb-sub-content { flex: 1; display: flex; flex-direction: column; }
  .mb-sub-card.is-active {
    border-color: var(--color-primary); background: var(--color-primary); color: #ffffff;
    /* min-height: 180px; */
  }
  .mb-sub-card.is-active .mb-sub-radio {
    border: 1px solid #ffffff;
  }
  .mb-sub-card.is-active .mb-sub-radio::after {
    content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 10px; height: 10px; background: #ffffff; border-radius: 50%;
  }
  .mb-sub-card__header {
    display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;
  }
  .mb-sub-card__header-left { flex: 1; }
  .mb-sub-card__header-right { text-align: right; }

.mb-sub-card__title {
    font-size: 20px;
    font-weight: 800;
    margin: 0;
    color: inherit;
    font-family: Barlow, sans-serif !important;
}
  .mb-sub-card__desc { font-size: 13px; color: var(--color-text-muted); margin-top: 4px; }
  .mb-sub-card.is-active .mb-sub-card__desc { color: rgba(255,255,255,0.8); }
  
  .mb-sub-card__badge { font-size: 13px; font-weight: 800; color: var(--color-success); display: block; margin-bottom: 2px; }
  .mb-sub-card__price-calc { font-size: 12px; color: var(--color-text-muted); }
  .mb-sub-card.is-active .mb-sub-card__badge { color: #ffffff; opacity: 0.9; }
  .mb-sub-card.is-active .mb-sub-card__price-calc { color: #ffffff; opacity: 0.8; }

  .mb-sub-card__extra-buttons { 
    max-height: 0; 
    opacity: 0;
    margin-top: 0; 
    gap: 12px; 
    width: 100%; 
    display: flex;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    pointer-events: none;
    overflow: hidden;
  }
  .mb-sub-card.is-active .mb-sub-card__extra-buttons { 
    max-height: 100px; 
    opacity: 1;
    margin-top: 24px; 
    pointer-events: auto;
  }
  .btn-chef { 
    background: #ffffff; color: var(--color-text-main); border: 1px solid rgba(255,255,255,0.3); 
    padding: 14px; border-radius: 8px; flex: 1; font-weight: 800; font-size: 14px; cursor: pointer; transition: all 0.2s; 
  }
  .btn-chef.is-selected { background: var(--color-pink); color: white; border-color: var(--color-pink); }
  
  .btn-pick { 
    background: #ffffff; color: var(--color-text-main); border: 1px solid rgba(255,255,255,0.3); 
    padding: 14px; border-radius: 8px; flex: 1; font-weight: 700; font-size: 14px; 
    display: flex; align-items: center; justify-content: center; gap: 8px; transition: all 0.2s;
    text-decoration: none; cursor: pointer;
  }
  .btn-pick.is-selected { background: white; color: var(--color-primary); border-color: white; }
  .btn-pick span { font-size: 10px; color: var(--color-primary); background: var(--color-primary-light); padding: 2px 6px; border-radius: 12px; font-weight: 700; }

  .mb-plan-info {
    background: #F7F6F2; border-radius: 8px; padding: 16px; margin-top: 16px;
    font-size: 13px; color: var(--color-text-muted);  border: 1px solid #D3D1C7; line-height: 1.5;
  }
  .mb-plan-info strong { color: var(--color-text-main); }

  /* --- Dietary Tags & Tabs --- */
  .mb-filters-title { font-size: 11px; font-weight: 700; color: var(--color-text-muted); text-transform: uppercase; width: 100%; margin-bottom: 12px; letter-spacing: 0.5px; }
  .mb-filters {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px;
  }
  .mb-filter-tag {
    font-size: 13px; font-weight: 600; padding: 10px 18px;
    border: 1px solid var(--color-border); border-radius: 40px;
    background: #ffffff; color: var(--color-text-muted); cursor: pointer;
    display: flex; align-items: center; gap: 10px;
    transition: all 0.2s;
  }
  .mb-filter-tag:hover { background: #fdfdfd; border-color: #d1d5db; }
  .mb-filter-tag::before { content: ''; display: block; width: 8px; height: 8px; border-radius: 50%; background: #ccc; }
  
  /* Specific Dot Colors from Image */
  .mb-filter-tag.vegan::before { background: #10B981; } /* Emerald */
  .mb-filter-tag.vegetarian::before { background: #84CC16; } /* Lime */
  .mb-filter-tag.gluten-free::before { background: #D97706; } /* Amber */
  .mb-filter-tag.lactose-free::before { background: #2563EB; } /* Blue */
  .mb-filter-tag.meat-based::before { background: #EF4444; } /* Red */

  .mb-tabs {
    display: flex; gap: 10px; margin-bottom: 32px;
  }
 .mb-tab {
    padding: 12px 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-muted);
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
}
  .mb-tab.is-active {
    background: var(--color-primary); color: #ffffff; border-color: var(--color-primary);
  }
  .mb-tab:hover:not(.is-active) { background: #f9f9f9; border-color: #d1d5db; }

  /* --- Products Grid --- */
  .mb-week-header {
    display: flex; justify-content: space-between; align-items: center; margin-block: 20px;
  }
  .mb-week-title { font-size: 20px; font-weight: 800; margin: 0; color: var(--color-text-main); }
  .mb-week-badge {
    background: var(--color-primary-light); color: var(--color-text-muted);
    padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600;
  }

  .mb-grid {
    display: grid; grid-template-columns: 1fr; gap: 24px;
  }
  @media screen and (min-width: 750px) {
    .mb-grid { grid-template-columns: 1fr 1fr; }
  }

  .mb-product {
    background: #ffffff; border: 1px solid var(--color-border);
    border-radius: 12px; overflow: hidden; display: flex; flex-direction: column;
  }
.mb-product__img {
    width: 120px;
    height: 120px;
    object-fit: cover;
}

.mb-product-cc {
    display: flex;
    align-items: center;
    gap: 20px;
}
.mb-product__content.mb-product__content {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-inline-end: 20px;
}
  .mb-product__title {
    font-size: 16px; font-weight: 800; margin: 0 0 6px 0; color: var(--color-text-main);
  }
  .mb-product__desc {
    font-size: 13px; color: var(--color-text-muted); margin: 0 0 16px 0; line-height: 1.4;
  }
  .mb-product__tags {
    display: flex; gap: 8px; margin-bottom: 5px; flex-wrap: wrap;
  }
  .mb-product__tag, .mb-modal__box-tag, .mb-modal__dish-tag {
    font-size: 11px; padding: 4px 10px; border-radius: 6px; font-weight: 700;
    letter-spacing: 0.2px; line-height: 1; display: inline-flex; align-items: center;
    transition: all 0.2s;
  }
  
  /* --- Tag Color Mapping --- 
     To add a new tag color, add .tag-[handle-name] below.
  */
  .tag-vegan, .tag-vegetarian { background: #DCFCE7; color: #166534; }
  .tag-meat, .tag-meat-based, .tag-etli { background: #FEE2E2; color: #991B1B; }
  .tag-gluten-free, .tag-gf, .is-gf { background: #FFEDD5; color: #9A3412; }
  .tag-lactose-free { background: #DBEAFE; color: #1E40AF; }
  .tag-fish, .tag-seafood { background: #E0F2FE; color: #075985; }
  .tag-low-carb { background: #F3E8FF; color: #6B21A8; }

  .mb-product__footer {
    display: flex; justify-content: space-between; align-items: center; margin-top: auto;
  }
.mb-product__price {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text-main);
    font-family: Barlow, sans-serif;
}
  .mb-qty {
    display: flex; align-items: center; border: 1px solid var(--color-border); border-radius: 6px; overflow: hidden;
  }
  .mb-qty button {
    background: #ffffff; border: none; width: 36px; height: 36px;
    font-size: 18px; font-weight: 400; cursor: pointer; color: var(--color-text-main);
  }
  .mb-qty button:hover { background: #F9FAFB; }
  .mb-qty input {
    width: 40px; height: 36px; border: none;
    border-left: 1px solid var(--color-border); border-right: 1px solid var(--color-border);
    text-align: center; font-weight: 700; font-size: 14px; color: var(--color-text-main); background: #ffffff; pointer-events: none;
  }

  .mb-product__link {
    display: block; width: 100%; text-align: center; padding: 16px; border: none; cursor: pointer;
    font-size: 13px; font-weight: 700; color: var(--color-primary);
    text-decoration: none; border-top: 1px solid var(--color-border); background: #ffffff;
  }
  .mb-product__link:hover { background: #F9FAFB; }

  /* --- Bundle Tabs --- */



  /* --- View Dishes Modal --- */
  .mb-modal {
    max-width: 560px; width: 92%; margin: auto; padding: 0; border: none; border-radius: 16px;
    background: #ffffff; box-shadow: 0 24px 48px rgba(0,0,0,0.2); outline: none;
  }
  .mb-modal::backdrop { background: rgba(17, 24, 39, 0.6); backdrop-filter: blur(4px); }
  
  .mb-modal__header { position: relative; height: 180px; }
  .mb-modal__hero { width: 100%; height: 100%; object-fit: cover; }
  .mb-modal__header-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: flex-end;
    background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.8)); padding: 24px; color: #fff;
  }
  .mb-modal__title { font-size: 24px; font-weight: 800; margin: 0 0 6px 0; color: #ffffff; }
  .mb-modal__subtitle { font-size: 13px; color: rgba(255,255,255,0.9); margin: 0; line-height: 1.4; }
  
  .mb-modal__close {
    position: absolute; top: 16px; right: 16px; width: 32px; height: 32px; border-radius: 50%;
    background: #5243C0; border: none; color: #ffffff; display: flex; align-items: center; justify-content: center;
    cursor: pointer; backdrop-filter: blur(4px); transition: background 0.2s;
  }
  .mb-modal__close:hover { background: rgba(255,255,255,0.4); }
  
  .mb-modal__body { padding: 24px; max-height: 50vh; overflow-y: auto; }
  .mb-modal__box-tags { display: flex; gap: 8px; margin-bottom: 24px; }
  
  .mb-modal__dishes-title {
    font-size: 11px; font-weight: 800; color: var(--color-text-muted); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 16px;
  }
  
  .mb-modal__dish { display: flex; gap: 16px; padding: 16px 0; border-bottom: 1px solid var(--color-border); }
  .mb-modal__dish:last-child { border-bottom: none; }
  .mb-modal__dish-img { width: 56px; height: 56px; border-radius: 8px; object-fit: cover; flex-shrink: 0; }
  .mb-modal__dish-info { flex: 1; }
  .mb-modal__dish-title { font-size: 14px; font-weight: 800; color: var(--color-text-main); margin: 0 0 4px 0; }
  .mb-modal__dish-desc { font-size: 12px; color: var(--color-text-muted); margin: 0 0 10px 0; line-height: 1.4; }
  .mb-modal__dish-tags { display: flex; gap: 6px; }
  
  .mb-modal__dish-stats { text-align: right; display: flex; flex-direction: column; }
  .mb-modal__dish-cals { font-size: 16px; font-weight: 800; color: var(--color-primary); line-height: 1; margin-bottom: 4px; }
  .mb-modal__dish-cals span { font-size: 10px; font-weight: 600; color: var(--color-text-muted); display: block; margin-top: 2px;}
  .mb-modal__dish-macros { font-size: 10px; color: var(--color-text-muted); font-weight: 600; white-space: nowrap; margin-top: auto; letter-spacing: 0.2px;}
  
  .mb-modal__allergen-info {
    font-size: 11px; color: var(--color-text-muted); line-height: 1.5; padding: 16px;
    background: #F9FAFB; border-radius: 8px; margin: 0 24px 24px 24px;
  }
  .mb-modal__allergen-info a { color: var(--color-primary); font-weight: 600; text-decoration: none;}
  
  .mb-modal__footer {
    display: flex; justify-content: space-between; align-items: center; padding: 20px 24px;
    border-top: 1px solid var(--color-border); background: #ffffff;
  }
  .mb-modal__price { font-size: 24px; font-weight: 800; color: var(--color-text-main); line-height: 1; margin-bottom: 4px; }
  .mb-modal__price-sub { font-size: 12px; color: var(--color-text-muted); font-weight: 600; }
  
  .mb-modal__add-btn {
    background: var(--color-primary); color: #ffffff; border: none; padding: 12px 32px; border-radius: 8px;
    font-size: 14px; font-weight: 800; cursor: pointer; transition: background 0.2s;
  }
  .mb-modal__add-btn:hover { background: var(--color-primary-hover); }

  body:has(dialog[open]) { overflow: hidden; }

  /* --- Long Plan Confirmation Modal --- */
  .mb-confirm-modal {
    max-width: 480px; width: 92%; margin: auto; padding: 0; border: none; border-radius: 16px;
    background: #ffffff; box-shadow: 0 24px 48px rgba(0,0,0,0.2); outline: none;
    overflow: hidden;
  }
  .mb-confirm-modal::backdrop { background: rgba(17, 24, 39, 0.6); backdrop-filter: blur(4px); }
  .mb-confirm-modal__header {
    background: linear-gradient(135deg, #5243C0, #7C6BF0);
    padding: 28px 28px 24px;
    position: relative;
  }
  .mb-confirm-modal__icon {
    width: 48px; height: 48px; background: rgba(255,255,255,0.2); border-radius: 12px;
    display: flex; align-items: center; justify-content: center; margin-bottom: 16px;
  }
  .mb-confirm-modal__title {
    font-size: 20px; font-weight: 800; color: #ffffff; margin: 0 0 8px 0;
    font-family: Barlow, sans-serif;
  }
  .mb-confirm-modal__subtitle {
    font-size: 14px; color: rgba(255,255,255,0.85); margin: 0; line-height: 1.5;
  }
  .mb-confirm-modal__body {
    padding: 28px;
  }
  .mb-confirm-modal__steps {
    list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px;
  }
  .mb-confirm-modal__step {
    display: flex; gap: 14px; align-items: flex-start;
  }
  .mb-confirm-modal__step-icon {
    width: 36px; height: 36px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px;
  }
  .mb-confirm-modal__step:nth-child(1) .mb-confirm-modal__step-icon { background: #EDE9FE; }
  .mb-confirm-modal__step:nth-child(2) .mb-confirm-modal__step-icon { background: #DCFCE7; }
  .mb-confirm-modal__step:nth-child(3) .mb-confirm-modal__step-icon { background: #FEF3C7; }
  .mb-confirm-modal__step-text {
    font-size: 14px; color: var(--color-text-main); line-height: 1.5; font-weight: 500;
  }
  .mb-confirm-modal__step-text strong {
    font-weight: 800;
  }
  .mb-confirm-modal__footer {
    padding: 0 28px 28px; display: flex; flex-direction: column; gap: 10px;
  }
  .mb-confirm-modal__confirm-btn {
    width: 100%; padding: 14px; background: var(--color-primary); color: #ffffff;
    font-size: 15px; font-weight: 800; border: none; border-radius: 10px;
    cursor: pointer; transition: all 0.2s; font-family: 'DM Sans', sans-serif;
  }
  .mb-confirm-modal__confirm-btn:hover { background: var(--color-primary-hover); transform: translateY(-1px); }
  .mb-confirm-modal__cancel-btn {
    width: 100%; padding: 12px; background: transparent; color: var(--color-text-muted);
    font-size: 14px; font-weight: 600; border: none; cursor: pointer;
    transition: color 0.2s; font-family: 'DM Sans', sans-serif;
  }
  .mb-confirm-modal__cancel-btn:hover { color: var(--color-text-main); }

  /* --- Sidebar Summary --- */
  .mb-summary {
    background: #ffffff; padding: 0;
  }
  .mb-summary__header {
    margin-bottom: 24px; padding-bottom: 20px; border-bottom: 1px solid var(--color-border);
  }
  .mb-summary__header h3 {
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--color-text-main);
  }
  .mb-summary__header p {
    margin: 4px 0 0 0; font-size: 15px; color: var(--color-text-muted);
  }

  .mb-summary__list { list-style: none; padding: 0; margin: 0 0 24px 0; }
  .mb-summary__list li {
    display: flex; justify-content: space-between; font-size: 13px;
    padding: 8px 0; color: var(--color-text-muted);
  }
  .mb-summary__list li span:last-child {
    font-weight: 700; color: var(--color-text-main);
  }
  .mb-summary__list-title {
    font-size: 14px; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--color-text-muted); margin: 24px 0 8px 0;
  }

  .mb-summary__total {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 0; border-top: 2px solid var(--color-text-main); margin-bottom: 20px;
  }
  .mb-summary__total span:first-child {
    font-size: 20px; font-weight: 800; color: var(--color-text-main);
  }
  .mb-summary__total span:last-child {
    font-size: 28px; font-weight: 900; color: var(--color-primary);
  }

  .mb-summary__submit {
    width: 100%; padding: 16px;
    background: #C4B5FD; color: #ffffff;
    font-size: 16px; font-weight: 800; border: none; border-radius: 8px;
    cursor: not-allowed; transition: all 0.3s;
  }
  .mb-summary__submit.is-ready {
    background: var(--color-primary); cursor: pointer;
  }
  .mb-summary__submit.is-ready:hover { opacity: 0.95; }
  
  .mb-summary__secure {
    text-align: center; font-size: 12px; color: var(--color-text-muted); margin-top: 16px;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }
  @media screen and (max-width: 750px) {
.mb-sub-card__header-right {
    text-align: left;
}
    .mb-subs {
    grid-template-columns: 1fr 1fr;
}
.mb-sub-card__header {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
}

label.mb-sub-card {
    padding: 12px;
}
  }
{%- endstyle -%}

<meal-builder class="meal-builder-wrapper color-{{ section.settings.color_scheme }}" 
  data-adding-text="{{ section.settings.cart_adding_text | escape }}"
  data-added-text="{{ section.settings.cart_added_text | escape }}"
  data-error-text="{{ section.settings.cart_error_text | escape }}"
  data-people-label="{{ section.settings.people_label | default: 'people' }}"
  data-boxes-label="{{ section.settings.boxes_label | default: 'boxes' }}"
  data-select-up-to="{{ section.settings.label_select_up_to | default: 'select up to' }}"
  data-no-boxes="{{ section.settings.label_no_boxes | default: 'No boxes selected yet' }}"
  data-confirmed-text="{{ section.settings.label_confirmed | default: 'Confirmed' | escape }}"
  data-not-confirmed-text="{{ section.settings.label_not_confirmed | default: 'Not confirmed' | escape }}"
  data-label-week="{{ section.settings.label_week_prefix | default: 'Week' | escape }}"
  data-label-dishes-suffix="{{ section.settings.label_week_dishes_suffix | default: 'gerechten' | escape }}"
  data-label-of="{{ section.settings.label_of | default: 'van' | escape }}"
  data-label-per="{{ section.settings.label_per | default: 'per' | escape }}"
  data-label-week-singular="{{ section.settings.label_week_singular | default: 'week' | escape }}"
  data-label-week-plural="{{ section.settings.label_week_plural | default: 'weken' | escape }}"
>
  <div class="meal-builder page-width section-{{ section.id }}-padding">
    
    {%- assign heading_text = page.title | default: section.settings.step1_heading -%}
    {%- if heading_text != blank -%}
      <h1 class="visually-hidden">{{ heading_text }}</h1>
    {%- endif -%}
    
    <!-- LEFT COLUMN: BUILDER FORM -->
    <div class="meal-builder__main">

<div class="color-{{ section.settings.color_scheme }} gradient">
    {%- if section.settings.heading != blank -%}
      <p class="h2 heading-h2" style="text-align: left; margin-bottom: 2rem; margin-top: 0;">{{ section.settings.heading }}</p>
    {%- endif -%}
    <div>
{% assign delivery_date = cart.attributes['Delivery Date'] %}
{% assign delivery_day = cart.attributes['Delivery Day'] %}
{% assign formatted_delivery_date = delivery_date | date: '%Y-%m-%d' %}

<div class="delivery-picker-section">
  <div class="delivery-picker-header">
    <p class="delivery-picker-title" style="margin-top: 0;">{{ section.settings.pc_heading | default: "Where do we deliver?" }}</p>
    <p class="delivery-picker-subtitle">{{ section.settings.pc_subtitle | default: "Enter your postcode to confirm your delivery zone — required before continuing." }}</p>
  </div>

  <delivery-picker
    id="section-{{ section.id }}"
    delivery-date="{{ delivery_date }}"
    delivery-day="{{ delivery_day }}"
    {% if section.settings.restrict_next_week_until_wednesday %}restrict-next-week{% endif %}
    {{ section.shopify_attributes }}
  >
    <div class="delivery-picker-container">
      
      <!-- Cart Validation Error Alert Box -->
      <div class="delivery-picker-cart-alert visually-hidden" style="
        background-color: #fdf3f3;
        border: 1px solid #eb5757;
        color: #c62828;
        padding: 12px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        text-align: left;
      ">
        {{ section.settings.pc_js_error_add_to_order | default: "Kies een bezorgdatum om verder te gaan." }}
      </div>
      
      <div class="delivery-picker-step">
        <span class="step-text">{{ section.settings.pc_step_label | default: "STEP 1 — ENTER YOUR POSTCODE" }}</span>
        <span class="step-badge">{{ section.settings.pc_step_badge | default: "REQUIRED" }}</span>
      </div>

      <div class="delivery-zone__form">
        <template id="delivery-zone-unavailable">
          <p class="delivery-zone__feedback delivery-zone__feedback--unavailable">{{ 'sections.delivery-picker.feedback.unavailable' | t }}</p>
        </template>

        <form class="delivery-input-group">
          <div class="delivery-select-wrapper">
            <img decoding="async" loading="lazy" id="current_country_flag" src="" alt="Flag" width="20" height="14" style="border-radius:2px; object-fit:cover; margin-left: 1rem; display: none;">
            <label for="delivery_zone_country" class="visually-hidden">{{ "sections.delivery-picker.labels.country" }}</label>
           <select id="delivery_zone_country" name="delivery_zone[country]" required>
              {% for block in section.blocks %}
                {% if block.type == 'delivery_country' %}
                  <option value="{{ block.settings.country_code | default: block.settings.country_name }}">
                    {{ block.settings.country_code | default: block.settings.country_name }}
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          </div>

          <div class="delivery-input-wrapper">
            <label for="delivery_zone_zip_code" class="visually-hidden">{{ "sections.delivery-picker.labels.zip_code" }}</label>
            <input id="delivery_zone_zip_code" name="delivery_zone[zip_code]" type="text" placeholder="{{ section.settings.pc_placeholder_text | default: 'e.g. 6512 AB...' }}" required />
          </div>

          <button type="submit" class="delivery-submit-button">{{ section.settings.pc_button_text | default: "Check &rarr;" }}</button>
        </form>

        <p class="delivery-picker__error" role="alert">{{ section.settings.pc_error_text | default: "Kies een bezorgdatum om verder te gaan." }}</p>
        <div class="delivery-zone__form-feedback"></div>
      </div>

      <div class="delivery-zones {% if delivery_date == blank %} visually-hidden {% endif %}">
        {% assign max_days = section.settings.max_days_ahead | default: 21 %}
        {% for i in (2..max_days) %}
          {% assign offset_seconds = i | times: 86400 %}
          {% assign future_timestamp = "now" | date: "%s" | plus: offset_seconds %}

          {% assign weekday_name     = future_timestamp | date: '%A' %}
          {% assign weekday_key      = weekday_name | downcase %}
          {% assign weekday_t_key    = 'sections.delivery-picker.days.' | append: weekday_key %}
          {% assign date_label       = future_timestamp | date: '%e %B' %}
          {% assign machine_date     = future_timestamp | date: '%Y-%m-%d' %}

          <button
            type="button"
            class="delivery-zone visually-hidden {% if formatted_delivery_date == machine_date %} delivery-zone--active {% endif %}"
            data-delivery-date="{{ machine_date }}"
            data-delivery-day="{{ weekday_key }}"
            data-delivery-offset="{{ i }}"
          >
            <span class="delivery-zone__day">{{ weekday_t_key | t }}</span>
            <span class="delivery-zone__date">{{ date_label }}</span>
          </button>
        {% endfor %}
      </div>
    </div>
  </delivery-picker>

  <div class="delivery-picker-footer">
    <span class="footer-label">{{ section.settings.pc_footer_label | default: "We deliver to:" }}</span>
    {% for block in section.blocks %}
      {% if block.type == 'delivery_country' %}
        <span class="footer-badge" {{ block.shopify_attributes }}>
          {% if block.settings.flag_image != blank %}
            <img decoding="async" loading="lazy" src="{{ block.settings.flag_image | image_url: width: 400 }}" alt="{{ block.settings.country_code }}"  style="border-radius:2px; object-fit:cover;">
          {% endif %}
          {{ block.settings.country_name }}
        </span>
      {% endif %}
    {% endfor %}
  </div>
</div>


    </div>
  </div>


      <!-- Step 2: Days -->
<div class="mb-section">
        <div class="mb-section-header">
          <h2>{{ section.settings.step2_heading }}</h2>
          <p>{{ section.settings.step2_description }}</p>
        </div>
        <menu-variant class="mb-tiles" id="days-selector">
          {% assign default_prod = section.settings.default_product %}
          {% assign default_days_num = section.settings.default_days | plus: 0 %}

          {% if default_prod != blank %}
            {%- comment -%} Pulls 5, 6, 7 dynamically from product variants {%- endcomment -%}
            {% for variant in default_prod.variants %}
              {% assign variant_days = variant.title | plus: 0 %}
              
              {% assign is_active = false %}
              {% if section.settings.default_days != blank and variant_days == default_days_num %}
                {% assign is_active = true %}
              {% elsif section.settings.default_days == blank and forloop.first %}
                {% assign is_active = true %}
              {% endif %}

              <label class="mb-tile{% if is_active %} is-active{% endif %}" data-value="{{ variant.title | escape }}">
                <input type="radio" name="days" value="{{ variant.title | escape }}" {% if is_active %}checked{% endif %}>
                <span class="mb-tile__val">{{ variant.title }}</span>
                <span class="mb-tile__label">{{ section.settings.days_label | default: 'days' }}</span>
              </label>
            {% endfor %}
            
          {% else %}
            {%- comment -%} FALLBACK: If no product is selected, force 5, 6, 7 to show anyway {%- endcomment -%}
            <label class="mb-tile is-active" data-value="5">
              <input type="radio" name="days" value="5" checked>
              <span class="mb-tile__val">5</span>
              <span class="mb-tile__label">{{ section.settings.days_label | default: 'days' }}</span>
            </label>
            
            <label class="mb-tile" data-value="6">
              <input type="radio" name="days" value="6">
              <span class="mb-tile__val">6</span>
              <span class="mb-tile__label">{{ section.settings.days_label | default: 'days' }}</span>
            </label>
            
            <label class="mb-tile" data-value="7">
              <input type="radio" name="days" value="7">
              <span class="mb-tile__val">7</span>
              <span class="mb-tile__label">{{ section.settings.days_label | default: 'days' }}</span>
            </label>
          {% endif %}
          
        </menu-variant>
      </div>

      <!-- Step 3: People -->
      <div class="mb-section">
        <div class="mb-section-header">
          <h2>{{ section.settings.step3_heading }}</h2>
          <p>{{ section.settings.step3_description }}</p>
        </div>
        <menu-quantity class="mb-tiles" id="people-selector">
          <label class="mb-tile is-active" data-value="1">
            <input type="radio" name="people" value="1" checked>
            <span class="mb-tile__val">1</span>
            <span class="mb-tile__label">{{ section.settings.person_label | default: 'person' }}</span>
          </label>
          <label class="mb-tile" data-value="2">
            <input type="radio" name="people" value="2">
            <span class="mb-tile__discount">{{ section.settings.discount_badge_people_2 | default: '-15% korting' }}</span>
            <span class="mb-tile__val">2</span>
            <span class="mb-tile__label">{{ section.settings.people_label | default: 'people' }}</span>
          </label>
          <label class="mb-tile" data-value="3">
            <input type="radio" name="people" value="3">
            <span class="mb-tile__discount">{{ section.settings.discount_badge_people_3 | default: '-20% korting' }}</span>
            <span class="mb-tile__val">3</span>
            <span class="mb-tile__label">{{ section.settings.people_label | default: 'people' }}</span>
          </label>
          <label class="mb-tile" data-value="4">
            <input type="radio" name="people" value="4">
            <span class="mb-tile__discount">{{ section.settings.discount_badge_people_4 | default: '-30% korting' }}</span>
            <span class="mb-tile__val">4</span>
            <span class="mb-tile__label">{{ section.settings.people_label | default: 'people' }}</span>
          </label>
        </menu-quantity>
      </div>

      <!-- Step 4: Subscription Length -->
<div class="mb-section">
        <div class="mb-section-header">
          <h2>{{ section.settings.step4_heading }}</h2>
          <p>{{ section.settings.step4_description }}</p>
        </div>
        <menu-duration class="mb-subs" id="duration-selector" style="margin-top: 16px;">
          
          {%- comment -%} Create a custom variable to guarantee the first plan is active {%- endcomment -%}
          {% assign is_first_plan = true %}
          
          {%- for block in section.blocks -%}
            {%- if block.type == 'subscription_plan' -%}
              {% if block.settings.weeks == 12 or block.settings.weeks == 24 %}
<a href="{{ section.settings.chefs_menu_url | default: '/pages/chefs-menu' }}?duration={{ block.settings.weeks }}&people=1&days=5" class="mb-sub-card menu-duration__link{% if is_first_plan %} is-active{% endif %}" data-chefs-duration="{{ block.settings.weeks }} weken" {{ block.shopify_attributes }} style="display:block; text-decoration:none;">
{% else %}
<label class="mb-sub-card{% if is_first_plan %} is-active{% endif %}" data-value="{{ block.settings.weeks }}" data-plan-id="{{ block.settings.selling_plan_id }}" {{ block.shopify_attributes }}>
<input type="radio" name="duration" value="{{ block.settings.weeks }}" data-plan-id="{{ block.settings.selling_plan_id }}" {% if is_first_plan %}checked{% endif %} class="visually-hidden">
{% endif %}
                <div class="mb-sub-content">
                  <div class="mb-sub-card__header">
                    <div class="mb-sub-card__header-left">
                      <h3 class="mb-sub-card__title">{{ block.settings.title }}</h3>
                      {% if block.settings.description != blank %}
                        <div class="mb-sub-card__desc">{{ block.settings.description }}</div>
                      {% endif %}
                    </div>
                    <div class="mb-sub-card__header-right">
                      {% if block.settings.badge != blank and block.settings.badge != 'Standard price' %}
                        <span class="mb-sub-card__badge">{{ block.settings.badge }}</span>
                      {% endif %}
                      {% if block.settings.price_calc != blank %}
                        <span class="mb-sub-card__price-calc">{{ block.settings.price_calc }}</span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="mb-sub-radio"></div>
                  
                  {%- comment -%} Chef's Box vs Pick & Mix Switch (only shown for subscription plans > 1 week) {%- endcomment -%}
                  {% assign weeks_num = block.settings.weeks | plus: 0 %}
                  {% if weeks_num == 12 or weeks_num == 24 %}
                    <div class="mb-sub-card__extra-buttons">
                      <button type="button" class="btn-chef is-selected">{{ section.settings.label_chefs_box | default: "Meal boxes" }}</button>
                      <a href="{{ section.settings.pick_and_mix_url | default: 'https://yasemin.nl/products/pick-mix-menu' }}" class="btn-pick">
                        {{ section.settings.label_pick_and_mix | default: "Pick&Mix" }}
                      </a>
                    </div>
                  {% endif %}
                </div>
              {% if block.settings.weeks == 12 or block.settings.weeks == 24 %}
</a>
{% else %}
</label>
{% endif %}
              
              {%- comment -%} Turn off the active state for the rest of the loops {%- endcomment -%}
              {% assign is_first_plan = false %}
            {%- endif -%}
          {%- endfor -%}
          
        </menu-duration>
        <div class="mb-plan-info">
          {{ section.settings.plan_info_text }}
        </div>
      </div>

      <!-- Step 5: Products -->
      <div class="mb-section" id="meal-boxes-section">
        <div class="mb-section-header">
          <h2>{{ section.settings.step5_heading }}</h2>
          <p>{{ section.settings.step5_description }}</p>
        </div>
        
        <div class="mb-filters-title">{{ section.settings.label_dietary_preferences | default: "DIETARY PREFERENCES" }}</div>
        <div class="mb-filters">
          {%- for block in section.blocks -%}
            {%- if block.type == 'dietary_filter' -%}
              <span class="mb-filter-tag {{ block.settings.filter_style }}" {{ block.shopify_attributes }}>{{ block.settings.filter_label }}</span>
            {%- endif -%}
          {%- endfor -%}
        </div>



        {%- for i in (1..4) -%}
          <weekly-menu-choice class="mb-week-wrapper" week="{{ i }}" maximum-quantity="1" days="5" quantity="1" default-product-id="{{ section.settings.default_product.id }}">
            
            <weekly-menu-choice-error class="visually-hidden mb-week-error" style="color:red; font-size:12px; margin-bottom: 8px;">
          <p>{{ "blocks.weekly-menu-choices.error" | t: week: i }}</p>
        </weekly-menu-choice-error>
        <div class="mb-week-header">
               <h3 class="mb-week-title">{{ section.settings.label_week_prefix | default: 'Week' }} {{ i }}</h3>
               <weekly-menu-choice-progress class="mb-week-badge-status" data-count-template="%quantity% van %max% gerechten"></weekly-menu-choice-progress>
            </div>

            <div class="mb-grid mb-week-grid">
              {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
                {%- for product in section.settings.collection.products -%}
                  <div class="mb-product weekly-menu-choice" data-product-id="{{ product.id }}">
                  <div class="mb-product-cc">

                    <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="mb-product__img" width="300" height="300" loading="lazy" decoding="async">
                    <div class="mb-product__content">
                      <h3 class="mb-product__title">{{ product.title }}</h3>
                      {% comment %} <p class="mb-product__desc">{{ product.description | strip_html | truncate: 60 }}</p> {% endcomment %}
                      
                      {% comment %} <div class="mb-product__tags">
                        {%- for tag in product.tags limit: 3 -%}
                          {%- assign tag_class = "tag-" | append: tag | handle -%}
                          <span class="mb-product__tag {{ tag_class }}">{{ tag }}</span>
                        {%- endfor -%}
                      </div> {% endcomment %}

                      <div class="mb-product__footer">
                        <span class="mb-product__price weekly-menu-choice__product-price" data-product-id="{{ product.id }}">{{ product.price | money }}</span>
                        <weekly-menu-choice-quantity class="mb-qty weekly-menu-choice__input-group">
                          <button type="button" class="mb-qty__minus weekly-menu-choice__control--decrease">-</button>
                          {%- assign is_default = false -%}
                          {%- if section.settings.default_product != blank and product.id == section.settings.default_product.id -%}
                            {%- assign is_default = true -%}
                          {%- endif -%}
                          <input type="number" step="1" min="0" max="4" class="mb-qty__input weekly-menu-choice__input" name="weekly_menu[week_{{ i }}][{{ product.id }}]" value="{% if is_default %}1{% else %}0{% endif %}" readonly aria-label="Quantity">
                          <button type="button" class="mb-qty__plus weekly-menu-choice__control--increase">+</button>
                        </weekly-menu-choice-quantity>
                      </div>
                    </div>
                  </div>
                    <weekly-menu-dishes product-id="{{ product.id }}"><button type="button" class="mb-product__link weekly-menu-dishes__show" onclick="document.getElementById('modal-{{ product.id }}-{{ i }}').showModal()" data-variant-id="{{ product.variants.first.id }}">{{ section.settings.view_dishes_text }}</button></weekly-menu-dishes>
                    <!-- View Dishes Modal -->
                    <dialog id="modal-{{ product.id }}-{{ i }}" class="mb-modal">
                      <div class="mb-modal__header">
                        <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}" class="mb-modal__hero" width="800" height="400" loading="lazy" decoding="async">
                        <div class="mb-modal__header-overlay">
                          <h3 class="mb-modal__title">{{ product.title }}</h3>
                          <p class="mb-modal__subtitle">{{ product.description | strip_html | truncate: 100 }}</p>
                        </div>
                        <button type="button" class="mb-modal__close" onclick="this.closest('dialog').close()" aria-label="Close">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
                        </button>
                      </div>
                      
                      <div class="mb-modal__body">
                        {% comment %} <div class="mb-modal__box-tags">
                          {%- for tag in product.tags limit: 3 -%}
                            {%- assign tag_class = "tag-" | append: tag | handle -%}
                            <span class="mb-modal__box-tag {{ tag_class }}">{{ tag }}</span>
                          {%- endfor -%}
                        </div> {% endcomment %}

                        <div class="mb-modal__dishes-title">{{ section.settings.modal_dishes_title | default: "THIS WEEK'S DISHES" }}</div>
                        
                        <div class="mb-modal__variant-dishes-container" data-product-id="{{ product.id }}">
                          {%- for variant in product.variants -%}
                            <div class="mb-modal__variant-dishes" data-variant-title="{{ variant.title | escape }}" style="display: none;">
                              {%- assign components = variant.metafields.custom.variant_components.value | compact -%}
                              {%- if components != blank -%}
                                {%- assign all_types = components | map: 'type' | uniq -%}
                                {%- for component_type in all_types -%}
                                  {%- assign typed_components = components | where: 'type', component_type -%}
                                  {%- if component_type != blank -%}
