class MenuDuration extends HTMLElement {
  constructor() {
    const element = super();
    this.element = element;

    this.inputs = this.element.querySelectorAll("input[type=\"radio\"]");
    this.links = Array.from(this.element.querySelectorAll(".menu-duration__link"));
    this.boundUpdateLinks = null;
  }

  connectedCallback() {
    this.inputs.forEach(inputEl => {
      inputEl.addEventListener("change", this.#onChange.bind(this));
    });

    if (this.links.length > 0) {
      this.#updateLinks();

      const parent = this.element.closest("weekly-menu");
      if (parent) {
        this.boundUpdateLinks = this.#updateLinks.bind(this);
        parent.addEventListener("change", this.boundUpdateLinks);
      }
    }
  }

  disconnectedCallback() {
    this.inputs.forEach(inputEl => {
      inputEl.removeEventListener("change", this.#onChange);
    });

    if (this.boundUpdateLinks) {
      const parent = this.element.closest("weekly-menu");
      if (parent) {
        parent.removeEventListener("change", this.boundUpdateLinks);
      }
    }
  }

  #onChange(event) {
    const value = event.currentTarget.value;
    this.element.setAttribute("value", value);
    this.element.dispatchEvent(new CustomEvent("change", { detail: { value } }));
  }

  #updateLinks() {
    const parent = this.element.closest("weekly-menu");
    const people = parent ? parent.getAttribute("people") : "1";
    const days = parent ? parent.getAttribute("days") : "5";

    this.links.forEach(link => {
      const params = new URLSearchParams({
        duration: link.dataset.chefsDuration,
        people,
        days
      });
      link.href = `${link.dataset.baseUrl}?${params}`;
    });
  }

  get value() {
    return this.element.getAttribute("value");
  }
}

class WeeklyMenu extends HTMLElement {
  constructor() {
    const element = super();
    this.element = element;

    this.submitEl = this.element.querySelector(".weekly-menu__submit");
    this.weeklyDuration = this.element.querySelector("menu-duration");
    this.weeklyVariant = this.element.querySelector("menu-variant");
    this.weeklyQuantity = this.element.querySelector("menu-quantity");
  }

  connectedCallback() {
    if (this.weeklyDuration) {
      this.weeklyDuration.addEventListener("change", this.#onDurationChange.bind(this));
    }
    if (this.weeklyVariant) {
      this.weeklyVariant.addEventListener("change", this.#onVariantChange.bind(this));
    }
    if (this.weeklyQuantity) {
      this.weeklyQuantity.addEventListener("change", this.#onPeopleChange.bind(this));
    }
    this.element.addEventListener("change", this.#onChange.bind(this));
    if (this.submitEl) this.submitEl.addEventListener("click", this.#onSubmit.bind(this));
    
    // Initialize
    setTimeout(() => {
        this.#onChange();
    }, 200);
  }

  disconnectedCallback() {
    if (this.weeklyDuration) {
      this.weeklyDuration.removeEventListener("change", this.#onDurationChange);
    }
    if (this.weeklyVariant) {
      this.weeklyVariant.removeEventListener("change", this.#onVariantChange);
    }
    if (this.weeklyQuantity) {
      this.weeklyQuantity.removeEventListener("change", this.#onPeopleChange);
    }
    this.element.removeEventListener("change", this.#onChange);
    if (this.submitEl) this.submitEl.removeEventListener("click", this.#onSubmit);
  }

  #addToCart() {
    const items = this.visibleWeeklyMenuChoices.flatMap(weeklyMenuChoice => {
      return [...weeklyMenuChoice.querySelectorAll(".weekly-menu-choice")].map(choice => {
        const input = choice.querySelector("input[type=\"number\"]");
        const quantity = parseInt(input.value);

        if (quantity > 0) {
          const product = this.products.find(product => product.id === parseInt(choice.dataset.productId));
          const productVariant = product.variants.find(variant => parseInt(variant.title, 10) === this.days);

          return { id: productVariant.id, properties: { "Week": weeklyMenuChoice.week }, quantity };
        }
      }).filter(lineItem => !!lineItem);
    });

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ items })
    }).then((response) => {
      if (!response.ok) {
        throw new Error(`HTTP error! Status: ${response.status}`);
      }
      return response.json();
    })
    .then((data) => {
      window.location.href = window.Shopify.routes.root + 'checkout';
    });
  }

  #onDurationChange(event) {
    this.duration = event.detail.value;

    this.weeklyMenuChoices.forEach(weeklyMenuChoice => {
      if (weeklyMenuChoice.week <= this.duration) {
        weeklyMenuChoice.show();
      } else {
        weeklyMenuChoice.hide();
      }
    });

    this.#onChange(event);
  }

  #onPeopleChange(event) {
    this.people = event.currentTarget.value;

    this.weeklyMenuChoices.forEach(weeklyMenuChoice => {
      weeklyMenuChoice.setAttribute("maximum-quantity", this.people);
    });

    this.#onChange(event);
  }

  #onVariantChange(event) {
    this.days = event.currentTarget.value;

    this.weeklyMenuChoices.forEach(weeklyMenuChoice => {
      weeklyMenuChoice.setAttribute("days", this.days);
    });

    this.#onChange(event);
  }

  #onChange(event) {
    // Update summary UI elements
    const durationEl = this.element.querySelector(".weekly-menu-summary__cart-line--duration .weekly-menu-summary__cart-line__value");
    if(durationEl) durationEl.textContent = this.duration + " Weken";
    
    const daysEl = this.element.querySelector(".weekly-menu-summary__cart-line--days .weekly-menu-summary__cart-line__value");
    if(daysEl) daysEl.textContent = this.days;
    
    const peopleEl = this.element.querySelector(".weekly-menu-summary__cart-line--people .weekly-menu-summary__cart-line__value");
    if(peopleEl) peopleEl.textContent = this.people;

    const discountAmountEl = this.element.querySelector(".weekly-menu-summary__discount-amount");
    if (discountAmountEl) {
        discountAmountEl.textContent = this.subTotal;
        discountAmountEl.style.display = this.totalDiscountInCents === 0 ? "none" : "block";
    }

    const priceAmountEl = this.element.querySelector(".weekly-menu-summary__price-amount");
    if(priceAmountEl) priceAmountEl.textContent = this.totalPrice;

    const peopleDiscValEl = this.element.querySelector(".weekly-menu-summary__cart-line--people-discount .weekly-menu-summary__cart-line__value");
    if(peopleDiscValEl) peopleDiscValEl.textContent = this.peopleDiscount;
    const peopleDiscRowEl = this.element.querySelector(".weekly-menu-summary__cart-line--people-discount");
    if (peopleDiscRowEl) peopleDiscRowEl.style.display = this.peopleDiscountInCents === 0 ? "none" : "flex";

    const durDiscValEl = this.element.querySelector(".weekly-menu-summary__cart-line--duration-discount .weekly-menu-summary__cart-line__value");
    if(durDiscValEl) durDiscValEl.textContent = this.durationDiscount;
    const durDiscRowEl = this.element.querySelector(".weekly-menu-summary__cart-line--duration-discount");
    if(durDiscRowEl) durDiscRowEl.style.display = this.durationDiscountInCents === 0 ? "none" : "flex";
  }

  #onSubmit(event) {
    event.preventDefault();
    this.element.setAttribute("loading", true);

    const deliveryPicker = this.element.querySelector('delivery-picker');
    if (deliveryPicker) {
      const deliveryDate = deliveryPicker.getAttribute('delivery-date');
      const today = new Date().setHours(0, 0, 0, 0);
      const hasValidDelivery = !!deliveryDate && new Date(deliveryDate) >= today;

      if (!hasValidDelivery) {
        deliveryPicker.setAttribute('delivery-error', '');
        deliveryPicker.scrollIntoView({ behavior: 'smooth', block: 'center' });
        this.element.setAttribute("loading", false);
        return;
      }
    }

    const isValid = this.#validate();
    if (isValid) this.#addToCart();

    this.element.setAttribute("loading", false);
  }

  #validate() {
    let isValid = true;
    this.visibleWeeklyMenuChoices.forEach(choice => {
      if (!choice.isValid) {
        choice.error.show();
        isValid = false;
      } else {
        choice.error.hide();
      }
    });
    return isValid;
  }

  get days() {
    return parseInt(this.element.getAttribute("days"), 10) || 5;
  }

  set days(value) {
    this.element.setAttribute("days", value);
  }

  get duration() {
    return parseInt(this.element.getAttribute("duration")) || 1;
  }

  set duration(value) {
    this.element.setAttribute("duration", value);
  }

  get durationDiscount() {
    return `-${formatMoney(this.durationDiscountInCents)}`;
  }

  get durationDiscountInCents() {
    if (this.duration > 1) return this.subTotalInCents * 0.07;
    return 0;
  }

  get lineItems() {
    return this.visibleWeeklyMenuChoices.flatMap(weeklyMenuChoice => {
      const week = weeklyMenuChoice.week;

      return [...weeklyMenuChoice.querySelectorAll(".weekly-menu-choice")].map(choice => {
        const input = choice.querySelector("input[type=\"number\"]");
        const quantity = parseInt(input.value);

        if (quantity > 0) {
          const product = this.products.find(product => product.id === parseInt(choice.dataset.productId));
          const productVariant = product.variants.find(variant => parseInt(variant.title, 10) === this.days);

          return { product, productVariant, week, quantity };
        }
      }).filter(lineItem => !!lineItem);
    });
  }

  get people() {
    return parseInt(this.element.getAttribute("people"), 10) || 1;
  }

  set people(value) {
    this.element.setAttribute("people", value);
  }

  get peopleDiscount() {
    return `-${formatMoney(this.peopleDiscountInCents)}`;
  }

  get peopleDiscountInCents() {
    if (this.people === 2) {
      return this.subTotalInCents * 0.15;
    } else if (this.people === 3) {
      return this.subTotalInCents * 0.2;
    } else if (this.people === 4) {
      return this.subTotalInCents * 0.3;
    } else {
      return 0;
    }
  }

  get products() {
    const dataEl = this.element.querySelector("#weekly-menus-data");
    if(!dataEl) return [];
    return JSON.parse(dataEl.textContent);
  }

  get subTotal() {
    return formatMoney(this.subTotalInCents);
  }

  get subTotalInCents() {
    return this.lineItems.reduce((subTotal, cartLine) => subTotal + ((cartLine.productVariant?.price || 0) * cartLine.quantity), 0);
  }

  get totalDiscountInCents() {
    return this.peopleDiscountInCents + this.durationDiscountInCents;
  }

  get totalPriceInCents() {
    return this.subTotalInCents - this.totalDiscountInCents;
  }

  get totalPrice() {
    return formatMoney(this.totalPriceInCents);
  }

  get visibleWeeklyMenuChoices() {
    return this.weeklyMenuChoices.filter(choice => choice.isVisible);
  }

  get weeklyMenuChoices() {
    return [...this.element.querySelectorAll("weekly-menu-choice")];
  }
}

// Format money utility if not available
function formatMoney(cents, format) {
  if (typeof cents == 'string') { cents = cents.replace('.', ''); }
  var value = '';
  var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
  var formatString = (format || window.Shopify?.money_format || '€{{amount_with_comma_separator}}');

  function defaultOption(opt, def) { return (typeof opt == 'undefined' ? def : opt); }

  function formatWithDelimiters(number, precision, thousands, decimal) {
    precision = defaultOption(precision, 2);
    thousands = defaultOption(thousands, '.');
    decimal   = defaultOption(decimal, ',');

    if (isNaN(number) || number == null) { return 0; }

    number = (number/100.0).toFixed(precision);

    var parts   = number.split('.'),
        dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands),
        cents   = parts[1] ? (decimal + parts[1]) : '';

    return dollars + cents;
  }

  switch(formatString.match(placeholderRegex)[1]) {
    case 'amount':
      value = formatWithDelimiters(cents, 2);
      break;
    case 'amount_no_decimals':
      value = formatWithDelimiters(cents, 0);
      break;
    case 'amount_with_comma_separator':
      value = formatWithDelimiters(cents, 2, '.', ',');
      break;
    case 'amount_no_decimals_with_comma_separator':
      value = formatWithDelimiters(cents, 0, '.', ',');
      break;
  }

  return formatString.replace(placeholderRegex, value);
}

if (!customElements.get('weekly-menu-choice')) {
    customElements.define('weekly-menu-choice', WeeklyMenuChoice);
    customElements.define('weekly-menu-choice-quantity', WeeklyMenuChoiceQuantity);
    customElements.define('weekly-menu-choice-error', WeeklyMenuChoiceError);
    customElements.define('weekly-menu-choice-progress', WeeklyMenuChoiceProgress);
    customElements.define('weekly-menu-dishes', WeeklyMenuDishes);
    customElements.define('menu-quantity', MenuQuantity);
    customElements.define('menu-variant', MenuVariant);
    customElements.define('menu-duration', MenuDuration);
    customElements.define('weekly-menu', WeeklyMenu);
}
