{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .mission-split__grid {
    align-items: center;
    row-gap: 4rem;
  }

  @media screen and (min-width: 750px) {
    .mission-split__grid {
      column-gap: 6rem;
    }
  }

  @media screen and (min-width: 990px) {
    .mission-split__grid {
      column-gap: 8rem;
    }
  }

  /* Left Column Styles */
  .mission-split__content {
    display: flex;
    flex-direction: column;
  }

  .mission-split__caption {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888888;
  }

  .mission-split__heading {
    color: #2c2c2c;
  }

  .mission-split__heading em {
    font-style: normal;
    color: #6046b6; /* Highlight Color */
  }

  .mission-split__text {
    font-size: 1.5rem;
    line-height: 1.7;
    color: #666666;
    margin-bottom: 2rem;
  }

  .mission-split__text:last-child {
    margin-bottom: 0;
  }

  .mission-split__text p {
    margin: 0 0 2rem 0;
  }
  .mission-split__text p:last-child {
    margin-bottom: 0;
  }

  /* Right Column (Quote Card) */
  .mission-split__quote-wrapper {
    width: 100%;
  }

  .mission-quote-card {
    background-color: #f4f0fa;
    border-radius: 12px;
    border-left: 6px solid #6046b6;
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 750px) {
    .mission-quote-card {
      padding: 4rem;
    }
  }

  .mission-quote-card__text {
    font-size: clamp(2rem, 2.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.3;
    color: #29255b;
    margin: 0 0 2rem 0;
  }

  .mission-quote-card__author {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888888;
    margin: 0 0 2.5rem 0;
  }

  .mission-quote-card__divider {
    width: 100%;
    height: 1px;
    background-color: rgba(96, 70, 182, 0.15);
    margin: 0 0 2.5rem 0;
  }

  .mission-quote-card__subtext {
    font-size: 1.3rem;
    line-height: 1.6;
    color: #666666;
    margin: 0;
  }
{%- endstyle -%}

<div class="mission-split section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="grid grid--1-col grid--2-col-tablet mission-split__grid">
      
      {%- comment -%} Left Column (Content) {%- endcomment -%}
      <div class="grid__item mission-split__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            
            {%- when 'caption' -%}
              <div class="mission-split__caption" {{ block.shopify_attributes }}>
                {{ block.settings.caption }}
              </div>

            {%- when 'heading' -%}
              <h2 class="mission-split__heading h2" {{ block.shopify_attributes }}>
                {{ block.settings.heading }}
              </h2>

            {%- when 'text' -%}
              <div class="mission-split__text" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Right Column (Quote Card) {%- endcomment -%}
      <div class="grid__item mission-split__quote-wrapper">
        {%- assign quote_block = section.blocks | where: "type", "quote_card" | first -%}
        
        {%- if quote_block -%}
          <div class="mission-quote-card" {{ quote_block.shopify_attributes }}>
            {%- if quote_block.settings.quote != blank -%}
              <h3 class="mission-quote-card__text">{{ quote_block.settings.quote }}</h3>
            {%- endif -%}
            
            {%- if quote_block.settings.author != blank -%}
              <p class="mission-quote-card__author">{{ quote_block.settings.author }}</p>
            {%- endif -%}
            
            <div class="mission-quote-card__divider"></div>
            
            {%- if quote_block.settings.subtext != blank -%}
              <p class="mission-quote-card__subtext">{{ quote_block.settings.subtext }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Mission Split",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "caption",
      "name": "Caption",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "caption",
          "default": "WHY WE EXIST",
          "label": "Caption Text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "heading",
          "default": "The Dream of Turkish Cuisine —<br><em>and the Reality of Every Day</em>",
          "label": "Heading",
          "info": "Wrap text in <em> tags to apply the purple highlight color."
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Paragraphs",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Who doesn't dream of it? Those flavorful dishes from Turkish cuisine that have been simmering for hours with patience and love. Dishes that tell a story, rich in flavor and tradition. We would love to bring them to the table every day.</p><p>But let's be honest: our busy, hectic lives don't always allow that. The time and energy to spend hours in the kitchen are often missing.</p><p>Yasemin was born from this exact desire — the wish to make real Turkish home cooking accessible to everyone. We believe that no one should miss the warmth and richness of a homemade meal, no matter how busy they are.</p>",
          "label": "Content"
        }
      ]
    },
    {
      "type": "quote_card",
      "name": "Quote Card (Right Side)",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "default": "\"Our mission is simple: we take the time so you can enjoy it.\"",
          "label": "Main Quote"
        },
        {
          "type": "text",
          "id": "author",
          "default": "— YASEMIN, FOUNDER",
          "label": "Author"
        },
        {
          "type": "textarea",
          "id": "subtext",
          "default": "We dive into the kitchen with love and take over the hours-long preparation and patient cooking process for you — so that only the best part remains for you.",
          "label": "Subtext Below Divider"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mission Split",
      "blocks": [
        { "type": "caption" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "quote_card" }
      ]
    }
  ]
}
{% endschema %}