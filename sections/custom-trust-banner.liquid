{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    background-color: {{ section.settings.background_color }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-trust-banner {
    display: block;
    overflow-x: hidden;
  }

  @media screen and (min-width: 750px) {
    .custom-trust-banner {
      display: flex;
      justify-content: center;
      align-items: center;
    }
  }

  /* MOBILE SLIDER STYLES (Default) */
  .custom-trust-banner__list {
    display: flex;
    flex-wrap: nowrap; /* Forces items into a single line */
    justify-content: flex-start;
    align-items: center;
    gap: 2rem;
    margin: 0 -1.5rem !important;
    padding: 0 1.5rem !important; /* Gives space at the edges when scrolling */
    list-style: none;
    overflow-x: auto; /* Enables horizontal scrolling */
    -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
    scroll-snap-type: x mandatory; /* Optional: adds a snap effect */
    scroll-padding-left: 1.5rem;
    
    /* Hide scrollbar for a clean look */
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none;  /* IE and Edge */
  }

  .custom-trust-banner__list::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }

  /* DESKTOP STYLES (768px and up) */
  @media screen and (min-width: 768px) {
    .custom-trust-banner__list {
      flex-wrap: wrap; /* Allow wrapping on desktop */
      justify-content: center;
      padding: 0 !important;
      margin: 0 !important;
      gap: 1.5rem 8.5rem;
      overflow-x: visible; /* Remove scrolling on desktop */
    }
  }

  .custom-trust-banner__item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: {{ section.settings.text_color }};
    flex-shrink: 0; /* CRITICAL: Prevents items from squishing on mobile */
    scroll-snap-align: start; /* Snaps item to the start of the scroll container */
  }

  .custom-trust-banner__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: {{ section.settings.icon_bg_color }};
    flex-shrink: 0;
  }

  .custom-trust-banner__icon svg {
    width: 14px;
    height: 14px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .custom-trust-banner__text {
    font-size: 1.3rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
    white-space: nowrap; /* Prevents text from breaking onto multiple lines */
  }
{%- endstyle -%}

<div class="custom-trust-banner section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.blocks.size > 0 -%}
      <ul class="custom-trust-banner__list">
        {%- for block in section.blocks -%}
          <li class="custom-trust-banner__item" {{ block.shopify_attributes }}>
            <div class="custom-trust-banner__icon">
              {%- if block.settings.custom_svg != blank -%}
                {{ block.settings.custom_svg }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag }}
              {%- endif -%}
            </div>
            
            {%- if block.settings.text != blank -%}
              <p class="custom-trust-banner__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#29255b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Icon Color",
      "default": "#d0cde1"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon Background Color",
      "default": "#3b3671"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 6,
      "settings": [
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Custom SVG Code",
