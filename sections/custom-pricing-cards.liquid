        },
        {
          "type": "pricing_card",
          "settings": {
            "bg_color": "#282054",
            "text_color": "#ffffff",
            "border_color": "#282054",
            "divider_color": "#3B326D",
            "eyebrow": "SUBSCRIPTION",
            "title": "Weekly Subscription",
            "description": "Regular & effortless",
            "price": "€7.00",
            "price_color": "#FF007F",
            "price_suffix": "per portion · 10% off after 4 weeks",
            "show_badge": true,
            "badge_text": "Best Value",
            "feature_1": "Choice from 4 curated menu concepts",
            "feature_2": "Fixed delivery every week",
            "feature_3": "10% discount applied after 4 weeks",
            "button_bg_color": "#5A4BBA"
          }
        }
      ]
    }
  ]
}
{% endschema %}