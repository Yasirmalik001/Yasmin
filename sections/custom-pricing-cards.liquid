            "price_suffix": "per portion",
            "show_badge": false,
            "feature_1": "Free choice from all 60+ dishes",
            "feature_2": "No fixed delivery schedule",
            "feature_3": "Order when you want, as often as you want",
            "button_bg_color": "#4A306D"
