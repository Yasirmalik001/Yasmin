{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .custom-info-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    overflow: hidden;
  }

  .custom-info-bar__list {
    display: flex;
    flex-wrap: nowrap;
    margin: 0;
    padding: 0;
    list-style: none;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE and Edge */
  }
  
  /* Hide scrollbar for Chrome, Safari and Opera */
  .custom-info-bar__list::-webkit-scrollbar {
    display: none;
  }

  .custom-info-bar__item {
    scroll-snap-align: start;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .custom-info-bar__value {
    color: {{ section.settings.value_color }};
    font-family: Barlow;
    font-weight: 900;
    font-style: Black;
    font-size: 22px;
    leading-trim: NONE;
    line-height: 100%;
    letter-spacing: 0%;
    white-space: nowrap;
  }

  .custom-info-bar__label {
    color: {{ section.settings.label_color }};
    font-size: clamp(1rem, 2vw, 1.2rem);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    white-space: nowrap;
  }

  @media screen and (max-width: 749px) {
    .custom-info-bar-{{ section.id }} .page-width {
      padding-left: 0;
      padding-right: 0;
      max-width: 100%;
    }

    .custom-info-bar__list {
      padding-left: 2rem;
      padding-right: 2rem;
      gap: 8.5rem;
      scroll-padding-left: 2rem;
    }

    .custom-info-bar__item {
      flex: 0 0 auto;
    }
  }

  @media screen and (min-width: 750px) {
    .custom-info-bar__list {
      justify-content: space-between;
      overflow-x: visible;
    }
    
    .custom-info-bar__item {
      flex: 1 1 auto;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_nutrition = false
  if template.name == 'product' and product != blank
    if product.metafields.custom.kcal.value != blank or product.metafields.custom.calories.value != blank
      assign has_nutrition = true
    endif
  endif

  if request.design_mode
    assign has_nutrition = true
  endif
-%}

{%- if has_nutrition -%}
  {%- liquid
    assign raw_kcal = product.metafields.custom.kcal.value | default: product.metafields.custom.calories.value
    if raw_kcal == blank and request.design_mode
      assign raw_kcal = '420 kcal'
    endif

    assign raw_protein = product.metafields.custom.protein.value
    if raw_protein == blank and request.design_mode
      assign raw_protein = '28g'
    endif

    assign raw_carbs = product.metafields.custom.carbohydrate.value | default: product.metafields.custom.carbs.value
    if raw_carbs == blank and request.design_mode
      assign raw_carbs = '32g'
    endif

    assign raw_fat = product.metafields.custom.fat.value
    if raw_fat == blank and request.design_mode
      assign raw_fat = '18g'
    endif

    # Normalize values (append units if not present)
    assign kcal_str = raw_kcal | downcase
    if kcal_str contains 'kcal'
      assign display_kcal = raw_kcal
    else
      assign display_kcal = raw_kcal | append: ' kcal'
    endif

    assign protein_str = raw_protein | downcase
    if protein_str contains 'g'
      assign display_protein = raw_protein
    else
      assign display_protein = raw_protein | append: 'g'
    endif

    assign carbs_str = raw_carbs | downcase
    if carbs_str contains 'g'
      assign display_carbs = raw_carbs
    else
      assign display_carbs = raw_carbs | append: 'g'
    endif

    assign fat_str = raw_fat | downcase
    if fat_str contains 'g'
      assign display_fat = raw_fat
    else
      assign display_fat = raw_fat | append: 'g'
    endif

    # Localization mapping
    assign iso = request.locale.iso_code

    # Calories Label
    assign label_kcal = 'CALORIES'
    if iso == 'nl'
      assign label_kcal = 'CALORIEËN'
    elsif iso == 'fr'
      assign label_kcal = 'CALORIES'
    elsif iso == 'tr'
      assign label_kcal = 'KALORİ'
    elsif iso == 'de'
      assign label_kcal = 'KALORIEN'
    endif

    # Protein Label
    assign label_protein = 'PROTEIN'
    if iso == 'nl'
      assign label_protein = 'EIWITTEN'
    elsif iso == 'fr'
      assign label_protein = 'PROTÉINES'
    elsif iso == 'tr'
      assign label_protein = 'PROTEİN'
    elsif iso == 'de'
      assign label_protein = 'EIWEISS'
    endif

    # Carbs Label
    assign label_carbs = 'CARBS'
    if iso == 'nl'
      assign label_carbs = 'KOOLHYDRATEN'
    elsif iso == 'fr'
      assign label_carbs = 'GLUCIDES'
    elsif iso == 'tr'
      assign label_carbs = 'KARBONHİDRAT'
    elsif iso == 'de'
      assign label_carbs = 'KOHLENHYDRATE'
    endif

    # Fat Label
    assign label_fat = 'FAT'
    if iso == 'nl'
      assign label_fat = 'VETTEN'
    elsif iso == 'fr'
      assign label_fat = 'LIPIDES'
    elsif iso == 'tr'
      assign label_fat = 'YAĞ'
    elsif iso == 'de'
      assign label_fat = 'FETT'
    endif

    # Servings/Portions
    assign val_portion = '1 person'
    assign label_portion = 'PORTIONS'
    if iso == 'nl'
      assign val_portion = '1 persoon'
      assign label_portion = 'PORTIE'
    elsif iso == 'fr'
      assign val_portion = '1 personne'
      assign label_portion = 'PORTIONS'
    elsif iso == 'tr'
      assign val_portion = '1 kişilik'
      assign label_portion = 'PORSİYON'
    elsif iso == 'de'
      assign val_portion = '1 Person'
      assign label_portion = 'PORTION'
    endif

    # Prep time
    assign val_prep = '5 min'
    assign label_prep = 'PREP TIME'
    if iso == 'nl'
      assign val_prep = '5 min'
      assign label_prep = 'OPWARMTIJD'
    elsif iso == 'fr'
      assign val_prep = '5 min'
      assign label_prep = 'TEMPS DE PRÉPARATION'
    elsif iso == 'tr'
      assign val_prep = '5 dk'
      assign label_prep = 'HAZIRLANIŞ SÜRESİ'
    elsif iso == 'de'
      assign val_prep = '5 Min.'
      assign label_prep = 'ZUBEREITUNGSZEIT'
    endif

    # Frozen status
    assign val_frozen = 'Never'
    assign label_frozen = 'NEVER FROZEN'
    if iso == 'nl'
      assign val_frozen = 'Nooit'
      assign label_frozen = 'NOOIT INGEVROREN'
    elsif iso == 'fr'
      assign val_frozen = 'Jamais'
      assign label_frozen = 'CONGELÉ'
    elsif iso == 'tr'
      assign val_frozen = 'Asla'
      assign label_frozen = 'DONDURULMAMIŞ'
    elsif iso == 'de'
      assign val_frozen = 'Nie'
      assign label_frozen = 'NIE GEFROREN'
    endif
  -%}

  <div class="custom-info-bar-{{ section.id }} section-{{ section.id }}-padding">
    <div class="page-width">
      <ul class="custom-info-bar__list" role="list">
        {%- if raw_kcal != blank -%}
          <li class="custom-info-bar__item">
            <div class="custom-info-bar__content center">
              <div class="custom-info-bar__value">{{ display_kcal }}</div>
              <div class="custom-info-bar__label">{{ label_kcal }}</div>
            </div>
          </li>
        {%- endif -%}
        {%- if raw_protein != blank -%}
          <li class="custom-info-bar__item">
            <div class="custom-info-bar__content center">
              <div class="custom-info-bar__value">{{ display_protein }}</div>
              <div class="custom-info-bar__label">{{ label_protein }}</div>
            </div>
          </li>
        {%- endif -%}
        {%- if raw_carbs != blank -%}
          <li class="custom-info-bar__item">
            <div class="custom-info-bar__content center">
              <div class="custom-info-bar__value">{{ display_carbs }}</div>
              <div class="custom-info-bar__label">{{ label_carbs }}</div>
            </div>
          </li>
        {%- endif -%}
        {%- if raw_fat != blank -%}
          <li class="custom-info-bar__item">
            <div class="custom-info-bar__content center">
              <div class="custom-info-bar__value">{{ display_fat }}</div>
              <div class="custom-info-bar__label">{{ label_fat }}</div>
            </div>
          </li>
        {%- endif -%}
        <li class="custom-info-bar__item">
          <div class="custom-info-bar__content center">
            <div class="custom-info-bar__value">{{ val_portion }}</div>
            <div class="custom-info-bar__label">{{ label_portion }}</div>
          </div>
        </li>
        <li class="custom-info-bar__item">
          <div class="custom-info-bar__content center">
            <div class="custom-info-bar__value">{{ val_prep }}</div>
            <div class="custom-info-bar__label">{{ label_prep }}</div>
          </div>
        </li>
        <li class="custom-info-bar__item">
          <div class="custom-info-bar__content center">
            <div class="custom-info-bar__value">{{ val_frozen }}</div>
            <div class="custom-info-bar__label">{{ label_frozen }}</div>
          </div>
        </li>
      </ul>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product Info Bar",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#422b62"
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Value Color",
      "default": "#ff007f"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#d8c4d5"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Bottom Border Color",
      "default": "#0091e6"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "info_item",
      "name": "Info Item",
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "420 kcal"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "CALORIES"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Info Bar",
      "blocks": [
        {
          "type": "info_item",
          "settings": {
            "value": "420 kcal",
            "label": "CALORIES"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "28g",
            "label": "PROTEIN"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "32g",
            "label": "CARBS"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "18g",
            "label": "FAT"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "1 person",
            "label": "SERVES"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "5 min",
            "label": "PREP TIME"
          }
        },
        {
          "type": "info_item",
          "settings": {
            "value": "Never",
            "label": "FROZEN"
          }
        }
      ]
    }
  ]
}
{% endschema %}