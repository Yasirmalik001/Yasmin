          <li><span>{{ section.settings.label_days_week | default: 'Days / week' }}</span><span id="sum-days">5</span></li>
          <li><span>{{ section.settings.label_people | default: 'People' }}</span><span id="sum-people">1</span></li>
          <li><span>{{ section.settings.label_duration | default: 'Duration' }}</span><span id="sum-duration">1 Week</span></li>
          <li><span>{{ section.settings.label_discount | default: 'Discount' }}</span><span id="sum-discount">0%</span></li>
          <li><span>{{ section.settings.label_selected_dishes | default: 'Selected Dishes' }}</span><span id="sum-selected-count">0 / 10</span></li>
