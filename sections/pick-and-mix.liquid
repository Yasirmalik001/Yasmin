        <div class="pm-summary__list-title">{{ section.settings.label_selected_dishes | default: 'SELECTED DISHES' }}</div>
        <ul class="pm-summary__list" id="sum-dishes">
          <li style="font-style:italic;">{{ section.settings.label_no_dishes | default: 'No dishes selected yet' }}</li>
        </ul>

        <pick-and-mix-error class="visually-hidden">
          <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" fill-rule="evenodd" />
          </svg>
          <p></p>
        </pick-and-mix-error>

        <div class="pm-summary__total">
          <span>{{ section.settings.label_total | default: 'Total' }}</span>
          <span id="sum-total">{{ first_plan.price | money }}</span>
        </div>

        <button class="pm-summary__submit" id="place-order-btn">{{ section.settings.submit_button_text | default: 'Place Order' }}</button>
        <div class="pm-summary__secure">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#00B359" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
          {{ section.settings.label_secure_checkout | default: 'Pay securely with iDeal' }}
        </div>
      </div>
    </div>

  </div>
  
  <script type="application/json" id="pick-and-mix-variants">
    {%- assign variants_output = '' -%}
    {%- for variant in product.variants -%}
      {%- if variants_output != '' -%}{%- assign variants_output = variants_output | append: ',' -%}{%- endif -%}

      {%- assign selling_plans_output = '' -%}
      {%- assign rendered_plan_handles = ',' -%}

      {%- for allocation in variant.selling_plan_allocations -%}
        {%- assign sp = allocation.selling_plan -%}
        {%- assign name_handle = sp.name | handleize -%}
        {%- assign lookup_token = ',' | append: name_handle | append: ',' -%}

        {%- unless rendered_plan_handles contains lookup_token -%}
          {%- if selling_plans_output != '' -%}{%- assign selling_plans_output = selling_plans_output | append: ',' -%}{%- endif -%}
          {%- capture sp_json -%}
            { "id": {{ sp.id | json }}, "name": {{ sp.name | json }}, "price": {{ allocation.price | json }}, "compareAtPrice": {{ allocation.compare_at_price | json }} }
          {%- endcapture -%}
          {%- assign selling_plans_output = selling_plans_output | append: sp_json -%}
          {%- assign rendered_plan_handles = rendered_plan_handles | append: name_handle | append: ',' -%}
        {%- endunless -%}
      {%- endfor -%}

      {%- capture variant_json -%}
        { "id": {{ variant.id | json }}, "title": {{ variant.title | json }}, "price": {{ variant.price | json }}, "sellingPlans": [{{ selling_plans_output }}] }
      {%- endcapture -%}
      {%- assign variants_output = variants_output | append: variant_json -%}
    {%- endfor -%}
    [{{ variants_output }}]
  </script>

  <script type="application/json" id="pick-and-mix-existing">
    {%- if existing_line -%}
      {
        "lineKey": {{ existing_line.key | json }},
        "variantId": {{ existing_line.variant_id | json }},
        "days": {{ existing_line.variant.title | json }},
        "duration": {{ existing_line.selling_plan_allocation.selling_plan.name | json }},
        "people": {{ existing_line.quantity | json }},
        "choices": {{ cart.attributes.pick_mix_choices | default: '' | json }}
      }
    {%- else -%}
      null
    {%- endif -%}
  </script>
</pick-and-mix-builder>

<script>
  class PickAndMixProgress extends HTMLElement {
    static #CIRCUMFERENCE = 2 * Math.PI * 5.5;

    connectedCallback() {
      this.innerHTML = `
        <span class="pm-progress__group" data-category="mains">
          <svg class="pm-progress__circle" viewBox="0 0 16 16" width="26" height="26" aria-hidden="true">
            <circle class="pm-progress__circle-track" cx="8" cy="8" r="5.5" fill="none" stroke-width="2"/>
            <circle class="pm-progress__circle-fill" cx="8" cy="8" r="5.5" fill="none" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="pm-progress__count"></span>
        </span>

        <span class="pm-progress__group" data-category="sides">
          <svg class="pm-progress__circle" viewBox="0 0 16 16" width="26" height="26" aria-hidden="true">
            <circle class="pm-progress__circle-track" cx="8" cy="8" r="5.5" fill="none" stroke-width="2"/>
            <circle class="pm-progress__circle-fill" cx="8" cy="8" r="5.5" fill="none" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="pm-progress__count"></span>
        </span>
      `;

      this.groups = {
        mains: this.querySelector('.pm-progress__group[data-category="mains"]'),
        sides: this.querySelector('.pm-progress__group[data-category="sides"]')
      };

      Object.values(this.groups).forEach(group => {
        group.querySelector('.pm-progress__circle-fill').style.strokeDasharray = PickAndMixProgress.#CIRCUMFERENCE;
      });

      this.render();
    }

    render(selectedMains = 0, selectedSides = 0, max = 0, mainsLabel = "mains", sidesLabel = "sides") {
      if (!this.groups) return;
      this.renderGroup('mains', selectedMains, max, mainsLabel);
      this.renderGroup('sides', selectedSides, max, sidesLabel);
    }

    renderGroup(category, quantity, max, labelText) {
      const group = this.groups[category];
      if (!group) return;

      const fill = group.querySelector('.pm-progress__circle-fill');
      const count = group.querySelector('.pm-progress__count');
      const progress = max > 0 ? Math.min(quantity / max, 1) : 0;

      fill.style.strokeDashoffset = PickAndMixProgress.#CIRCUMFERENCE * (1 - progress);
      count.textContent = `${quantity} / ${max} ${labelText}`;
    }
  }

  if (!customElements.get('pick-and-mix-progress')) {
    customElements.define('pick-and-mix-progress', PickAndMixProgress);
  }

  if (!customElements.get('pick-and-mix-builder')) {
    customElements.define('pick-and-mix-builder', class PickAndMixBuilder extends HTMLElement {
      constructor() {
        super();
        this.state = {
          days: 5,
          people: 1,
          duration: "",
          planId: null,
          peopleDiscount: 0,
          dishes: {}, // variantId -> quantity
          total: 0
        };
      }

      get verified() {
        return (window.postcodeVerified === true || sessionStorage.getItem('postcodeVerified') === 'true') && 
               (window.deliveryDateSelected === true || sessionStorage.getItem('deliveryDateSelected') === 'true');
      }

      triggerVerificationCheck() {
         const picker = document.querySelector('delivery-picker') || document.getElementById('PostcodeChecker-Inline');
         if (picker) { 
           picker.scrollIntoView({ behavior: 'smooth', block: 'center' }); 
           
           const isPostcodeOk = window.postcodeVerified === true || sessionStorage.getItem('postcodeVerified') === 'true';
           if (!isPostcodeOk) {
             if (typeof picker.triggerError === 'function') {
               picker.triggerError('{{ section.settings.pc_js_error_add_to_order | default: "Kies een bezorgdatum om verder te gaan." | escape }}');
             }
             const zipInput = picker.querySelector('input#delivery_zone_zip_code') || picker.querySelector('input');
             if (zipInput) zipInput.focus();
           } else {
             if (typeof picker.triggerError === 'function') {
               picker.triggerError('{{ section.settings.pc_js_error_add_to_order | default: "Please select a delivery date first." | escape }}');
             }
           }
         }
      }

      connectedCallback() {
        this.variants = JSON.parse(this.querySelector('#pick-and-mix-variants').textContent);
        this.existing = JSON.parse(this.querySelector('#pick-and-mix-existing').textContent);
        
        this.bindEvents();

        if (this.existing) {
          this.hydrateFromExisting();
        } else {
          // Initialize defaults
          const activeDay = this.querySelector('#days-selector .pm-tile.is-active');
          this.state.days = activeDay ? parseInt(activeDay.dataset.value) : 5;

          const activePeople = this.querySelector('#people-selector .pm-tile.is-active');
          this.state.people = activePeople ? parseInt(activePeople.dataset.value) : 1;

          const activePlan = this.querySelector('#duration-selector .pm-sub-card.is-active');
          this.state.duration = activePlan ? activePlan.dataset.value : "";
          this.state.planId = activePlan ? parseInt(activePlan.dataset.planId) : null;
        }

        this.updateUI();
      }

      hydrateFromExisting() {
        this.state.days = parseInt(this.existing.days);
        this.state.people = parseInt(this.existing.people);
        this.state.duration = this.existing.duration;

        const activeVar = this.variants.find(v => parseInt(v.title) === this.state.days);
        if (activeVar) {
          const activePlan = activeVar.sellingPlans.find(p => p.name === this.state.duration);
          if (activePlan) this.state.planId = activePlan.id;
        }

        if (this.existing.choices) {
          this.existing.choices.split(',').forEach(entry => {
            const [varId, qty] = entry.split(':');
            if (varId && qty) {
              const qVal = parseInt(qty);
              if (qVal > 0) {
                this.state.dishes[parseInt(varId)] = qVal;
                const input = this.querySelector(`.pm-qty[data-variant-id="${varId}"] input`);
                if (input) input.value = qVal;
              }
            }
          });
        }

        this.updateTilesActiveState('#days-selector', this.state.days);
        this.updateTilesActiveState('#people-selector', this.state.people);
        this.updatePlanActiveState('#duration-selector', this.state.duration);
      }

      updateTilesActiveState(selector, value) {
        const container = this.querySelector(selector);
        if (!container) return;
        container.querySelectorAll('.pm-tile').forEach(tile => {
          const input = tile.querySelector('input');
          if (parseInt(tile.dataset.value) === value) {
            tile.classList.add('is-active');
            if (input) input.checked = true;
          } else {
            tile.classList.remove('is-active');
          }
        });
      }

      updatePlanActiveState(selector, value) {
        const container = this.querySelector(selector);
        if (!container) return;
        container.querySelectorAll('.pm-sub-card').forEach(card => {
          const input = card.querySelector('input');
          if (card.dataset.value === value) {
            card.classList.add('is-active');
            if (input) input.checked = true;
          } else {
            card.classList.remove('is-active');
          }
        });
      }

      bindEvents() {
        // Step 2: Days
        const daysSelector = this.querySelector('#days-selector');
        if (daysSelector) {
          daysSelector.querySelectorAll('.pm-tile').forEach(tile => {
            tile.addEventListener('click', (e) => {
              if (!this.verified) {
                e.preventDefault();
                e.stopPropagation();
                this.triggerVerificationCheck();
                return;
              }
              daysSelector.querySelectorAll('.pm-tile').forEach(t => t.classList.remove('is-active'));
              tile.classList.add('is-active');
              const input = tile.querySelector('input');
              if (input) input.checked = true;
              this.state.days = parseInt(tile.dataset.value);
              this.onPlanParamsChange();
            });
          });
        }

        // Step 3: People
        const peopleSelector = this.querySelector('#people-selector');
        if (peopleSelector) {
          peopleSelector.querySelectorAll('.pm-tile').forEach(tile => {
            tile.addEventListener('click', (e) => {
              if (!this.verified) {
                e.preventDefault();
                e.stopPropagation();
                this.triggerVerificationCheck();
                return;
              }
              peopleSelector.querySelectorAll('.pm-tile').forEach(t => t.classList.remove('is-active'));
              tile.classList.add('is-active');
              const input = tile.querySelector('input');
              if (input) input.checked = true;
              this.state.people = parseInt(tile.dataset.value);
              this.onPlanParamsChange();
            });
          });
        }

        // Step 4: Duration
        const durationSelector = this.querySelector('#duration-selector');
        if (durationSelector) {
          durationSelector.querySelectorAll('.pm-sub-card').forEach(card => {
            card.addEventListener('click', (e) => {
              if (!this.verified) {
                e.preventDefault();
                e.stopPropagation();
                this.triggerVerificationCheck();
                return;
              }
              durationSelector.querySelectorAll('.pm-sub-card').forEach(c => c.classList.remove('is-active'));
              card.classList.add('is-active');
              const input = card.querySelector('input');
              if (input) input.checked = true;
              this.state.duration = card.dataset.value;
              this.state.planId = parseInt(card.dataset.planId);
              this.updateUI();
            });
          });
        }

        // Category Filters
        const filters = this.querySelectorAll('#category-filters button');
        filters.forEach(btn => {
          btn.addEventListener('click', () => {
            filters.forEach(b => b.classList.remove('is-active'));
            btn.classList.add('is-active');
            const filter = btn.dataset.filter;

            const cards = this.querySelectorAll('.pm-product');
            cards.forEach(card => {
              if (filter === 'all' || card.dataset.category === filter) {
                card.classList.remove('visually-hidden');
              } else {
                card.classList.add('visually-hidden');
              }
            });
          });
        });

        // Quantity Selectors
        const qtyGroups = this.querySelectorAll('.pm-qty');
        qtyGroups.forEach(group => {
          const minus = group.querySelector('.pm-qty__minus');
          const plus = group.querySelector('.pm-qty__plus');
          const input = group.querySelector('input');
          const variantId = parseInt(group.dataset.variantId);
          const category = group.dataset.category;

          plus.addEventListener('click', () => {
            if (!this.verified) {
              this.triggerVerificationCheck();
              return;
            }

            const currentSelected = this.getSelectedCountByCategory(category);
            const limit = (this.state.days * this.state.people * 2) / 2;
            if (currentSelected >= limit) return;

            let current = parseInt(input.value);
            input.value = current + 1;
            this.state.dishes[variantId] = current + 1;
            this.updateUI();
          });

          minus.addEventListener('click', () => {
            if (!this.verified) {
              this.triggerVerificationCheck();
              return;
            }

            let current = parseInt(input.value);
            if (current > 0) {
              input.value = current - 1;
              if (current - 1 === 0) {
                delete this.state.dishes[variantId];
              } else {
                this.state.dishes[variantId] = current - 1;
              }
              this.updateUI();
            }
          });
        });

        // Form Submit
        const submitBtn = this.querySelector('#place-order-btn');
        if (submitBtn) {
          submitBtn.addEventListener('click', () => this.submitToCart());
        }

        // Listen to delivery picker changes
        document.addEventListener('delivery-picker:updated', (e) => {
          const sumDay = this.querySelector('#sum-day');
          const sumZone = this.querySelector('#sum-zone');
          if (e.detail.deliveryDate) {
             const d = new Date(e.detail.deliveryDate);
             if (sumDay) sumDay.textContent = d.toLocaleDateString('en-GB', { weekday: 'long', month: 'long', day: 'numeric' });
             if (sumZone) sumZone.textContent = 'Confirmed';
          } else {
             if (sumDay) sumDay.textContent = 'Not confirmed';
             if (sumZone) sumZone.textContent = 'Not confirmed';
          }
        });
      }

      onPlanParamsChange() {
        const activeVar = this.variants.find(v => parseInt(v.title) === this.state.days);
        if (activeVar) {
          const activePlan = activeVar.sellingPlans.find(p => p.name === this.state.duration);
          if (activePlan) {
            this.state.planId = activePlan.id;
          } else {
            const firstPlan = activeVar.sellingPlans[0];
            if (firstPlan) {
              this.state.duration = firstPlan.name;
              this.state.planId = firstPlan.id;
              this.updatePlanActiveState('#duration-selector', this.state.duration);
            }
          }
        }

        const discounts = { 1: 0, 2: 0.15, 3: 0.20, 4: 0.30 };
        this.state.peopleDiscount = discounts[this.state.people] || 0;

        this.updateUI();
      }

      getSelectedCountByCategory(category) {
        let total = 0;
        this.querySelectorAll(`.pm-qty[data-category="${category}"]`).forEach(group => {
          const val = parseInt(group.querySelector('input').value) || 0;
          total += val;
        });
        return total;
      }

      updateUI() {
        const requiredQuantity = this.state.days * this.state.people * 2;
        const requiredMains = requiredQuantity / 2;
        const requiredSides = requiredQuantity / 2;

        const selectedMains = this.getSelectedCountByCategory('mains');
        const selectedSides = this.getSelectedCountByCategory('sides');
        const totalSelected = selectedMains + selectedSides;

        // Update progress circles
        const progressEl = this.querySelector('pick-and-mix-progress');
        if (progressEl) {
          progressEl.render(
            selectedMains, 
            selectedSides, 
            requiredMains, 
            this.dataset.mainsLabel || 'mains', 
            this.dataset.sidesLabel || 'sides'
          );
        }

        // Update Portion Prices on step 4 cards
        const activeVar = this.variants.find(v => parseInt(v.title) === this.state.days);
        if (activeVar) {
          const portionLabel = this.dataset.portionLabel || 'portion';
          activeVar.sellingPlans.forEach(plan => {
             const portionPrice = (plan.price / 100) / (this.state.days * 2 * 4);
            const cardPriceCalc = this.querySelector(`.pm-sub-card__price-calc[data-plan-name="${CSS.escape(plan.name)}"]`);
            if (cardPriceCalc) {
              cardPriceCalc.textContent = `= €${portionPrice.toFixed(2)} / ${portionLabel}`;
            }
          });

          // Calculate Totals
          const activePlan = activeVar ? activeVar.sellingPlans.find(p => p.name === this.state.duration) : null;
          
          let planPrice = 0;
          let comparePrice = 0;
          
          if (activePlan) {
            planPrice = activePlan.price / 100;
            comparePrice = activePlan.compareAtPrice ? (activePlan.compareAtPrice / 100) : planPrice;
          } else if (activeVar) {
            planPrice = activeVar.price / 100;
            comparePrice = planPrice;
          }

          const originalSubtotal = comparePrice * this.state.people;
          const subtotal = planPrice * this.state.people;
          const peopleDiscountAmount = subtotal * this.state.peopleDiscount;
          
          this.state.total = subtotal - peopleDiscountAmount;
          const totalDiscountInEuros = originalSubtotal - this.state.total;

          // Update Summary list
          const sumDays = this.querySelector('#sum-days');
          if (sumDays) sumDays.textContent = this.state.days;

          const sumPeople = this.querySelector('#sum-people');
          if (sumPeople) sumPeople.textContent = this.state.people;

          const sumDuration = this.querySelector('#sum-duration');
          if (sumDuration) sumDuration.textContent = this.state.duration;

          const durationWeeks = parseInt(this.state.duration) || 1;
          const sumSubtitle = this.querySelector('#sum-subtitle');
          if (sumSubtitle) {
             sumSubtitle.style.display = durationWeeks > 1 ? '' : 'none';
          }

          const sumDiscount = this.querySelector('#sum-discount');
          if (sumDiscount) {
            if (totalDiscountInEuros > 0) {
              sumDiscount.textContent = `-€${totalDiscountInEuros.toFixed(2)}`;
              sumDiscount.style.color = 'var(--color-success)';
              sumDiscount.style.fontWeight = '800';
            } else {
              sumDiscount.textContent = '€0.00';
              sumDiscount.style.color = 'inherit';
              sumDiscount.style.fontWeight = 'normal';
            }
          }

          const sumSelectedCount = this.querySelector('#sum-selected-count');
          if (sumSelectedCount) sumSelectedCount.textContent = `${totalSelected} / ${requiredQuantity}`;

          const sumTotal = this.querySelector('#sum-total');
          if (sumTotal) {
            if (totalDiscountInEuros > 0) {
              sumTotal.innerHTML = `
                <div style="color: var(--color-text-muted); line-height: 1; text-align: right; margin-bottom: 2px;">per 4 weken</div>
                <div style="text-align: right; font-size: 22px;">€${this.state.total.toFixed(2)}</div>
                <div style="font-size: 14px; text-decoration: line-through; color: #9CA3AF; line-height: 1; margin-top: 4px; text-align: right;">€${originalSubtotal.toFixed(2)}</div>
              `;
            } else {
              sumTotal.innerHTML = `
                <div style="color: var(--color-text-muted); line-height: 1; text-align: right; margin-bottom: 2px;">per 4 weken</div>
                <div style="text-align: right;">€${this.state.total.toFixed(2)}</div>
              `;
            }
          }
        }

        // Update Selected list in sidebar
        const sumDishes = this.querySelector('#sum-dishes');
        if (sumDishes) {
          sumDishes.innerHTML = '';
          const activeDishes = Object.entries(this.state.dishes).filter(([_, qty]) => qty > 0);
          if (activeDishes.length === 0) {
            sumDishes.innerHTML = `<li style="font-style:italic;">${this.dataset.noDishes || 'No dishes selected yet'}</li>`;
          } else {
            const requiredQuantity = this.state.days * this.state.people * 2;
            const requiredMains = requiredQuantity / 2;
            const requiredSides = requiredQuantity / 2;
            const selectedMains = this.getSelectedCountByCategory('mains');
            const selectedSides = this.getSelectedCountByCategory('sides');

            const groupMains = [];
            const groupSides = [];

            activeDishes.forEach(([variantId, qty]) => {
              const qtyEl = this.querySelector(`.pm-qty[data-variant-id="${variantId}"]`);
              const title = qtyEl ? qtyEl.dataset.title : 'Dish';
              const productEl = qtyEl ? qtyEl.closest('.pm-product') : null;
              const category = productEl ? productEl.dataset.category : 'mains';
              const imgSrc = productEl ? (productEl.querySelector('.pm-product__img')?.src || '') : '';
              
              const itemHtml = `
                <li class="pm-sum-dish-item">
                  <div class="pm-sum-dish-left">
                    ${imgSrc ? `<img src="${imgSrc}" alt="${title}">` : ''}
                    <span>${title}</span>
                  </div>
                  <span>${qty}x</span>
                </li>
              `;
              if (category === 'mains') groupMains.push(itemHtml);
              else groupSides.push(itemHtml);
            });

            let html = '';
            if (groupMains.length > 0) {
              html += `
                <div class="pm-sum-category-header">
                  <span>Hoofdgerechten</span>
                  <span style="color: ${selectedMains === requiredMains ? 'var(--color-success)' : 'inherit'};">
                    ${selectedMains === requiredMains ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><circle cx="12" cy="12" r="10"></circle></svg>' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><circle cx="12" cy="12" r="10"></circle></svg>'}
                    ${selectedMains} / ${requiredMains}
                  </span>
                </div>
                ${groupMains.join('')}
              `;
            }
            if (groupSides.length > 0) {
              html += `
                <div class="pm-sum-category-header">
                  <span>Bijgerechten</span>
                  <span style="color: ${selectedSides === requiredSides ? 'var(--color-success)' : 'inherit'};">
                    ${selectedSides === requiredSides ? '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><circle cx="12" cy="12" r="10"></circle></svg>' : '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="margin-right:6px;"><circle cx="12" cy="12" r="10"></circle></svg>'}
                    ${selectedSides} / ${requiredSides}
                  </span>
                </div>
                ${groupSides.join('')}
              `;
            }
            sumDishes.innerHTML = html;
          }
        }
      }

      async submitToCart() {
        const btn = this.querySelector('#place-order-btn');
        if (!btn) return;

        if (!this.verified) {
           this.triggerVerificationCheck();
           return;
        }

        const requiredQuantity = this.state.days * this.state.people * 2;
        const requiredMains = requiredQuantity / 2;
        const requiredSides = requiredQuantity / 2;

        const selectedMains = this.getSelectedCountByCategory('mains');
        const selectedSides = this.getSelectedCountByCategory('sides');

        const missingMains = Math.max(requiredMains - selectedMains, 0);
        const missingSides = Math.max(requiredSides - selectedSides, 0);

        const errorEl = this.querySelector('pick-and-mix-error');
        if (missingMains > 0 || missingSides > 0) {
          let message = "";
          if (missingMains > 0 && missingSides > 0) {
            message = `Kies nog ${missingMains} hoofdgerechten en ${missingSides} bijgerechten om verder te gaan.`;
          } else if (missingMains > 0) {
            message = `Kies nog ${missingMains} hoofdgerechten om verder te gaan.`;
          } else {
            message = `Kies nog ${missingSides} bijgerechten om verder te gaan.`;
          }

          if (errorEl) {
            errorEl.querySelector('p').textContent = message;
            errorEl.classList.remove('visually-hidden');
            errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
          return;
        }

        if (errorEl) {
          errorEl.classList.add('visually-hidden');
        }

        this.setAttribute("loading", "true");
        btn.textContent = this.dataset.addingText || 'Adding...';

        const pickMixChoices = Object.entries(this.state.dishes)
          .map(([variantId, qty]) => `${variantId}:${qty}`)
          .join(',');

        const headers = { 'Content-Type': 'application/json', 'Accept': 'application/json' };

        try {
          if (this.existing && this.existing.lineKey) {
            await fetch('/cart/change.js', {
              method: 'POST',
              headers,
              body: JSON.stringify({ id: this.existing.lineKey, quantity: 0 })
            });
          }

          const activeVar = this.variants.find(v => parseInt(v.title) === this.state.days);
          if (!activeVar) throw new Error("Selected days variant not found.");

          const addResponse = await fetch('/cart/add.js', {
            method: 'POST',
            headers,
            body: JSON.stringify({
              items: [{
                id: activeVar.id,
                quantity: this.state.people,
                selling_plan: this.state.planId
              }]
            })
          });
          if (!addResponse.ok) throw new Error("Cart add failed.");

          const updateResponse = await fetch('/cart/update.js', {
            method: 'POST',
            headers,
            body: JSON.stringify({ attributes: { pick_mix_choices: pickMixChoices } })
          });
          if (!updateResponse.ok) throw new Error("Cart attributes update failed.");

          window.location.href = '/checkout';

        } catch (err) {
          console.error(err);
          btn.textContent = this.dataset.errorText || 'Error — try again';
          this.removeAttribute("loading");
          setTimeout(() => {
            btn.textContent = this.querySelector('#place-order-btn').dataset.defaultText || 'Place Order';
            this.updateUI();
          }, 2000);
        }
      }
    });
  }
</script>

