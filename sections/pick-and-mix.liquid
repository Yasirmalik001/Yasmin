{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign first_plan = current_variant.selling_plan_allocations.first.selling_plan -%}

{%- assign existing_line = nil -%}
{%- for item in cart.items -%}
  {%- if item.product_id == product.id -%}
    {%- assign existing_line = item -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- style -%}
  /* --- Global & Variables --- */
  .pick-mix-wrapper {
    --color-primary: #5243C0; /* Exact Figma Purple */
    --color-primary-light: #F4F3FA;
    --color-primary-hover: #4032A0;
    --color-success: #00B359; /* Exact Figma Green */
    --color-pink: #FF007F; /* Exact Figma Pink */
    --color-border: #E5E7EB;
    --color-text-main: #111827;
    --color-text-muted: #6B7280;
    font-family: 'DM Sans', sans-serif;
  }

  .pick-mix-wrapper * {
    font-family: 'DM Sans', sans-serif;
  }

  .pick-mix-wrapper h2,
  .pick-mix-wrapper h2 * {
    font-family: Barlow, sans-serif !important;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* --- Layout --- */
  .pick-mix-layout {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  @media screen and (min-width: 990px) {
    .pick-mix-layout {
      flex-direction: row;
      align-items: flex-start;
      gap: 5rem;
      justify-content: space-between;
    }
    .pick-mix-sidebar-col {
      width: 320px;
      flex-shrink: 0;
    }
  }
  .pick-mix-main-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4rem;
    max-width: 1050px;
  }
  .pick-mix-sidebar-col {
    position: sticky;
    top: 12rem;
  }

  /* --- Typography & Headers --- */
  .pm-section-header { margin-bottom: 1.5rem; }
  .pm-section-header h2 {
    font-size: 24px;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    color: var(--color-text-main);
  }
  .pm-section-header p {
    font-size: 14px;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* --- Radio Tiles (Days & People) --- */
  .pm-tiles {
    display: flex; gap: 16px; flex-wrap: wrap;
  }
  .pm-tile {
    position: relative;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    width: 80px; height: 90px;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    cursor: pointer; background: #ffffff;
    transition: all 0.2s;
  }
  .pm-tile input { display: none; }
  .pm-tile__val { font-size: 28px; font-weight: 800; color: var(--color-text-main); line-height: 1; margin-bottom: 4px; }
  .pm-tile__label { font-size: 13px; color: var(--color-text-muted); }
  .pm-tile__discount {
    position: absolute; top: -10px; background: var(--color-success); color: #fff;
    font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 6px;
  }
  .pm-tile.is-active {
    border-color: var(--color-primary); background: var(--color-primary);
  }
  .pm-tile.is-active .pm-tile__val,
  .pm-tile.is-active .pm-tile__label {
    color: #ffffff;
  }

  /* --- Subscription Length (Cards) --- */
  .pm-subs {
    display: grid; grid-template-columns: 1fr; gap: 16px;
  }
  @media screen and (min-width: 750px) {
    .pm-subs { grid-template-columns: 1fr 1fr; }
  }
  .pm-sub-card {
    border: 1px solid var(--color-border); border-radius: 12px;
    padding: 24px; background: #ffffff; cursor: pointer;
    display: flex; flex-direction: column;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    min-height: 120px;
    overflow: hidden;
  }
  .pm-sub-radio {
    width: 20px; height: 20px; border-radius: 50%; border: 1px solid #D1D5DB;
    margin-top: 16px; display: block; position: relative;
    transition: all 0.2s;
  }
  .pm-sub-content { flex: 1; display: flex; flex-direction: column; }
  .pm-sub-card.is-active {
    border-color: var(--color-primary); background: var(--color-primary); color: #ffffff;
    /* min-height: 180px; */
  }
  .pm-sub-card.is-active .pm-sub-radio {
    border: 1px solid #ffffff;
  }
  .pm-sub-card.is-active .pm-sub-radio::after {
    content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 10px; height: 10px; background: #ffffff; border-radius: 50%;
  }
  .pm-sub-card__header {
    display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;
  }
  .pm-sub-card__header-left { flex: 1; }
  .pm-sub-card__header-right { text-align: right; }

  .pm-sub-card__title {
    font-size: 20px;
    font-weight: 800;
    margin: 0;
    color: inherit;
    font-family: Barlow, sans-serif !important;
  }
  .pm-sub-card__desc { font-size: 13px; color: var(--color-text-muted); margin-top: 4px; }
  .pm-sub-card.is-active .pm-sub-card__desc { color: rgba(255,255,255,0.8); }
  
  .pm-sub-card__badge { font-size: 13px; font-weight: 800; color: var(--color-success); display: block; margin-bottom: 2px; }
  .pm-sub-card__price-calc { font-size: 12px; color: var(--color-text-muted); }
  .pm-sub-card.is-active .pm-sub-card__badge { color: #ffffff; opacity: 0.9; }
  .pm-sub-card.is-active .pm-sub-card__price-calc { color: #ffffff; opacity: 0.8; }

  .pm-plan-info {
    background: #F7F6F2; border-radius: 8px; padding: 16px; margin-top: 16px;
    font-size: 13px; color: var(--color-text-muted);  border: 1px solid #D3D1C7; line-height: 1.5;
  }
  .pm-plan-info strong { color: var(--color-text-main); }

  /* --- Dietary Tabs --- */
  .pm-filters {
    display: flex; gap: 10px; margin-bottom: 24px;
  }
  .pm-filter-tab {
    padding: 12px 14px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-muted);
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pm-filter-tab.is-active {
    background: var(--color-primary); color: #ffffff; border-color: var(--color-primary);
  }
  .pm-filter-tab:hover:not(.is-active) { background: #f9f9f9; border-color: #d1d5db; }

  /* --- Products Grid --- */
  .pm-dishes-header {
    display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-wrap: wrap; gap: 1rem;
  }
  .pm-dishes-title { font-size: 20px; font-weight: 800; margin: 0; color: var(--color-text-main); }

  .pm-grid {
    display: grid; grid-template-columns: 1fr; gap: 24px;
  }
  @media screen and (min-width: 750px) {
    .pm-grid { grid-template-columns: 1fr 1fr; }
  }

.pm-product {
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    /* flex-direction: column; */
    transition: all 0.3s ease;
    align-items: center;
}
  .pm-product:hover {
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
  }
.pm-product__img-wrapper {
    width: 100%;
    height: 180px;
    overflow: hidden;
    max-width: 180px;
}
  .pm-product__img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;
  }
  .pm-product:hover .pm-product__img {
    transform: scale(1.05);
  }
  .pm-product__content {
    padding: 0 20px; display: flex; flex-direction: column; flex: 1; gap: 5px;
  }
  .pm-product__category {
    font-size: 11px; font-weight: 800; text-transform: uppercase; color: var(--color-pink); margin-bottom: 8px; letter-spacing: 0.5px;
  }
  .pm-product__title {
    font-size: 16px; font-weight: 800; margin: 0 0 6px 0; color: var(--color-text-main);
  }
  .pm-product__desc {
    font-size: 13px; color: var(--color-text-muted); margin: 0 0 16px 0; line-height: 1.4;
  }
  .pm-product__tags {
    display: flex; gap: 8px; margin-bottom: 5px; flex-wrap: wrap;
  }
  .pm-product__tag {
    font-size: 11px; padding: 4px 10px; border-radius: 6px; font-weight: 700;
    letter-spacing: 0.2px; line-height: 1; display: inline-flex; align-items: center;
  }
  
  /* --- Tag Color Mapping --- */
  .tag-vegan, .tag-vegetarian { background: #DCFCE7; color: #166534; }
  .tag-meat, .tag-meat-based, .tag-etli { background: #FEE2E2; color: #991B1B; }
  .tag-gluten-free, .tag-gf, .is-gf { background: #FFEDD5; color: #9A3412; }
  .tag-lactose-free { background: #DBEAFE; color: #1E40AF; }
  .tag-fish, .tag-seafood { background: #E0F2FE; color: #075985; }
  .tag-low-carb { background: #F3E8FF; color: #6B21A8; }
.pm-product__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    gap: 10px;
}
  .pm-product__price {
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text-main);
    font-family: Barlow, sans-serif;
  }
  .pm-qty {
    display: flex; align-items: center; border: 1px solid var(--color-border); border-radius: 6px; overflow: hidden;
  }
  .pm-qty button {
    background: #ffffff; border: none; width: 36px; height: 36px;
    font-size: 18px; font-weight: 400; cursor: pointer; color: var(--color-text-main);
  }
  .pm-qty button:hover { background: #F9FAFB; }
  .pm-qty input {
    width: 40px; height: 36px; border: none;
    border-left: 1px solid var(--color-border); border-right: 1px solid var(--color-border);
    text-align: center; font-weight: 700; font-size: 14px; color: var(--color-text-main); background: #ffffff; pointer-events: none;
  }

  /* --- Progress Circle --- */
pick-and-mix-progress {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 15px;
}
  .pm-progress__group {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .pm-progress__circle {
    transform: rotate(-90deg);
    flex-shrink: 0;
  }
  .pm-progress__circle-track {
    stroke: var(--color-border);
  }
  .pm-progress__circle-fill {
    stroke: var(--color-success);
    transition: stroke-dashoffset 0.2s ease;
  }
  .pm-progress__count {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-text-main);
    white-space: nowrap;
  }

  /* --- Sidebar Summary --- */
  .pm-summary {
    background: #ffffff; padding: 0;
  }
  .pm-summary__header {
    margin-bottom: 14px; padding-bottom: 10px; border-bottom: 1px solid var(--color-border);
  }
  .pm-summary__header h3 {
    margin: 0; font-size: 24px; font-weight: 800; color: var(--color-text-main);
  }
  .pm-summary__header p {
    margin: 4px 0 0 0; font-size: 13px; color: var(--color-text-muted);
  }

  .pm-summary__list { list-style: none; padding: 0; margin: 0 0 24px 0; }
  .pm-summary__list li {
    display: flex; justify-content: space-between; font-size: 13px;
    padding: 8px 0; color: var(--color-text-muted);
  }
  .pm-summary__list li span:last-child {
    font-weight: 700; color: var(--color-text-main);
  }
  .pm-sum-category-header {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 14px; font-weight: 800; color: var(--color-text-main);
    margin: 16px 0 8px 0; font-family: Barlow, sans-serif;
  }
  .pm-sum-category-header span:last-child {
    display: flex; align-items: center; font-size: 14px; font-weight: 700;
  }
  .pm-sum-dish-item {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 0; font-size: 14px; color: var(--color-text-muted);
  }
  .pm-sum-dish-left {
    display: flex; align-items: center; gap: 12px;
  }
  .pm-sum-dish-left img {
    width: 24px; height: 24px; border-radius: 4px; object-fit: cover;
  }
  .pm-sum-dish-item > span:last-child {
    font-weight: 700; color: var(--color-text-main);
  }
  .pm-summary__list-title {
    font-size: 11px; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--color-text-muted); margin: 24px 0 8px 0;
  }

  .pm-summary__total {
    display: flex; justify-content: space-between; align-items: center;
    padding: 20px 0; border-top: 2px solid var(--color-text-main); margin-bottom: 0px;
  }
  .pm-summary__total span:first-child {
    font-size: 22px; font-weight: 800; color: var(--color-text-main);
  }
  .pm-summary__total span:last-child {
    font-size: 28px; font-weight: 900; color: var(--color-primary);
  }

  .pm-summary__submit {
    width: 100%; padding: 16px;
    background: var(--color-primary); color: #ffffff;
    font-size: 16px; font-weight: 800; border: none; border-radius: 8px;
    cursor: pointer; transition: all 0.3s;
  }
  .pm-summary__submit:hover { opacity: 0.95; }
  
  .pm-summary__secure {
    text-align: center; font-size: 12px; color: var(--color-text-muted); margin-top: 16px;
    display: flex; align-items: center; justify-content: center; gap: 6px;
  }

  /* --- Error Banner --- */
pick-and-mix-error {
    display: flex;
    gap: 9px;
    padding: 10px;
    border-radius: 8px;
    background-color: #fdf3f3;
    /* border: 1px solid #eb5757; */
    font-size: 13px;
    color: #c62828;
    margin-bottom: 1.5rem;
    align-items: baseline;
    font-weight: 500 !important;
}
  pick-and-mix-error svg { width: 16px; height: 16px; flex-shrink: 0; fill: currentColor; }
  pick-and-mix-error p { margin: 0; font-weight: 500; }

  pick-and-mix-builder:not(:defined) { display: none; }
  pick-and-mix-builder[loading="true"] {
    cursor: wait;
    pointer-events: none;
    opacity: 0.6;
  }

  @media screen and (max-width: 750px) {
    .pm-sub-card__header-right { text-align: left; }
    .pm-subs { grid-template-columns: 1fr 1fr; }
    .pm-sub-card__header { flex-direction: column; align-items: flex-start; gap: 12px; }
    label.pm-sub-card { padding: 12px; }
  }
{%- endstyle -%}

<pick-and-mix-builder class="pick-mix-wrapper color-{{ section.settings.color_scheme }}" 
  data-adding-text="{{ section.settings.js_adding_text | escape }}"
  data-added-text="{{ section.settings.js_added_text | escape }}"
  data-error-text="{{ section.settings.js_error_text | escape }}"
  data-mains-label="{{ section.settings.label_mains | default: 'mains' }}"
  data-sides-label="{{ section.settings.label_sides | default: 'sides' }}"
  data-no-dishes="{{ section.settings.label_no_dishes | default: 'No dishes selected yet' }}"
  data-label-mains-suffix="{{ section.settings.label_mains_suffix | default: 'mains' | escape }}"
  data-label-sides-suffix="{{ section.settings.label_sides_suffix | default: 'sides' | escape }}"
  data-label-of="{{ section.settings.label_of | default: 'van' | escape }}"
  data-portion-label="{{ section.settings.plan_portion_text | default: 'portie' | escape }}"
  data-days-label="{{ section.settings.days_label | default: 'dagen' | escape }}"
  data-person-label="{{ section.settings.person_label | default: 'persoon' | escape }}"
  data-people-label="{{ section.settings.people_label | default: 'personen' | escape }}"
>
  <div class="pick-mix-layout page-width section-{{ section.id }}-padding">
    
    {%- assign heading_text = page.title | default: section.settings.step2_heading -%}
    {%- if heading_text != blank -%}
      <h1 class="visually-hidden">{{ heading_text }}</h1>
    {%- endif -%}
    
    <!-- LEFT COLUMN: BUILDER FORM -->
    <div class="pick-mix-main-col">
      
<div class="color-{{ section.settings.color_scheme }} gradient">
    {%- if section.settings.heading != blank -%}
      <p class="h2 heading-h2" style="text-align: left; margin-bottom: 2rem; margin-top: 0;">{{ section.settings.heading }}</p>
    {%- endif -%}
    <div>
{% assign delivery_date = cart.attributes['Delivery Date'] %}
{% assign delivery_day = cart.attributes['Delivery Day'] %}
{% assign formatted_delivery_date = delivery_date | date: '%Y-%m-%d' %}

<div class="delivery-picker-section">
  <div class="delivery-picker-header">
    <p class="delivery-picker-title" style="margin-top: 0;">{{ section.settings.pc_heading | default: "Where do we deliver?" }}</p>
    <p class="delivery-picker-subtitle">{{ section.settings.pc_subtitle | default: "Enter your postcode to confirm your delivery zone — required before continuing." }}</p>
  </div>

  <delivery-picker
    id="section-{{ section.id }}"
    delivery-date="{{ delivery_date }}"
    delivery-day="{{ delivery_day }}"
    {% if section.settings.restrict_next_week_until_wednesday %}restrict-next-week{% endif %}
    {{ section.shopify_attributes }}
  >
    <div class="delivery-picker-container">
      
      <!-- Cart Validation Error Alert Box -->
      <div class="delivery-picker-cart-alert visually-hidden" style="
        background-color: #fdf3f3;
        border: 1px solid #eb5757;
        color: #c62828;
        padding: 12px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 500;
        line-height: 1.5;
        text-align: left;
      ">
        {{ section.settings.pc_js_error_add_to_order | default: "Kies een bezorgdatum om verder te gaan." }}
      </div>
      
      <div class="delivery-picker-step">
        <span class="step-text">{{ section.settings.pc_step_label | default: "STEP 1 — ENTER YOUR POSTCODE" }}</span>
        <span class="step-badge">{{ section.settings.pc_step_badge | default: "REQUIRED" }}</span>
      </div>

      <div class="delivery-zone__form">
        <template id="delivery-zone-unavailable">
          <p class="delivery-zone__feedback delivery-zone__feedback--unavailable">{{ 'sections.delivery-picker.feedback.unavailable' | t }}</p>
        </template>

        <form class="delivery-input-group">
          <div class="delivery-select-wrapper">
            <img decoding="async" loading="lazy" id="current_country_flag" src="" alt="Flag" width="20" height="14" style="border-radius:2px; object-fit:cover; margin-left: 1rem; display: none;">
            <label for="delivery_zone_country" class="visually-hidden">{{ "sections.delivery-picker.labels.country" }}</label>
           <select id="delivery_zone_country" name="delivery_zone[country]" required>
              {% for block in section.blocks %}
                {% if block.type == 'delivery_country' %}
                  <option value="{{ block.settings.country_code | default: block.settings.country_name }}">
                    {{ block.settings.country_code | default: block.settings.country_name }}
                  </option>
                {% endif %}
              {% endfor %}
            </select>
          </div>

          <div class="delivery-input-wrapper">
            <label for="delivery_zone_zip_code" class="visually-hidden">{{ "sections.delivery-picker.labels.zip_code" }}</label>
            <input id="delivery_zone_zip_code" name="delivery_zone[zip_code]" type="text" placeholder="{{ section.settings.pc_placeholder_text | default: 'e.g. 6512 AB...' }}" required />
          </div>

          <button type="submit" class="delivery-submit-button">{{ section.settings.pc_button_text | default: "Check &rarr;" }}</button>
        </form>

        <p class="delivery-picker__error" role="alert">{{ section.settings.pc_error_text | default: "Kies een bezorgdatum om verder te gaan." }}</p>
        <div class="delivery-zone__form-feedback"></div>
      </div>

      <div class="delivery-zones {% if delivery_date == blank %} visually-hidden {% endif %}">
        {% assign max_days = section.settings.max_days_ahead | default: 21 %}
        {% for i in (2..max_days) %}
          {% assign offset_seconds = i | times: 86400 %}
          {% assign future_timestamp = "now" | date: "%s" | plus: offset_seconds %}

          {% assign weekday_name     = future_timestamp | date: '%A' %}
          {% assign weekday_key      = weekday_name | downcase %}
          {% assign weekday_t_key    = 'sections.delivery-picker.days.' | append: weekday_key %}
          {% assign date_label       = future_timestamp | date: '%e %B' %}
          {% assign machine_date     = future_timestamp | date: '%Y-%m-%d' %}

          <button
            type="button"
            class="delivery-zone visually-hidden {% if formatted_delivery_date == machine_date %} delivery-zone--active {% endif %}"
            data-delivery-date="{{ machine_date }}"
            data-delivery-day="{{ weekday_key }}"
            data-delivery-offset="{{ i }}"
          >
            <span class="delivery-zone__day">{{ weekday_t_key | t }}</span>
            <span class="delivery-zone__date">{{ date_label }}</span>
          </button>
        {% endfor %}
      </div>
    </div>
  </delivery-picker>

  <div class="delivery-picker-footer">
    <span class="footer-label">{{ section.settings.pc_footer_label | default: "We deliver to:" }}</span>
    {% for block in section.blocks %}
      {% if block.type == 'delivery_country' %}
        <span class="footer-badge" {{ block.shopify_attributes }}>
          {% if block.settings.flag_image != blank %}
            <img decoding="async" loading="lazy" src="{{ block.settings.flag_image | image_url: width: 400 }}" alt="{{ block.settings.country_code }}"  style="border-radius:2px; object-fit:cover;">
          {% endif %}
          {{ block.settings.country_name }}
        </span>
      {% endif %}
    {% endfor %}
  </div>
</div>


    </div>
  </div>


      <!-- Step 2: Days -->
      <div class="pm-section">
        <div class="pm-section-header">
          <h2>{{ section.settings.step2_heading }}</h2>
          <p>{{ section.settings.step2_description }}</p>
        </div>
        <div class="pm-tiles" id="days-selector">
          {%- for variant in product.variants -%}
            <label class="pm-tile{% if forloop.first %} is-active{% endif %}" data-value="{{ variant.title | escape }}">
              <input type="radio" name="days" value="{{ variant.title | escape }}" {% if forloop.first %}checked{% endif %}>
              <span class="pm-tile__val">{{ variant.title }}</span>
              <span class="pm-tile__label">{{ section.settings.days_label | default: 'dagen' }}</span>
            </label>
          {%- endfor -%}
        </div>
      </div>

      <!-- Step 3: People -->
      <div class="pm-section">
        <div class="pm-section-header">
          <h2>{{ section.settings.step3_heading }}</h2>
          <p>{{ section.settings.step3_description }}</p>
        </div>
        <div class="pm-tiles" id="people-selector">
          <label class="pm-tile is-active" data-value="1">
            <input type="radio" name="people" value="1" checked>
            <span class="pm-tile__val">1</span>
            <span class="pm-tile__label">{{ section.settings.person_label | default: 'persoon' }}</span>
          </label>
          <label class="pm-tile" data-value="2">
            <input type="radio" name="people" value="2">
            <span class="pm-tile__discount">{{ section.settings.discount_badge_people_2 | default: '-15%' }}</span>
            <span class="pm-tile__val">2</span>
            <span class="pm-tile__label">{{ section.settings.people_label | default: 'personen' }}</span>
          </label>
          <label class="pm-tile" data-value="3">
            <input type="radio" name="people" value="3">
            <span class="pm-tile__discount">{{ section.settings.discount_badge_people_3 | default: '-20%' }}</span>
            <span class="pm-tile__val">3</span>
            <span class="pm-tile__label">{{ section.settings.people_label | default: 'personen' }}</span>
          </label>
          <label class="pm-tile" data-value="4">
            <input type="radio" name="people" value="4">
            <span class="pm-tile__discount">{{ section.settings.discount_badge_people_4 | default: '-30%' }}</span>
            <span class="pm-tile__val">4</span>
            <span class="pm-tile__label">{{ section.settings.people_label | default: 'personen' }}</span>
          </label>
        </div>
      </div>

      <!-- Step 4: Subscription Length -->
      <div class="pm-section">
        <div class="pm-section-header">
          <h2>{{ section.settings.step4_heading }}</h2>
          <p>{{ section.settings.step4_description }}</p>
        </div>
        <div class="pm-subs" id="duration-selector">
          {%- assign rendered_plan_names = "," -%}
          {%- assign is_first_plan = true -%}
          {%- for group in product.selling_plan_groups -%}
            {%- for sp in group.selling_plans -%}
              {%- assign name_handle = sp.name | handleize -%}
              {%- assign lookup_token = "," | append: name_handle | append: "," -%}
              {%- unless rendered_plan_names contains lookup_token -%}
                <label class="pm-sub-card{% if is_first_plan %} is-active{% endif %}" data-value="{{ sp.name | escape }}" data-plan-id="{{ sp.id }}">
                  <input type="radio" name="duration" value="{{ sp.name | escape }}" data-plan-id="{{ sp.id }}" {% if is_first_plan %}checked{% endif %} style="display:none;">
                <div class="pm-sub-content">
                  <div class="pm-sub-card__header">
                    <div class="pm-sub-card__header-left">
                      <h3 class="pm-sub-card__title">{{ sp.name }}</h3>
                      <div class="pm-sub-card__desc">{{ section.settings.plan_desc_text | default: 'Flexible plan. Cancel or pause anytime.' }}</div>
                    </div>
                    <div class="pm-sub-card__header-right">
                      <span class="pm-sub-card__badge">{{ section.settings.plan_badge_text | default: 'Best Price' }}</span>
                      <span class="pm-sub-card__price-calc" data-plan-name="{{ sp.name | escape }}">= &euro;0.00 / {{ section.settings.plan_portion_text | default: 'portion' }}</span>
                    </div>
