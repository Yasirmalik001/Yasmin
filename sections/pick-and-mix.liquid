                  <div class="pm-product__img-wrapper">
                    {%- if product.featured_image != blank -%}
                      <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" class="pm-product__img" width="300" height="300" loading="lazy" decoding="async">
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'pm-product__img' }}
                    {%- endif -%}
                  </div>
                  <div class="pm-product__content">
                    <span class="pm-product__category">{{ category_label }}</span>
                    <h3 class="pm-product__title">{{ product.title }}</h3>
                    {% comment %} <div class="pm-product__tags">
                      {%- for tag in product.tags limit: 3 -%}
                        {%- assign tag_class = "tag-" | append: tag | handle -%}
                        <span class="pm-product__tag {{ tag_class }}">{{ tag }}</span>
                      {%- endfor -%}
                    </div> {% endcomment %}
                    <div class="pm-product__footer">
                      <span class="pm-product__price">{{ product.price | money }}</span>
                      <div class="pm-qty" data-variant-id="{{ variant.id }}" data-category="{{ category }}" data-title="{{ product.title | escape }}">
                        <button type="button" class="pm-qty__minus">-</button>
