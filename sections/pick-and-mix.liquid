            {% comment %} <button type="button" class="pm-filter-tab is-active" data-filter="all">{{ section.settings.label_all | default: 'All' }}</button> {% endcomment %}
            <button type="button" class="pm-filter-tab is-active" data-filter="mains">{{ section.settings.label_mains | default: 'Mains' }}</button>
            <button type="button" class="pm-filter-tab" data-filter="sides">{{ section.settings.label_sides | default: 'Sides' }}</button>
