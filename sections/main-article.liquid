{{ 'section-blog-post.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* --- PREVIOUS STYLES --- */
  .custom-article-header {padding-bottom: 32px; max-width: 1200px; margin: 0 auto; }
  .article-category-badge { display: inline-block; background: #eeebff; color: #5c43d6; font-size: 12px; font-weight: bold; padding: 6.4px 12.8px; border-radius: 4px; letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 24px; }
  .custom-article-header .article-template__title { font-size: 56px; font-weight: 900; line-height: 1.1; margin-bottom: 16px; color: #1a1a1a; letter-spacing: -0.02em; }
  .article-excerpt { font-size: 20px; color: #666; font-style: italic; margin-bottom: 40px; max-width: 800px; line-height: 1.5; }
  
  .article-meta-row { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #eaeaea; padding-top: 24px; flex-wrap: wrap; gap: 16px; }
  .article-author-info { display: flex; align-items: center; gap: 16px; }
  .author-avatar { width: 42px; height: 42px; background: #eeebff; color: #5c43d6; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 15.2px; }
  .author-details { display: flex; flex-direction: column; }
  .author-name { font-weight: bold; color: #333; font-size: 15.2px; }
  .meta-details { font-size: 13.6px; color: #888; margin-top: 3.2px; }
  
  .article-actions { display: flex; gap: 8px; }
  .btn-secondary { background: white; border: 1px solid #ccc; color: #333; padding: 8px 19.2px; border-radius: 4px; cursor: pointer; font-size: 13.6px; text-decoration: none; }
  .btn-secondary:hover { border-color: #999; }

  .article-image-wrapper { max-width: 1200px; margin: 0 auto 64px; padding: 0 24px; }
  .article-image-wrapper img { width: 100%; height: auto; border-radius: 16px; object-fit: cover; }

  .article-main-grid { display: grid; grid-template-columns: 1fr 340px; gap: 80px; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  @media (max-width: 900px) { .article-main-grid { grid-template-columns: 1fr; gap: 48px; } }

  .article-content-column .rte { font-size: 17.6px; line-height: 1.8; color: #333; }
  .article-content-column .rte h2, .article-content-column .rte h3 { font-weight: 900; margin-top: 40px; color: #1a1a1a; }
  .article-content-column .rte blockquote { background: #f4f0ff; border-left: 5px solid #d11c8e; padding: 32px 40px; margin: 40px 0; border-radius: 0 12px 12px 0; font-weight: 800; color: #2c1b54; font-size: 20px; line-height: 1.5; font-style: normal; border-right: none; border-top: none; border-bottom: none; }

  .sidebar-widget { margin-bottom: 56px; }
  .widget-title { font-size: 12px; color: #888; letter-spacing: 0.1em; text-transform: uppercase; border-bottom: 1px solid #eaeaea; padding-bottom: 12.8px; margin-bottom: 24px; font-weight: bold; }
  .related-article-card { margin-bottom: 24px; }
  .related-category { display: block; font-size: 11.2px; color: #5c43d6; font-weight: bold; text-transform: uppercase; margin-bottom: 6.4px; }
  .related-title { display: block; font-weight: 900; font-size: 16.8px; color: #1a1a1a; text-decoration: none; margin-bottom: 6.4px; line-height: 1.3; }
  .related-title:hover { color: #5c43d6; }
  .related-date { font-size: 12.8px; color: #888; }
  
  .newsletter-widget { background: #eeebff; padding: 40px 32px; border-radius: 12px; text-align: left; }
  .newsletter-widget h3 { margin: 0 0 12.8px 0; font-size: 19.2px; color: #1a1a1a; font-weight: 900; }
  .newsletter-widget p { font-size: 14.4px; color: #555; margin-bottom: 24px; line-height: 1.5; }
  .newsletter-form input { width: 100%; padding: 14.4px; border: 1px solid #e0e0e0; border-radius: 4px; margin-bottom: 12.8px; box-sizing: border-box; }
  .newsletter-form button { width: 100%; padding: 14.4px; background: #5c43d6; color: white; border: none; border-radius: 4px; font-weight: bold; cursor: pointer; transition: background 0.2s; }
  .newsletter-form button:hover { background: #4a35a8; }

  .article-bottom-tags { display: flex; flex-wrap: wrap; gap: 9.6px; margin: 64px 0 48px; border-top: 1px solid #eaeaea; padding-top: 48px; }
  .tag-pill { border: 1px solid #ccc; padding: 8px 19.2px; border-radius: 4px; font-size: 13.6px; color: #555; text-decoration: none; transition: all 0.2s; }
  .tag-pill:hover { border-color: #5c43d6; color: #5c43d6; }

  .article-bottom-share { display: flex; align-items: center; gap: 16px; margin-bottom: 64px; flex-wrap: wrap; }
  .share-label { font-size: 14.4px; font-weight: bold; color: #1a1a1a; margin-right: 8px; }
  .share-btn { background: white; border: 1px solid #ccc; color: #333; padding: 8px 19.2px; border-radius: 4px; font-size: 13.6px; cursor: pointer; text-decoration: none; }
  .share-btn:hover { background: #f9f9f9; }

  /* --- NEW: MORE FROM THE JOURNAL STYLES --- */
  .article-more-from-journal { background: #f9f9f9; padding: 96px 0; margin-top: 64px; border-top: 1px solid #eaeaea; }
  .journal-header-wrap { display: flex; justify-content: space-between; align-items: flex-end; }
  .journal-header-left { display: flex; flex-direction: column; }
  .journal-kicker { font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.1em; font-weight: bold; margin-bottom: 8px; }
  /* .journal-title { font-size: 35.2px; font-weight: 900; margin: 0; color: #1a1a1a; line-height: 1.1; } */
  .journal-all-link { color: #5c43d6; text-decoration: none; font-weight: 500; font-size: 16px; transition: color 0.2s; }
  .journal-all-link:hover { color: #4a35a8; }
  
  .journal-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; padding-block:  24px; }
  @media (max-width: 900px) { .journal-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 650px) { 
    .journal-grid { grid-template-columns: 1fr; } 
    .journal-header-wrap { flex-direction: column; align-items: flex-start; gap: 16px; } 
  }
  
  .journal-card { position: relative; background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.03); border: 1px solid #f0f0f0; display: flex; flex-direction: column; transition: transform 0.2s, box-shadow 0.2s; }
  .journal-card:hover { transform: translateY(-4px); box-shadow: 0 8px 30px rgba(0,0,0,0.08); }
  .journal-card-image { aspect-ratio: 16/10; overflow: hidden; background: #f4f4f4; }
  .journal-card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .journal-card:hover .journal-card-image img { transform: scale(1.05); }
  .journal-card-content { padding: 28.8px; display: flex; flex-direction: column; flex-grow: 1; }
  .journal-card-category { font-size: 12px; color: #5c43d6; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12.8px; display: block; }
  .journal-card-title { font-size: 20px; font-weight: 800; margin: 0 0 24px 0; line-height: 1.35; }
  .journal-card-title a { text-decoration: none; color: #1a1a1a; }
  .journal-card-title a:before { content: ""; position: absolute; inset: 0; } /* Makes entire card clickable */
  .journal-card-date { font-size: 13.6px; color: #888; margin-top: auto; }
{%- endstyle -%}

{%- assign reading_time = article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
{%- assign author_names = article.author | split: ' ' -%}
{%- assign author_initials = '' -%}
{%- for name in author_names limit: 2 -%}
  {%- assign initial = name | slice: 0 | upcase -%}
  {%- assign author_initials = author_initials | append: initial -%}
{%- endfor -%}

<article class="article-template" itemscope itemtype="http://schema.org/BlogPosting">
  
  <!-- Custom Header -->
  <header class="custom-article-header page-width{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {% if article.tags.size > 0 %}
      <div class="article-category-badge">{{ article.tags.first }}</div>
    {% endif %}
    
    <h1 class="article-template__title" itemprop="headline">{{ article.title | escape }}</h1>
    
    {% if article.excerpt.size > 0 %}
      <p class="article-excerpt">{{ article.excerpt | strip_html }}</p>
    {% endif %}

    <div class="article-meta-row">
      <div class="article-author-info">
        <div class="author-avatar">{{ author_initials }}</div>
        <div class="author-details">
          <span class="author-name" itemprop="author">{{ article.author }}</span>
          <span class="meta-details">
            {{ article.published_at | date: "%-d %B %Y" }} · {{ reading_time }} min read {% if article.tags.size > 0 %}· {{ article.tags.first }}{% endif %}
          </span>
        </div>
      </div>
      <div class="article-actions">
        <button class="btn-secondary" onclick="window.print()">Save</button>
        <button class="btn-secondary" onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!');">Share</button>
      </div>
    </div>
  </header>

  <!-- Hero Image -->
  {%- if article.image -%}
    <div class="article-image-wrapper{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
      <img
        srcset="
          {% if article.image.width >= 350 %}{{ article.image | image_url: width: 350 }} 350w,{% endif %}
          {% if article.image.width >= 750 %}{{ article.image | image_url: width: 750 }} 750w,{% endif %}
          {% if article.image.width >= 1100 %}{{ article.image | image_url: width: 1100 }} 1100w,{% endif %}
          {% if article.image.width >= 1500 %}{{ article.image | image_url: width: 1500 }} 1500w,{% endif %}
          {% if article.image.width >= 2200 %}{{ article.image | image_url: width: 2200 }} 2200w,{% endif %}
          {{ article.image | image_url }} {{ article.image.width }}w
        "
        sizes="(min-width: 1200px) 1200px, 100vw"
        src="{{ article.image | image_url: width: 1200 }}"
        loading="eager"
        fetchpriority="high"
        width="{{ article.image.width }}"
        height="{{ article.image.height }}"
        alt="{{ article.image.alt | escape }}"
      >
    </div>
  {%- endif -%}

  <!-- Main 2-Column Layout -->
  <div class="article-main-grid{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    
    <!-- Left Column: Content -->
    <div class="article-content-column">
      <div class="rte" itemprop="articleBody">
        {{ article.content }}
      </div>

      <!-- Bottom Tags -->
      {% if article.tags.size > 0 %}
        <div class="article-bottom-tags">
          {% for tag in article.tags %}
            <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="tag-pill">{{ tag }}</a>
          {% endfor %}
        </div>
      {% endif %}

      <!-- Bottom Share -->
      <div class="article-bottom-share">
        <span class="share-label">Share this article</span>
        <a href="https://www.facebook.com/sharer.php?u={{ shop.url | append: article.url }}" target="_blank" class="share-btn">Facebook</a>
        <a href="https://api.whatsapp.com/send?text={{ shop.url | append: article.url }}" target="_blank" class="share-btn">WhatsApp</a>
        <button onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!');" class="share-btn">Copy link</button>
      </div>
    </div>

    <!-- Right Column: Sidebar -->
    <aside class="article-sidebar-column">
      
      <!-- Related Articles -->
      <div class="sidebar-widget">
        <h3 class="widget-title">Related Articles</h3>
        {%- assign recent_articles = blog.articles | limit: 4 -%}
        {%- assign article_count = 0 -%}
        {%- for recent_article in recent_articles -%}
          {%- if recent_article.id != article.id and article_count < 3 -%}
            <div class="related-article-card">
              <span class="related-category">{{ recent_article.tags.first | default: blog.title }}</span>
              <a href="{{ recent_article.url }}" class="related-title">{{ recent_article.title }}</a>
              <span class="related-date">{{ recent_article.published_at | date: "%-d %B %Y" }}</span>
            </div>
            {%- assign article_count = article_count | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Newsletter Box -->
      <div class="sidebar-widget newsletter-widget">
        <h3>Get New Recipes by Email</h3>
        <p>New articles and menu updates, once a week. No spam.</p>
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input 
            type="email" 
            name="contact[email]" 
            placeholder="Your email address" 
            aria-label="Email address"
            required>
          <button type="submit">Subscribe</button>
        {% endform %}
      </div>

    </aside>
  </div>
  
  <!-- Back to blog button -->
  {% comment %} <div class="article-template__back element-margin-top center page-width">
    <a href="{{ blog.url }}" class="article-template__link link animate-arrow">
      <span class="icon-wrap">
        <span class="svg-wrapper">
          {{- 'icon-arrow.svg' | inline_asset_content -}}
        </span>
      </span>
      {{ 'blogs.article.back_to_blog' | t: title: blog.title | escape }}
    </a>
  </div> {% endcomment %}

  <!-- Comments section -->
  {%- if blog.comments_enabled? -%}
    <div class="article-template__comment-wrapper background-secondary">
      <div id="comments" class="page-width page-width--narrow">
        {%- if article.comments_count > 0 -%}
          {%- assign anchorId = '#Comments-' | append: article.id -%}
          <h2 id="Comments-{{ article.id }}" tabindex="-1">{{ 'blogs.article.comments' | t: count: article.comments_count }}</h2>
          {% paginate article.comments by 5 %}
            <div class="article-template__comments">
              {%- if comment.status == 'pending' and comment.content -%}
                <article id="{{ comment.id }}" class="article-template__comments-comment">
                  {{ comment.content }}
                  <footer class="right"><span class="circle-divider caption-with-letter-spacing">{{ comment.author }}</span></footer>
                </article>
              {%- endif -%}
              {%- for comment in article.comments -%}
                <article id="{{ comment.id }}" class="article-template__comments-comment">
                  {{ comment.content }}
                  <footer class="right">
                    <span class="circle-divider caption-with-letter-spacing">{{ comment.author }}</span>
                    <span class="caption-with-letter-spacing">{{- comment.created_at | time_tag: format: 'date' -}}</span>
                  </footer>
                </article>
              {%- endfor -%}
              {% render 'pagination', paginate: paginate, anchor: anchorId %}
            </div>
          {% endpaginate %}
        {%- endif -%}
        
        {% form 'new_comment', article %}
          {%- liquid
            assign post_message = 'blogs.article.success'
            if blog.moderated? and comment.status == 'unapproved'
              assign post_message = 'blogs.article.success_moderated'
            endif
          -%}
          <h2>{{ 'blogs.article.comment_form_title' | t }}</h2>
          {%- if form.errors -%}
            <div class="form__message" role="alert">
              <h3 class="form-status caption-large text-body" tabindex="-1" autofocus>
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span> {{ 'templates.contact.form.error_heading' | t }}
              </h3>
            </div>
            <ul class="form-status-list caption-large">
              {%- for field in form.errors -%}
                <li>
                  <a href="#CommentForm-{{ field }}" class="link">
                    {%- if form.errors.translated_fields[field] contains 'author' -%}{{ 'blogs.article.name' | t }}
                    {%- elsif form.errors.translated_fields[field] contains 'body' -%}{{ 'blogs.article.message' | t }}
                    {%- else -%}{{ form.errors.translated_fields[field] }}{%- endif -%}
                    {{ form.errors.messages[field] }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- elsif form.posted_successfully? -%}
            <div class="form-status-list form__message" role="status">
              <h3 class="form-status" tabindex="-1" autofocus>
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span> {{ post_message | t }}
              </h3>
            </div>
          {%- endif -%}

          <div {% if blog.moderated? == false %}class="article-template__comments-fields"{% endif %}>
            <div class="article-template__comment-fields">
              <div class="field field--with-error">
                <input type="text" name="comment[author]" id="CommentForm-author" class="field__input" autocomplete="name" value="{{ form.author }}" aria-required="true" required placeholder="{{ 'blogs.article.name' | t }}">
                <label class="field__label" for="CommentForm-author">{{- 'blogs.article.name' | t }} <span aria-hidden="true">*</span></label>
              </div>
              <div class="field field--with-error">
                <input type="email" name="comment[email]" id="CommentForm-email" autocomplete="email" class="field__input" value="{{ form.email }}" autocorrect="off" autocapitalize="off" aria-required="true" required placeholder="{{ 'blogs.article.email' | t }}">
                <label class="field__label" for="CommentForm-email">{{- 'blogs.article.email' | t }} <span aria-hidden="true">*</span></label>
              </div>
            </div>
            <div class="field field--with-error">
              <textarea rows="5" name="comment[body]" id="CommentForm-body" class="text-area field__input" aria-required="true" required placeholder="{{ 'blogs.article.message' | t }}">{{ form.body }}</textarea>
              <label class="form__label field__label" for="CommentForm-body">{{- 'blogs.article.message' | t }} <span aria-hidden="true">*</span></label>
            </div>
          </div>
          {%- if blog.moderated? -%}
            <p class="article-template__comment-warning caption">{{ 'blogs.article.moderated' | t }}</p>
          {%- endif -%}
          <input type="submit" class="button" value="{{ 'blogs.article.post' | t }}">
        {% endform %}
      </div>
    </div>
  {%- endif -%}
</article>

<!-- NEW: More from the Journal Section -->
<div class="article-more-from-journal{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="journal-header-wrap page-width">
    <div class="journal-header-left">
      <span class="journal-kicker">Continue Reading</span>
      <h2 class="journal-title h2">More from the Journal</h2>
    </div>
    <a href="{{ blog.url }}" class="journal-all-link">All articles &rarr;</a>
  </div>
  
  <div class="journal-grid page-width">
    {%- assign current_article_id = article.id -%}
    {%- assign count = 0 -%}
    {%- for related_article in blog.articles -%}
      {%- if related_article.id != current_article_id and count < 3 -%}
        <div class="journal-card">
          <div class="journal-card-image">
            {%- if related_article.image -%}
              <img src="{{ related_article.image | image_url: width: 600 }}" alt="{{ related_article.image.alt | escape }}" loading="lazy" width="600" height="375">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="journal-card-content">
            <span class="journal-card-category">{{ related_article.tags.first | default: blog.title }}</span>
            <h3 class="journal-card-title"><a href="{{ related_article.url }}">{{ related_article.title }}</a></h3>
            <span class="journal-card-date">{{ related_article.published_at | date: "%-d %B %Y" }}</span>
          </div>
        </div>
        {%- assign count = count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "tag": "section",
  "class": "section"
}
{% endschema %}