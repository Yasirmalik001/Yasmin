{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }} {
    --columns-desktop: {{ section.settings.columns_desktop }};
    --columns-mobile: {{ section.settings.columns_mobile }};
    --gap-desktop: {{ section.settings.spacing }}px;
    --gap-mobile: {{ section.settings.spacing | divided_by: 1.5 }}px;
  }

  .section-{{ section.id }} .slider-template-section__swiper {
    overflow: {% if section.settings.overflow %}visible{% else %}hidden{% endif %};
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* --- TABS & BUTTON STYLES --- */
  .custom-menu-header { margin-bottom: 24px; }
  .menu-overline { font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #4A3B8C; margin-bottom: 5px; font-weight: 700; }
  .menu-title-row { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px; }
  .menu-view-all { font-family: DM Sans;
  font-weight: 500;
  font-style: Medium;
  font-size: 14px;
  leading-trim: NONE;
  line-height: 22.4px;
  color: #534AB7;
  letter-spacing: 0px;
  ; text-decoration: none; font-weight: 600; display: flex; align-items: center; gap: 5px; }
  .menu-tabs { 
    display: flex; 
    gap: 12px; 
    overflow-x: auto; 
    scrollbar-width: none; 
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }
  .menu-tabs::-webkit-scrollbar { display: none; }

  @media screen and (max-width: 749px) {
    .menu-tabs {
      margin-left: -1.5rem !important;
      margin-right: -1.5rem !important;
      padding-left: 1.5rem !important;
      padding-right: 1.5rem !important;
      scroll-padding-left: 1.5rem;
    }
  }

  .menu-tab { 
    padding: 12px 16px; 
    border-radius: 30px; 
    border: 1px solid #E5E5E5; 
    background: #fff; 
    font-family: Barlow;
    font-weight: 700;
    font-style: Bold;
    font-size: 11px;
    leading-trim: NONE;
    line-height: 16.5px;
    letter-spacing: 0.5px;
    color: black;
    text-transform: uppercase;
    cursor: pointer; 
    white-space: nowrap; 
    transition: all 0.3s ease; 
    letter-spacing: 0.5px;
    flex-shrink: 0;
    scroll-snap-align: start;
  }
  .menu-tab.active { background: #4A3B8C; color: #fff; border-color: #4A3B8C; }

{%- endstyle -%}

{%- liquid
  assign products_to_display = section.settings.collection.all_products_count

  if section.settings.collection.all_products_count > section.settings.products_to_show
    assign products_to_display = section.settings.products_to_show
    assign more_in_collection = true
  endif

  assign columns_mobile_int = section.settings.columns_mobile | plus: 0
  assign columns_desktop_int = section.settings.columns_desktop | plus: 0

  assign max_columns_to_show = columns_mobile_int
  if columns_desktop_int > columns_mobile_int
    assign max_columns_to_show = columns_desktop_int
  endif

  assign mobile_slide_class = 'swiper-slide--multi'
  assign mobile_swiper_slides = 2
  if section.settings.columns_mobile == '1'
    assign mobile_slide_class = 'swiper-slide--single'
    assign mobile_swiper_slides = 1.5
  endif
-%}

<div class="section-{{ section.id }} color-{{ section.settings.color_scheme }} isolate gradient {% if section.settings.overflow %}slider-template-section__overflow-hidden{% endif %}">
  <div
    class="collection{% if section.settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding{% if section.settings.full_width %} collection--full-width{% endif %} {% unless section.settings.full_width %}page-width{% endunless %}"
    id="collection-{{ section.id }}"
    data-id="{{ section.id }}"
  >
    <!-- CUSTOM DESIGNED TABS HEADER -->
    <div class="custom-menu-header {% if section.settings.enable_slider_mobile %} title-wrapper--self-padded-tablet-down{% endif %}">
      <p class="menu-overline">{{ section.settings.overline_text | default: "THIS WEEK'S MENU" }}</p>
      
      <div class="menu-title-row">
        {%- if section.settings.title != blank -%}
          <h2 class="title inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}

        <div class="view-all__icons" style="display: flex; align-items: center; gap: 15px;">
      {%- if section.settings.show_view_all -%}
  <a href="{{ section.settings.button_link }}" class="menu-view-all {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ section.settings.button_label }} 
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
      <path d="M2.91541 6.99707H11.0786" stroke="#534AB7" stroke-width="1.16618" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M6.99707 2.91504L11.0787 6.99665L6.99707 11.0783" stroke="#534AB7" stroke-width="1.16618" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
{%- endif -%}

          {%- if section.settings.controls_position == 'bottom' or section.settings.controls_position == 'middle' -%}
            <div class="slider-template-controls-nav">
              <button type="button" class="slider-template-arrow js-slider-template-prev" aria-label="{{ 'general.slider.previous_slide' | t }}">
                {% render 'svg-icons', svg-icons: 'ma-caret-left' %}
              </button>
              <button type="button" class="slider-template-arrow js-slider-template-next" aria-label="{{ 'general.slider.next_slide' | t }}">
                {% render 'svg-icons', svg-icons: 'ma-caret-right' %}
              </button>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- DYNAMIC TABS GENERATED FROM BLOCKS -->
      {%- if section.blocks.size > 0 -%}
        <div class="menu-tabs js-menu-tabs">
          {%- for block in section.blocks -%}
            <button 
              class="menu-tab {% if forloop.first %}active{% endif %}" 
              data-target="tab-{{ block.id }}" 
              {{ block.shopify_attributes }}
            >
              {{ block.settings.title | default: block.settings.collection.title | default: 'Collection' }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.description != blank or section.settings.show_description and section.settings.collection.description != empty -%}
        <div class="collection__description {{ section.settings.description_style }} rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          {%- if section.settings.show_description -%}
            {{ section.settings.collection.description }}
          {%- else -%}
            {{ section.settings.description -}}
          {%- endif %}
        </div>
      {%- endif -%}
    </div>
    <!-- END TABS HEADER -->

    <div class="collection-tab-contents">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div id="tab-{{ block.id }}" class="collection-tab-content" {% unless forloop.first %}style="display: none;"{% endunless %}>
            <slider-container class="slider-template-section block" data-block-id="{{ block.id }}">
              <div class="slider-template-section__container">
                <div
                  class="swiper js-slider-template-swiper slider-template-section__swiper"
                  data-swiper-config='
                    {
                      "enableSliderDesktop": {{ section.settings.enable_slider_desktop }},
                      "enableSliderMobile": {{ section.settings.enable_slider_mobile }},
                      "loop": {{ section.settings.enable_loop | default: false }},
                      "autoplay": {{ section.settings.enable_autoplay | default: false }},
                      "autoplayInterval": {{ section.settings.autoplay_interval | times: 1000 | default: 3000 }},
                      "mobileSlides": {{ mobile_swiper_slides }},
                      "mobileSpacing": {{ section.settings.spacing | divided_by: 1.5 }},
                      "desktopSlides": {{ section.settings.columns_desktop }},
                      "desktopSpacing": {{ section.settings.spacing }}
                    }
                  '
                >
                  <div class="swiper-wrapper">
                    {% assign skip_card_product_styles = false %}

                    {%- if block.settings.collection != blank and block.settings.collection.products.size > 0 -%}
                      {% assign lazy_load = false %}
                      {%- for product in block.settings.collection.products limit: section.settings.products_to_show -%}
                        {% if lazy_load == false and forloop.index > max_columns_to_show %}
                          {% assign lazy_load = true %}
                        {% endif %}
                        
                        <div
                          class="swiper-slide {{ mobile_slide_class }}"
                          {% if settings.animations_reveal_on_scroll %}
                            data-cascade
                            style="--animation-order: {{ forloop.index }};"
                          {% endif %}
                        >
                          {% render 'card-collection-product',
                            card_product: product,
                            media_aspect_ratio: section.settings.image_ratio,
                            image_shape: section.settings.image_shape,
                            lazy_load: lazy_load,
                            show_secondary_image: section.settings.show_secondary_image,
                            show_vendor: section.settings.show_vendor,
                            show_rating: section.settings.show_rating,
                            skip_styles: skip_card_product_styles,
                            section_id: section.id,
                            quick_add: section.settings.quick_add
                          %}
                        </div>
                        {%- assign skip_card_product_styles = true -%}
                      {%- endfor -%}
                    {%- else -%}
                      {%- for i in (1..section.settings.columns_desktop) -%}
                        <div
                          class="swiper-slide {{ mobile_slide_class }}"
                          {% if settings.animations_reveal_on_scroll %}
                            data-cascade
                            style="--animation-order: {{ forloop.index }};"
                          {% endif %}
                        >
                          {% liquid
                            assign ridx = forloop.rindex
                            case ridx
                              when 5
                                assign ridx = 1
                              when 6
                                assign ridx = 2
                            endcase
                          %}
                          {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                          {% render 'card-product',
                            show_vendor: section.settings.show_vendor,
                            media_aspect_ratio: section.settings.image_ratio,
                            image_shape: section.settings.image_shape,
                            lazy_load: false,
                            placeholder_image: placeholder_image
                          %}
                        </div>
                      {%- endfor -%}
                    {%- endif -%}
                  </div>
                </div>

                <div
                  class="
                    slider-template-controls
                    slider-template-controls--{{ section.settings.controls_position }}
                    {% unless section.settings.show_controls_desktop %}slider-template--hide-desktop{% endunless %}
                    {% unless section.settings.show_controls_mobile %}slider-template--hide-mobile{% endunless %}
                  "
                >
                  {%- if section.settings.controls_position == 'bottom' -%}
                    <div class="slider-template-progress-track">
                      <div class="slider-template-progress-fill"></div>
                    </div>
                  {%- endif -%}

                  {%- if section.settings.controls_position == 'dots' -%}
                    <div class="slider-template-pagination"></div>
                  {%- endif -%}

                </div>

                {%- if section.settings.controls_position == 'dots' -%}
                  <div
                    class="
                      slider-template-controls
                      slider-template-controls--middle
                      {% unless section.settings.show_controls_desktop %}slider-template--hide-desktop{% endunless %}
                    "
                  >
                    {% comment %} <div class="slider-template-controls-nav">
                      <button
                        type="button"
                        class="slider-template-arrow js-slider-template-prev"
                        aria-label="{{ 'general.slider.previous_slide' | t }}"
                      >
                        {% render 'svg-icons', svg-icons: 'ma-caret-left' %}
                      </button>
                      <button
                        type="button"
                        class="slider-template-arrow js-slider-template-next"
                        aria-label="{{ 'general.slider.next_slide' | t }}"
                      >
                        {% render 'svg-icons', svg-icons: 'ma-caret-right' %}
                      </button>
                    </div> {% endcomment %}
                  </div>
                {%- endif -%}
              </div>
            </slider-container>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all and more_in_collection -%}
      <div class="view-all_mobile-show center collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        <a
          href="{{ section.settings.collection.url }}"
          class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
          aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.collection.title | escape }}"
        >
          {{ 'sections.featured_collection.view_all' | t }}
        </a>
      </div>
    {%- endif -%}

    {% if section.settings.image_shape == 'arch' %}
      {{ 'mask-arch.svg' | inline_asset_content }}
    {%- endif -%}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sectionBlock = document.getElementById('collection-{{ section.id }}');
    if (!sectionBlock) return;

    const tabs = sectionBlock.querySelectorAll('.menu-tab');
    const tabContents = sectionBlock.querySelectorAll('.collection-tab-content');

    tabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        tabs.forEach(t => t.classList.remove('active'));
        e.target.classList.add('active');

        const targetId = e.target.getAttribute('data-target');
        
        tabContents.forEach(content => {
          if (content.id === targetId) {
            content.style.display = 'block';
            // Re-initialize swiper if needed, though they usually auto-update
            const swiperContainer = content.querySelector('.js-slider-template-swiper');
            if (swiperContainer && swiperContainer.swiper) {
              swiperContainer.swiper.update();
            }
          } else {
            content.style.display = 'none';
          }
        });
      });
    });
  });
</script>

