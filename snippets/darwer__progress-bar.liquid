{% if settings.free_gift or settings.free_shipping %}

{% assign show_shipping_bar = settings.free_shipping %}
{% assign swap_layout = false %}
{% assign use_fixed_positions = settings.fixed_icon_positions | default: false %}

{% assign free_shipping_minimum = settings.free_shipping_minimum | times: 100 %}
{% assign free_gift_minimum = settings.free_gift_minimum | times: 100 %}

<free-shipping class="cart-drawer__progress-bar {% if swap_layout %}layout-swapped{% endif %}"
  data-cart-total="{{ cart.total_price }}"
  data-minimum="{{ free_shipping_minimum }}"
  data-gift-minimum="{{ free_gift_minimum }}"
  data-gift-variant-id="{{ all_products[settings.free_gift_product].selected_or_first_available_variant.id }}"
  data-show-gift="{{ settings.free_gift | json }}"
  data-show-shipping="{{ show_shipping_bar | json }}"
  data-fixed-icons="{{ use_fixed_positions }}"
  data-locale="{{ localization.language.iso_code }}-{{ localization.country.iso_code }}"
  data-currency="{{ localization.country.currency.iso_code }}"
  data-gift-notification-text="{{ 'sections.cart.free_gift_added' | t | escape }}"
  style="{% if settings.free_shipping_text != blank or settings.free_gift_texts != blank %}margin-bottom: 4.4rem;{% endif %}"
>
  <div class="cart-drawer__progress-text">
    <div class="cart-drawer__progress-messages--shipping cart-drawer__hidden">
      <div class="cart-drawer__progress-text-remaining">
        {{ settings.free_shipping_not_met | replace: 'amount', '<strong></strong>' }}
      </div>
      <div class="cart-drawer__progress-text-full">
        <span>{{ settings.free_shipping_met }}</span>
      </div>
    </div>

    {% if settings.free_gift %}
      <div class="cart-drawer__progress-messages--gift cart-drawer__hidden">
        <div class="cart-drawer__progress-text-remaining">
          {{ settings.free_gift_not_met | replace: 'amount', '<strong></strong>' }}
        </div>
        <div class="cart-drawer__progress-text-full">{{ settings.free_gift_met }}</div>
      </div>
    {% endif %}
  </div>

  <div class="cart-drawer__progress-bar-container">
    {% if show_shipping_bar %}
      <div class="cart-drawer__progress-milestone cart-drawer__progress-milestone--shipping cart-drawer__hidden">
        {%- if settings.free_shipping_icon != blank -%}
          <img src="{{ settings.free_shipping_icon | image_url: width: 34 }}" alt="{{ 'sections.cart.free_shipping_icon_alt' | t }}" loading="lazy" width="34" height="34">
        {%- else -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
