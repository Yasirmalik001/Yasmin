            </g>
          </svg>
        {%- endif -%}
        <span>{{ settings.free_shipping_text }}</span>
      </div>
    {% endif %}

    {% if settings.free_gift %}
      <div class="cart-drawer__progress-milestone cart-drawer__progress-milestone--gift cart-drawer__hidden">
        {%- if settings.free_gift_icon != blank -%}
          <img src="{{ settings.free_gift_icon | image_url: width: 34 }}" alt="{{ 'sections.cart.free_gift_icon_alt' | t }}" loading="lazy" width="34" height="34">
        {%- else -%}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M128,18.4c60.4,0,109.6,49.2,109.6,109.6c0,60.4-49.2,109.6-109.6,109.6c-60.4,0-109.6-49.2-109.6-109.6C18.4,67.6,67.6,18.4,128,18.4 M128,10C62.8,10,10,62.8,10,128c0,65.2,52.8,118,118,118c65.2,0,118-52.8,118-118C246,62.8,193.2,10,128,10L128,10z"/>
            <path d="M171.4,90.8c1.8-2.9,3.4-6.7,3.1-10.6c-0.2-2.6-1.5-6.3-6-9.3c-3.8-2.5-8.6-3.1-14-1.7c-9.2,2.3-19.7,10.3-26.5,19.5c-6.8-9.2-17.3-17.2-26.5-19.5c-5.4-1.3-10.2-0.7-14,1.7c-4.5,3-5.7,6.7-6,9.2c-0.4,3.9,1.3,7.7,3.1,10.6h-4.9c-6.2,0-11.1,5-11.1,11.1v14.9c0,5.2,3.5,9.5,8.3,10.7c-0.5,1.3-0.8,2.7-0.8,4.1v44.6c0,6.1,5,11.2,11.1,11.2H128c0,0,40.9,0,40.9,0c6.1,0,11.1-5,11.1-11.2v-44.6c0-1.5-0.3-2.9-0.8-4.2c4.7-1.3,8.2-5.6,8.2-10.7V102c0-6.1-5-11.1-11.2-11.1L171.4,90.8L171.4,90.8z M156.3,76.4c3.3-0.9,6.1-0.6,8.1,0.7c2.2,1.4,2.6,2.8,2.6,3.7c0.4,3.7-3.6,8.5-5.1,9.9h-26.2C141.5,84,149.6,78.1,156.3,76.4L156.3,76.4L156.3,76.4z M88.9,80.9c0.1-0.9,0.5-2.3,2.7-3.7c2-1.3,4.7-1.6,8.1-0.7c6.7,1.7,14.8,7.6,20.5,14.4H94C92.5,89.3,88.5,84.5,88.9,80.9L88.9,80.9L88.9,80.9z M76.7,102.7c0-1.9,1.7-3.4,3.6-3.4h43.6v20.5H87.6h-7.3c-2,0-3.6-1.5-3.6-3.4V102.7L76.7,102.7L76.7,102.7z M84.9,175.6v-44c0-2,1.6-3.7,3.6-3.7h35.4v51.3H88.5C86.5,179.3,84.9,177.7,84.9,175.6L84.9,175.6L84.9,175.6z M171.1,175.6c0,2-1.6,3.7-3.5,3.7h-35.4V128h35.4c2,0,3.5,1.7,3.5,3.7V175.6L171.1,175.6L171.1,175.6z M179.3,116.4c0,1.9-1.6,3.4-3.6,3.4h-7.3h-36.3V99.3h43.6c2,0,3.6,1.5,3.6,3.4V116.4L179.3,116.4L179.3,116.4z"/>
