{% schema %}
  {
    "name": "t:weekly-menu-choices.name",
    "blocks": [ { "type": "@theme" } ],
    "settings": [
      {
        "type": "product",
        "id": "default_product",
        "label": "t:weekly-menu-choices.labels.default_product"
      }
    ],
    "presets": [
      { "name": "t:weekly-menu-choices.name" }
    ]
  }
{% endschema %}



{% javascript %}
class WeeklyMenuChoice extends HTMLElement {
  static observedAttributes = [ "days", "maximum-quantity" ];

  constructor() {
    const element = super();
    this.element = element;

    this.#setup();
    this.dishes = [...this.element.querySelectorAll("weekly-menu-dishes")];
  }

  connectedCallback() {
    this.quantities.forEach(quantityEl => {
      quantityEl.addEventListener("change", this.#recalculate.bind(this));
    });
  }

  disconnectedCallback() {
    this.quantities.forEach(quantityEl => {
      quantityEl.removeEventListener("change", this.#recalculate);
    });
  }

  attributeChangedCallback (name, oldValue, newValue) {
    if (name === "days" && oldValue) {
      this.#updatePrices();
      this.#rerenderDialogs();
    }

    if (name === "maximum-quantity" && oldValue) {
      const delta = parseInt(newValue, 10) - parseInt(oldValue, 10);
      if (delta > 0) {
        this.#addToDefault(delta);
      } else if (delta < 0) {
        this.#removeFromQuantities(Math.abs(delta));
      }
      this.#recalculate();
      this.element.closest("weekly-menu")?.dispatchEvent(new Event("change"));
    }
  }

  hide() {
    this.element.setAttribute("hidden", true);
  }

  show() {
    this.element.removeAttribute("hidden");
  }

  #setup() {
    this.weeklyMenus = [];
    this.quantities = [...this.element.querySelectorAll("weekly-menu-choice-quantity")];

    const productsEl = document.querySelector("script#weekly-menus-data");
    if (productsEl) {
      this.weeklyMenus = JSON.parse(productsEl.textContent);
    }

    setTimeout(() => {
      this.#recalculate();
    }, 100);
  }

  #updatePrices() {
    [...this.element.querySelectorAll(".weekly-menu-choice__product-price")].forEach(priceEl => {
      const productID = parseInt(priceEl.dataset.productId, 10);
      const product = this.products.find(product => product.id === productID);
      const productVariant = product.variants.find(variant => variant.title === this.days);
      priceEl.textContent = formatMoney(productVariant.price);
    });
  }

  #recalculate() {
    this.quantity = this.quantities.reduce((totalQuantity, quantityEl) => totalQuantity + quantityEl.quantity, 0);

    const atMax = this.quantity >= this.maximumQuantity;
    this.quantities.forEach(quantityEl => {
      quantityEl.increaseButtonEl.disabled = atMax;
    });
  }

  #addToDefault(amount) {
    const defaultEl = this.#defaultQuantityEl;
    if (!defaultEl) return;
    const maxAllowed = parseInt(defaultEl.inputFieldEl.max, 10) || 4;
    defaultEl.inputFieldEl.value = Math.min(defaultEl.quantity + amount, maxAllowed);
  }

  #removeFromQuantities(amount) {
    let remaining = amount;

    const defaultEl = this.#defaultQuantityEl;
    if (defaultEl && remaining > 0) {
      const canRemove = Math.min(defaultEl.quantity, remaining);
      defaultEl.inputFieldEl.value = defaultEl.quantity - canRemove;
      remaining -= canRemove;
    }

    if (remaining > 0) {
      for (const quantityEl of this.quantities) {
        if (quantityEl === defaultEl || remaining === 0) continue;
        const canRemove = Math.min(quantityEl.quantity, remaining);
        quantityEl.inputFieldEl.value = quantityEl.quantity - canRemove;
        remaining -= canRemove;
      }
    }
  }

  get #defaultQuantityEl() {
    const productId = this.defaultProductId;
    if (!productId) return null;
    const choice = this.element.querySelector(`.weekly-menu-choice[data-product-id="${productId}"]`);
    if (!choice) return null;
    return choice.querySelector("weekly-menu-choice-quantity");
  }

  #rerenderDialogs() {
    [...this.element.querySelectorAll("weekly-menu-dishes")].forEach((dish) => {
      const productId = dish.productId;
      const product = this.weeklyMenus.find(product => product.id === productId);
      const activeProductVariant = product.variants.find(variant => variant.title === this.days);

      [...dish.querySelectorAll("button")].forEach(button => {
        button.classList.toggle("visually-hidden", parseInt(button.dataset.variantId, 10) !== activeProductVariant.id)
      });
    });
  }

  get days() {
    return this.element.getAttribute("days");
  }

  get error() {
    return this.element.querySelector("weekly-menu-choice-error");
  }

  get isHidden() {
    return this.element.hidden;
  }

  get isValid() {
    return this.quantity === this.maximumQuantity;
  }

  get isVisible() {
    return !this.isHidden;
  }

  get week() {
    return parseInt(this.element.getAttribute("week"), 10);
  }

  get prices() {
    return this.element.querySelectorAll("");
  }

  get products() {
    return JSON.parse(this.element.closest("weekly-menu").querySelector("#weekly-menus-data").textContent);
  }

  get quantity() {
    return parseInt(this.element.getAttribute("quantity"), 10);
  }

  set quantity(value) {
    this.element.setAttribute("quantity", value);
  }

  get maximumQuantity() {
    return parseInt(this.element.getAttribute("maximum-quantity"), 10);
  }

  get defaultProductId() {
    const id = parseInt(this.element.getAttribute("default-product-id"), 10);
    return isNaN(id) ? null : id;
  }
}

class WeeklyMenuChoiceQuantity extends HTMLElement {
  constructor() {
    const element = super();
    this.element = element;

    this.inputFieldEl = this.element.querySelector(".weekly-menu-choice__input");
    this.increaseButtonEl = this.element.querySelector("button.weekly-menu-choice__control--increase");
    this.decreaseButtonEl = this.element.querySelector("button.weekly-menu-choice__control--decrease");
  }

  connectedCallback() {
    this.increaseButtonEl.addEventListener("click", this.increase.bind(this));
    this.decreaseButtonEl.addEventListener("click", this.decrease.bind(this));
  }

  disconnectedCallback() {
    this.increaseButtonEl.removeEventListener("click", this.increase);
    this.decreaseButtonEl.removeEventListener("click", this.decrease);
  }

  decrease() {
    if (this.quantity === 0) return;

    this.quantity = this.quantity - 1;
  }

  increase() {
    this.quantity = this.quantity + 1;
  }

  set quantity(value) {
    this.inputFieldEl.value = value;
    this.element.dispatchEvent(new Event("change"));
    this.element.closest("weekly-menu").dispatchEvent(new Event("change"));
  }

  get quantity() {
    return parseInt(this.inputFieldEl.value, 10);
  }

  get totalQuantity() {
    return parseInt(this.weeklyMenuChoice.getAttribute("quantity"), 10);
  }
}

class WeeklyMenuChoiceError extends HTMLElement {
  constructor() {
    const element = super();
    this.element = element;
  }

  show() {
    this.element.classList.remove("visually-hidden");
  }

  hide() {
    this.element.classList.add("visually-hidden");
  }
}

class WeeklyMenuDishes extends HTMLElement {
  static observedAttributes = [ "variant-id" ];

  constructor() {
    const element = super();
    this.element = element;
  }

  attributeChangedCallback (name, oldValue, newValue) {
    if (name === "variant-id" && oldValue) {
      [...this.element.querySelectorAll(".weekly-menu-dishes__show")].forEach(button => {
        button.classList.toggle("visually-hidden", button.dataset.variantId === this.getAttribute("variant-id"))
      });
    }
  }

  get productId() {
    return parseInt(this.element.getAttribute("product-id"), 10);
  }
}

class WeeklyMenuChoiceProgress extends HTMLElement {
  static #CIRCUMFERENCE = 2 * Math.PI * 5.5;

  connectedCallback() {
    this.innerHTML = `
      <svg class="weekly-menu-choice-progress__circle" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
        <circle class="weekly-menu-choice-progress__circle-track" cx="8" cy="8" r="5.5" fill="none" stroke-width="2"/>
        <circle class="weekly-menu-choice-progress__circle-fill" cx="8" cy="8" r="5.5" fill="none" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <span class="weekly-menu-choice-progress__count"></span>
    `;

    this.fillCircle = this.querySelector('.weekly-menu-choice-progress__circle-fill');
    this.countEl = this.querySelector('.weekly-menu-choice-progress__count');
    this.fillCircle.style.strokeDasharray = WeeklyMenuChoiceProgress.#CIRCUMFERENCE;

    this.#render();

    this.observer = new MutationObserver(() => this.#render());
    this.observer.observe(this.closest('weekly-menu-choice'), {
      attributes: true,
      attributeFilter: ['quantity', 'maximum-quantity']
    });
  }

  disconnectedCallback() {
    this.observer?.disconnect();
  }

  #render() {
    const parent = this.closest('weekly-menu-choice');
    const quantity = parseInt(parent.getAttribute('quantity'), 10) || 0;
    const max = parseInt(parent.getAttribute('maximum-quantity'), 10) || 0;
    const progress = max > 0 ? Math.min(quantity / max, 1) : 0;

    this.fillCircle.style.strokeDashoffset = WeeklyMenuChoiceProgress.#CIRCUMFERENCE * (1 - progress);
    this.countEl.textContent = (this.dataset.countTemplate || `${quantity}/${max}`)
      .replace('%quantity%', quantity)
      .replace('%max%', max);
  }
}

customElements.define('weekly-menu-choice', WeeklyMenuChoice);
customElements.define('weekly-menu-choice-quantity', WeeklyMenuChoiceQuantity);
customElements.define('weekly-menu-choice-error', WeeklyMenuChoiceError);
customElements.define('weekly-menu-choice-progress', WeeklyMenuChoiceProgress);
customElements.define('weekly-menu-dishes', WeeklyMenuDishes);
{% endjavascript %}
