<div
  id="block-{{ block.id }}"
  class="weekly-menu-choices"
  {{ block.shopify_attributes }}
>
  {% content_for 'blocks' %}

  <div class="mb-plan-info">
    <strong>Voor je plan van 12/24 weken:</strong> Je kiest nu de boxen voor de eerste 4 weken. Je keuzes voor de resterende weken kun je later eenvoudig aanpassen in je account — anders worden je selecties van week 4 automatisch herhaald.
  </div>

  <div class="mb-section-header" style="margin-top: 32px;">
    <h2 style="font-family: Barlow, sans-serif !important; font-size: 24px; font-weight: 800; margin: 0 0 0.5rem 0; color: #111827;">Kies je maaltijdboxen</h2>
    <p style="font-size: 14px; color: #6B7280; margin: 0;">Selecteer welke boxen je elke week wilt ontvangen. Je kunt zelf de aantallen bepalen — mix en match flexibel naar eigen smaak.</p>
  </div>

  <div class="mb-filters-title" style="font-size: 11px; font-weight: 700; color: #6B7280; text-transform: uppercase; margin-bottom: 12px; letter-spacing: 0.5px; margin-top:24px;">DIEETVOORKEUREN</div>
  <div class="mb-filters" style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 24px;">
    <span class="mb-filter-tag vegetarian">Vegetarisch</span>
    <span class="mb-filter-tag gluten-free">Glutenvrij</span>
    <span class="mb-filter-tag lactose-free">Lactosevrij</span>
    <span class="mb-filter-tag meat-based">Met vlees</span>
    <span class="mb-filter-tag vegan">Veganistisch</span>
  </div>

  {% for collection_product in closest.collection.products %}
    {%- assign product = all_products[collection_product.handle] -%}
    {% for variant in product.variants %}
      {% assign components = variant.metafields.custom.variant_components %}

      <dialog class="weekly-menu-dishes__dialog" id="dish-{{ variant.id }}" popover>
        <div class="weekly-menu-dishes__dialog-content">
          {%- assign all_types = components.value | map: 'type' | uniq -%}
          {%- for component_type in all_types -%}
            {%- assign typed_components = components.value | where: 'type', component_type -%}
            {%- if component_type != blank -%}
              <h6 class="weekly-menu-dishes__type-heading">{{ component_type }}</h6>
            {%- endif -%}
            <ul class="weekly-menu-dishes__list">
              {%- for component in typed_components -%}
                <li class="weekly-menu-dishes__dish">
                  <div class="weekly-menu-dishes__dish-image">
                    {{ component.featured_image | image_url: width: 80 | image_tag: alt: component.title }}
                  </div>

                  <div class="weekly-menu-dishes__dish-information">
                    <p>{{ component.title }}</p>
                  </div>
                </li>
              {%- endfor -%}
            </ul>
          {%- endfor -%}
        </div>
      </dialog>
    {% endfor %}
  {% endfor %}

  <weekly-menu-choice week="1" maximum-quantity="1" days="5" quantity="1" default-product-id="{{ block.settings.default_product.id }}">
    <weekly-menu-choice-error class="visually-hidden">
      <svg viewBox="0 0 20 20" fill="currentColor" data-slot="icon" aria-hidden="true">
        <path d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" fill-rule="evenodd" />
      </svg>

      <p>{{ "blocks.weekly-menu-choices.error" | t: week: 1 }}</p>
    </weekly-menu-choice-error>

    <div class="weekly-menu-choice__header mb-week-header">
      <h3 class="weekly-menu-choice__title mb-week-title">{{ "blocks.weekly-menu-choices.week_one" | t }}</h3>
      <weekly-menu-choice-progress data-count-template="{{ 'blocks.weekly-menu-choices.progress' | t: quantity: '%quantity%', max: '%max%' }}"></weekly-menu-choice-progress>
    </div>

    <div class="weekly-menu-choice__options mb-grid">
      {% for product in closest.collection.products %}
        <div class="weekly-menu-choice mb-product" data-product-id="{{ product.id }}">
          <div class="mb-product-cc">
            <div class="weekly-menu-choice__thumbnail mb-product__img-wrapper">
              {{ product.featured_image | image_url: width: 300 | image_tag: alt: product.title, class: 'mb-product__img' }}
            </div>

            <div class="weekly-menu-choice__product mb-product__content">
              <span class="weekly-menu-choice__product-name mb-product__title">{{ product.title }}</span>
              <div class="mb-product__footer">
                <span class="weekly-menu-choice__product-price mb-product__price" data-product-id="{{ product.id }}">{{ product.price | money }}</span>

                <weekly-menu-choice-quantity class="weekly-menu-choice__input-group mb-qty">
                  <button class="weekly-menu-choice__control weekly-menu-choice__control--decrease mb-qty__minus" type="button">-</button>
                  <input class="weekly-menu-choice__input mb-qty__input" name="weekly_menu[week_one][{{product.id}}]" type="number" step="1" min="0" max="4" value="{%- if product == block.settings.default_product -%}1{%- else -%}0{%- endif -%}" readonly />
                  <button class="weekly-menu-choice__control weekly-menu-choice__control--increase mb-qty__plus" type="button">+</button>
                </weekly-menu-choice-quantity>
              </div>
            </div>
          </div>

          <weekly-menu-dishes product-id="{{ product.id }}">
            {% for variant in product.variants %}
              <button class="weekly-menu-dishes__show mb-product__link {% unless forloop.first %} visually-hidden{% endunless %}" popovertarget="dish-{{ variant.id }}" data-variant-id="{{ variant.id }}">
                {{ "blocks.weekly-menu-choices.show_dishes" | t }}
              </button>
            {% endfor %}
          </weekly-menu-dishes>
        </div>
      {% endfor %}
    </div>
  </weekly-menu-choice>

  <weekly-menu-choice week="2" maximum-quantity="1" days="5" quantity="1" hidden default-product-id="{{ block.settings.default_product.id }}">
    <weekly-menu-choice-error class="visually-hidden">
