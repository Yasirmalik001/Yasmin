{% assign delivery_date = cart.attributes['Delivery Date'] %}
{% assign delivery_day = cart.attributes['Delivery Day'] %}
{% assign formatted_delivery_date = delivery_date | date: '%Y-%m-%d' %}

<div class="delivery-picker-container">
  <h2 class="delivery-picker-title">Waar bezorgen wij?</h2>
  <p class="delivery-picker-subtitle">Vul je postcode in om je bezorgzone te controleren — dit is verplicht om verder te gaan.</p>

  <delivery-picker
    id="section-{{ block.id }}"
    delivery-date="{{ delivery_date }}"
    delivery-day="{{ delivery_day }}"
    {% if block.settings.restrict_next_week_until_wednesday %}restrict-next-week{% endif %}
    {{ block.shopify_attributes }}
  >
    <div class="delivery-picker delivery-picker-card">
      
      <p class="delivery-picker__error" role="alert">{{ "sections.delivery-picker.errors.required" | t }}</p>

      <div class="step-and-form-row">
        
        <div class="delivery-picker-step">
          <span class="step-text">STAP 1 — VUL JE POSTCODE IN</span>
          <span class="step-badge">VERPLICHT</span>
        </div>

        <div class="delivery-zone__form">
          <template id="delivery-zone-unavailable">
            <p class="delivery-zone__feedback delivery-zone__feedback--unavailable">{{ "sections.delivery-picker.feedback.unavailable" }}</p>
          </template>

          <form class="delivery-picker-form-group">
            <div class="input-col country-col">
              <label for="delivery_zone_country" class="visually-hidden">{{ "sections.delivery-picker.labels.country" }}</label>
              <select id="delivery_zone_country" name="delivery_zone[country]" class="custom-select" required>
                <option value="NL">NL</option>
                <option value="BE">BE</option>
                <option value="DE">DE</option>
              </select>
            </div>

            <div class="input-col zip-col">
              <label for="delivery_zone_zip_code" class="visually-hidden">{{ "sections.delivery-picker.labels.zip_code" }}</label>
              <input id="delivery_zone_zip_code" name="delivery_zone[zip_code]" type="text" class="custom-input" placeholder="1024" required />
            </div>

            <button type="submit" class="button custom-check-btn">
              <span>Check</span>
              <span>&rarr;</span>
            </button>
          </form>

          <div class="delivery-zone__form-feedback"></div>
        </div>
      </div>

      <div class="delivery-zones delivery-zones-custom {% if delivery_date == blank %} visually-hidden {% endif %}">
        {% for i in (2..block.settings.max_days_ahead) %}
          {% assign offset_seconds = i | times: 86400 %}
          {% assign future_timestamp = "now" | date: "%s" | plus: offset_seconds %}

          {% assign weekday_name     = future_timestamp | date: '%A' %}
          {% assign weekday_key      = weekday_name | downcase %}
          {% assign weekday_t_key    = 'sections.delivery-picker.days.' | append: weekday_key %}
          {% assign date_label       = future_timestamp | date: '%e %B' %}
          {% assign machine_date     = future_timestamp | date: '%Y-%m-%d' %}

          <button
            type="button"
            class="delivery-zone custom-zone-btn {% if formatted_delivery_date == machine_date %} delivery-zone--active {% endif %}"
            data-delivery-date="{{ machine_date }}"
            data-delivery-day="{{ weekday_key }}"
            data-delivery-offset="{{ i }}"
          >
            <span class="delivery-zone__day custom-zone-day">{{ weekday_t_key | t }}</span>
            <span class="delivery-zone__date custom-zone-date">{{ date_label }}</span>
          </button>
        {% endfor %}
      </div>
    </div>
  </delivery-picker>

  <div class="delivery-picker-footer">
    <span class="footer-label">Wij bezorgen in:</span>
    <span class="footer-badge">🇳🇱 Netherlands</span>
    <span class="footer-badge">🇩🇪 Germany</span>
    <span class="footer-badge">🇧🇪 Belgium</span>
  </div>
</div>

{% stylesheet %}
delivery-picker {
  display: block;
  container: delivery-picker / inline-size;
  padding: 8px 0;
}

delivery-picker[loading="true"] {
  cursor: wait;
  pointer-events: none;
  opacity: .5;
}

.delivery-zone__form {
    width: 100%;
}

.delivery-picker {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.delivery-zone__form form {
  display: flex;
  gap: 8px;
}

.delivery-zone__form input,
.delivery-zone__form select {
  width: 100%;
}

@media screen and (min-width: 750px) {
  .delivery-zone__form form {
    grid-template-columns: 125px 4fr 1fr;
  }
}

.delivery-zones {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
}

@media screen and (min-width: 750px) {
  .delivery-zones {
    grid-template-columns: repeat(4, 1fr);
  }
}

.delivery-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2px;
  padding: 8px 12px;
  background-color: oklch(96.3% 0.002 197.1);
  border-radius: 3px;
  border: 1px solid oklch(96.3% 0.002 197.1);
  font-size: 14px;
}

.delivery-zone:hover {
  border-color: oklch(92.5% 0.005 214.3);
}

.delivery-zone--active {
  border-color: oklch(38.1% 0.176 304.987);
  background-color: oklch(49.6% 0.265 301.924);
  color: #fff;
}

.delivery-picker__error {
  display: none;
  grid-column: 1 / -1;
  color: oklch(40% 0.18 25);
  font-size: 14px;
  padding: 8px 12px;
  border: 1px solid oklch(65% 0.18 25);
  border-radius: 4px;
  background: oklch(97% 0.04 25);
  margin-bottom: 4px;
}

delivery-picker[delivery-error] .delivery-picker__error {
  display: block;
}

